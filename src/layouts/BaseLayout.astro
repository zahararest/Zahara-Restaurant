---
import '../styles/global.css';
import Header        from '../components/Header.astro';
import Footer        from '../components/Footer.astro';
import Motion        from '../components/Motion.astro';
import Accessibility from '../components/Accessibility.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import { RESTAURANT } from '../data/restaurant';
import { PHOTOS } from '../data/photos';
import type { PhotoEntry } from '../data/photos';
import { resized, resizedSrcset, resizedMobileCoverSrcset } from '../lib/photo';
import { pick, layout as labels, header as headerLabels } from '../data/i18n';

// ── Analytics / Ads — opt-in via Cloudflare Pages environment variables ──
// Set these as "Variables" (not Secrets) in the Cloudflare Pages dashboard
// under Settings → Environment Variables so they are baked into the build.
//
//   PUBLIC_GOOGLE_ADS_ID        — Google Ads conversion tag, e.g. AW-XXXXXXXXX
//   PUBLIC_GA_MEASUREMENT_ID    — Google Analytics 4, e.g. G-XXXXXXXXXX
//   PUBLIC_GSC_VERIFICATION     — Google Search Console meta verification code
//
// Leave any variable unset to omit the corresponding tag entirely.
const googleAdsId     = import.meta.env.PUBLIC_GOOGLE_ADS_ID     || '';
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID  || '';
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION   || '';
// Use Ads ID for gtag if set, otherwise fall back to GA4 ID
const gtagId          = googleAdsId || gaMeasurementId;

export interface Props {
  title:           string;
  /** Full <title> override — keyword-led, used verbatim. Falls back to
   *  "{title} — {brand}" when omitted. */
  seoTitle?:       string;
  description?:    string;
  lang?:           'he' | 'en';
  /** Set true on pages whose hero is a full-bleed photo behind the header. */
  transparentHeader?: boolean;
  /** When set, emit a responsive high-priority preload for this page's LCP
   *  hero image so it downloads during head parse (reliable, early LCP). */
  heroImage?:      PhotoEntry;
}

const {
  title,
  seoTitle,
  lang = 'he',
  transparentHeader = false,
  heroImage,
} = Astro.props;
const dir = lang === 'he' ? 'rtl' : 'ltr';
const t = pick(labels, lang);

const description = Astro.props.description || t.defaultDescription;
const keywords    = t.keywords;
const brandName   = RESTAURANT.name[lang];
const fullTitle   = seoTitle || `${title} — ${brandName}`;
const reserveLabel = pick(headerLabels, lang).reserve;

const path    = Astro.url.pathname;
const altPath = lang === 'he'
  ? (path === '/' ? '/en/' : `/en${path}`)
  : (path.replace(/^\/en/, '') || '/');

const origin   = Astro.url.origin;
// The Hebrew (default-locale) URL of THIS page — used for x-default so the
// fallback points at the same page's default version, not the home page.
const heHref   = lang === 'he' ? Astro.url.href : new URL(altPath, origin).href;
const heroUrl  = new URL(PHOTOS.hero.src, origin).href;
const imageUrls = [PHOTOS.hero, PHOTOS.moodDining, PHOTOS.contact]
  .map((p) => new URL(p.src, origin).href);

// A @graph so the page can describe the restaurant (primary), the website,
// AND its sister restaurant Angelica — they're run by the same team, and the
// cross-reference helps the page surface for "Angelica" searches too.
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type':       'Restaurant',
      '@id':         `${origin}/#restaurant`,
      name:          RESTAURANT.name.en,
      alternateName: ['זהרה', 'מסעדת זהרה', 'Zahara Jerusalem', 'Zahara Restaurant'],
      description:   t.defaultDescription,
      slogan:        lang === 'he' ? 'אחותה הצעירה של אנג׳ליקה' : "Angelica's younger sister",
      url:           `${origin}/`,
      image:         imageUrls,
      logo:          `${origin}/favicon.svg`,
      address: {
        '@type':         'PostalAddress',
        streetAddress:   RESTAURANT.address.streetAddress,
        addressLocality: RESTAURANT.address.city,
        addressRegion:   'Jerusalem District',
        addressCountry:  RESTAURANT.address.country,
      },
      geo: {
        '@type':    'GeoCoordinates',
        latitude:   RESTAURANT.geo.lat,
        longitude:  RESTAURANT.geo.lng,
      },
      areaServed:          { '@type': 'City', name: 'Jerusalem', alternateName: 'ירושלים' },
      telephone:           `+972-${RESTAURANT.phone.display.replace(/^0/, '')}`,
      email:               RESTAURANT.email,
      servesCuisine:       ['Kosher', 'Contemporary Mediterranean', 'French', 'Asian', 'כשרה'],
      acceptsReservations: 'True',
      priceRange:          '$$$',
      currenciesAccepted:  'ILS',
      paymentAccepted:     'Cash, Credit Card',
      keywords,
      hasMenu:             `${origin}/menu/`,
      hasMap:              `https://maps.google.com/?q=${encodeURIComponent(RESTAURANT.address.maps)}`,
      amenityFeature: [
        { '@type': 'LocationFeatureSpecification', name: 'Kosher',       value: true },
        { '@type': 'LocationFeatureSpecification', name: 'כשרה',         value: true },
        { '@type': 'LocationFeatureSpecification', name: 'Reservations', value: true },
        { '@type': 'LocationFeatureSpecification', name: 'Accessible',   value: true },
      ],
      employee: {
        '@type':        'Person',
        name:           RESTAURANT.chef.en,
        alternateName:  RESTAURANT.chef.he,
        jobTitle:       lang === 'he' ? 'שף' : 'Chef',
      },
      openingHoursSpecification: [{
        '@type':    'OpeningHoursSpecification',
        dayOfWeek:  [...RESTAURANT.hours.days],
        opens:      RESTAURANT.hours.opens,
        closes:     RESTAURANT.hours.closes,
      }],
      isPartOf:  { '@type': 'Hotel', name: RESTAURANT.hotel.en, '@id': `${origin}/#hotel` },
      // Official profiles — strengthens entity recognition (knowledge panel)
      // and ties the site to the restaurant's social presence.
      sameAs:    [RESTAURANT.instagram, RESTAURANT.facebook].filter(Boolean),
      // Lets Google surface a "Reserve a table" action that deep-links to the
      // Tabit booking page — a high-value affordance for local restaurant search.
      potentialAction: {
        '@type': 'ReserveAction',
        target: {
          '@type':        'EntryPoint',
          urlTemplate:    RESTAURANT.reservationUrl,
          inLanguage:     lang === 'he' ? 'he-IL' : 'en-US',
          actionPlatform: [
            'http://schema.org/DesktopWebPlatform',
            'http://schema.org/IOSPlatform',
            'http://schema.org/AndroidPlatform',
          ],
        },
        result: {
          '@type': 'FoodEstablishmentReservation',
          name:    lang === 'he' ? 'הזמנת שולחן' : 'Table reservation',
        },
      },
      mainEntityOfPage: `${origin}/`,
    },
    {
      '@type':       'Restaurant',
      '@id':         `${origin}/#angelica`,
      name:          RESTAURANT.sisterName.en,
      alternateName: ['אנג׳ליקה', 'מסעדת אנג׳ליקה', 'Angelica Jerusalem'],
      description:   lang === 'he'
        ? 'אנג׳ליקה — מוסד קולינרי ותיק בירושלים, המסעדה האחות של זהרה.'
        : 'Angelica — a longstanding Jerusalem culinary institution and the sister restaurant of Zahara.',
      areaServed:    { '@type': 'City', name: 'Jerusalem' },
      servesCuisine: ['Mediterranean', 'Kosher'],
    },
    {
      '@type':       'WebSite',
      '@id':         `${origin}/#website`,
      name:          'Zahara',
      alternateName: ['זהרה', 'מסעדת זהרה'],
      url:           `${origin}/`,
      inLanguage:    lang === 'he' ? 'he-IL' : 'en-US',
      publisher:     { '@id': `${origin}/#restaurant` },
    },
  ],
};
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon"             type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon"                     href="/favicon.svg" />
    <link rel="manifest"                             href="/site.webmanifest" />

    {/* LCP hero preload — art-directed to match HeroBleed's <picture> exactly,
        so the browser starts the hero download during head parse rather than
        when the parser reaches the <img>. Makes the LCP fire early and
        reliably (it was intermittently slipping past the metric window). */}
    {heroImage && (
      <>
        {/* quality 70 must match HeroBleed.astro's HERO_QUALITY exactly, or
            the preload URL won't match the <picture> and the bytes are wasted. */}
        <link rel="preload" as="image" fetchpriority="high"
              imagesrcset={resizedMobileCoverSrcset(heroImage.src, [[640, 1180], [820, 1500], [1080, 1980]], 70)}
              imagesizes="100vw" media="(max-width: 600px)" />
        <link rel="preload" as="image" fetchpriority="high"
              imagesrcset={resizedSrcset(heroImage.src, [800, 1200, 1800, 2400], 70)}
              imagesizes="100vw" media="(min-width: 601px)" />
      </>
    )}

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords"    content={keywords} />
    {/* Match the system theme: cream chrome in light, dark in dark mode. */}
    <meta name="theme-color" content="#F4EDDF" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1A1410" media="(prefers-color-scheme: dark)" />
    <meta name="format-detection" content="telephone=yes" />

    <link rel="canonical"      href={Astro.url.href} />
    <link rel="alternate" hreflang={lang}                         href={Astro.url.href} />
    <link rel="alternate" hreflang={lang === 'he' ? 'en' : 'he'} href={new URL(altPath, Astro.url.origin).href} />
    <link rel="alternate" hreflang="x-default"                   href={heHref} />

    <meta property="og:type"           content="website" />
    <meta property="og:title"          content={fullTitle} />
    <meta property="og:description"    content={description} />
    <meta property="og:url"            content={Astro.url.href} />
    <meta property="og:locale"         content={lang === 'he' ? 'he_IL' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'he' ? 'en_US' : 'he_IL'} />
    <meta property="og:site_name"      content="Zahara" />
    <meta property="og:image"          content={new URL(PHOTOS.hero.src, Astro.url.origin).href} />
    <meta property="og:image:alt"      content={PHOTOS.hero.alt[lang]} />
    <meta name="twitter:card"          content="summary_large_image" />
    <meta name="twitter:title"         content={fullTitle} />
    <meta name="twitter:description"   content={description} />
    <meta name="twitter:image"         content={new URL(PHOTOS.hero.src, Astro.url.origin).href} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />

    {/* Google Search Console ownership verification — add PUBLIC_GSC_VERIFICATION
        as a Cloudflare Pages build variable to activate. */}
    {gscVerification && (
      <meta name="google-site-verification" content={gscVerification} />
    )}

    {/* Google tag (Ads + Analytics) — loaded only when PUBLIC_GOOGLE_ADS_ID or
        PUBLIC_GA_MEASUREMENT_ID is set as a Cloudflare Pages build variable.
        Uses async loading so it never blocks first paint. */}
    {gtagId && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gtagId}`}></script>
        <script is:inline define:vars={{ gtagId, googleAdsId, gaMeasurementId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}

          // Consent Mode v2 — default DENIED so Google writes no analytics or
          // advertising cookies until the visitor opts in via the consent
          // banner. Required for EU/EEA visitors (GDPR + ePrivacy) and aligns
          // with the informed-consent expectation under Israel's Privacy
          // Protection Law. gtag.js still loads (cookieless ping only) so
          // measurement can resume the instant consent is granted.
          gtag('consent', 'default', {
            ad_storage:         'denied',
            analytics_storage:  'denied',
            ad_user_data:       'denied',
            ad_personalization: 'denied',
            wait_for_update:    500,
          });
          // Replay a returning visitor's prior acceptance so they aren't
          // re-prompted and tracking resumes on this very page load.
          try {
            if (localStorage.getItem('zahara-consent') === 'granted') {
              gtag('consent', 'update', {
                ad_storage:         'granted',
                analytics_storage:  'granted',
                ad_user_data:       'granted',
                ad_personalization: 'granted',
              });
            }
          } catch (_) { /* storage blocked — stay denied */ }

          gtag('js', new Date());
          if (googleAdsId) gtag('config', googleAdsId);
          if (gaMeasurementId && gaMeasurementId !== googleAdsId) gtag('config', gaMeasurementId);
        </script>
      </>
    )}

    {/* Fonts are self-hosted in /public/fonts/ via src/styles/font-faces.css.
        Single bilingual family (AlenbiSerif, Regular + Bold) covers display +
        body for both Hebrew and English. No Google CDN requests — no
        third-party IP logging on page load. To change fonts: edit
        src/styles/font-config.css */}

    {/* Preload the above-the-fold faces — AlenbiSerif Regular (body) and
        Bold (display), used on every page regardless of language. */}
    <link rel="preload" href="/fonts/AlenbiSerifRegular_web/AlenbiSerif-Regular.woff2"
          as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/AlenbiSerifBold_web/AlenbiSerif-Bold.woff2"
          as="font" type="font/woff2" crossorigin />

    {/* Theme + palette pre-paint — runs SYNCHRONOUSLY before <body>
        renders so the page paints once in the visitor's chosen theme
        AND with any palette overrides they've saved on /admin/colors/.

        The palette is injected as a real <style> element holding two
        blocks — `:root{…light…}` and `html[data-theme="dark"]{…dark…}` —
        NOT as inline styles on <html>. This is deliberate: inline styles
        beat every selector, so the previous inline approach made dark
        mode impossible to apply over a saved light palette. With a
        <style> block the cascade is honest:
          :root defaults  <  injected :root light  <  html[data-theme=dark]
        so toggling the theme actually changes the page. */}
    <script is:inline>
      (function () {
        var root = document.documentElement;

        // ── 0. Animation-ready gate (LCP-safe) ────────────────────
        // Reveal animations (word/line masks, fade-up, .reveal-on-scroll)
        // start from a HIDDEN state. If that hidden state shipped in the
        // static HTML, the hero headline — the LCP element — would be
        // invisible until JS ran, and Lighthouse would report NO_LCP.
        //
        // So the hidden states are scoped under `html.anim-ready`, which we
        // add HERE, synchronously, before first paint — but ONLY when JS is
        // running AND the visitor hasn't asked for reduced motion. Result:
        //   • JS on, motion ok  → class present → elements hide then animate.
        //   • JS off / reduced  → class absent  → everything paints visible
        //                          immediately, so LCP is the hero text.
        try {
          if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            root.classList.add('anim-ready');
          }
        } catch (_) { /* matchMedia unsupported — leave content visible */ }

        // ── 1. Theme (two states only: light + dark) ──────────────
        try {
          var saved = localStorage.getItem('zahara-theme');
          root.setAttribute('data-theme', saved === 'light' ? 'light' : 'dark');
        } catch (_) {
          root.setAttribute('data-theme', 'dark');
        }

        // ── 2. Palette overrides (light + dark) ───────────────────
        // Normalise any stored value into { light:{}, dark:{} } — older
        // installs saved a flat { "--token":"#hex" } map (light only).
        function normalisePair(raw) {
          var pair = { light: {}, dark: {} };
          if (!raw || typeof raw !== 'object') return pair;
          var looksFlat = false, k;
          for (k in raw) { if (k.indexOf('--') === 0) { looksFlat = true; break; } }
          var src = looksFlat ? { light: raw } : raw;
          ['light', 'dark'].forEach(function (mode) {
            var m = src[mode];
            if (m && typeof m === 'object') {
              for (var t in m) {
                if (t.indexOf('--') === 0 && typeof m[t] === 'string') pair[mode][t] = m[t];
              }
            }
          });
          return pair;
        }
        function bodyOf(map) {
          var out = '';
          for (var k in map) out += k + ':' + map[k] + ';';
          return out;
        }
        function cssFor(pair) {
          var css = '';
          var l = bodyOf(pair.light), d = bodyOf(pair.dark);
          if (l) css += ':root{' + l + '}';
          if (d) css += 'html[data-theme="dark"]{' + d + '}';
          return css;
        }
        var styleEl = null;
        function applyOverrides(raw) {
          var css = cssFor(normalisePair(raw));
          if (!css) { if (styleEl) styleEl.textContent = ''; return; }
          if (!styleEl) {
            styleEl = document.createElement('style');
            styleEl.id = 'zahara-palette-overrides';
            document.head.appendChild(styleEl);
          }
          styleEl.textContent = css;
        }
        function clearAll() { if (styleEl) styleEl.textContent = ''; }
        try {
          var paletteRaw = localStorage.getItem('zahara-color-overrides');
          if (paletteRaw) applyOverrides(JSON.parse(paletteRaw));
        } catch (_) { /* localStorage blocked or bad JSON — fine */ }

        // ── 3. Live cross-tab updates ─────────────────────────────
        try {
          var bc = new BroadcastChannel('zahara-colors');
          bc.addEventListener('message', function (ev) {
            var d = ev && ev.data;
            if (!d) return;
            if (d.type === 'reset') { clearAll(); return; }
            if (d.type === 'colors-changed') applyOverrides(d.overrides || {});
          });
        } catch (_) { /* BroadcastChannel unsupported — refresh to see */ }

        // ── 4. Cross-tab THEME sync via storage events ───────────
        try {
          window.addEventListener('storage', function (e) {
            if (e.key === 'zahara-theme') {
              root.setAttribute('data-theme', e.newValue === 'dark' ? 'dark' : 'light');
            }
          });
        } catch (_) {}
      })();
    </script>

    {/* Per-page head injection — pages that want to preload images
        (e.g. the home page's cinematic menu chapter photos) can drop
        <link rel="preload"> tags via the named "head" slot. */}
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">
      {t.skipToContent}
    </a>
    <div class="scroll-progress" aria-hidden="true">
      <div class="scroll-progress__bar"></div>
    </div>
    <Header lang={lang} transparent={transparentHeader} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />

    {/* Persistent floating Reserve CTA — the primary action, lifted out of
        the header so it's always one tap away. Sits at the inline-end
        corner; the scroll-to-top button stacks above it once it appears. */}
    <a class="floating-reserve" href={RESTAURANT.reservationUrl} target="_blank" rel="noopener" aria-label={reserveLabel}>
      <svg class="floating-reserve__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="17" rx="2" />
        <path d="M3 9h18M8 2v4M16 2v4" />
      </svg>
      <span class="floating-reserve__label">{reserveLabel}</span>
    </a>
    <script is:inline>
      (function () {
        var fr = document.querySelector('.floating-reserve');
        if (!fr) return;
        var heroBtn = document.querySelector('[data-hero-reserve]');
        if (heroBtn && 'IntersectionObserver' in window) {
          // Home: show the floating button only once the hero's "Reserve a
          // table" button has scrolled out of view.
          new IntersectionObserver(function (entries) {
            fr.classList.toggle('is-visible', !entries[0].isIntersecting);
          }, { threshold: 0 }).observe(heroBtn);
        } else {
          // Inner pages (no hero reserve): reveal after a little scrolling.
          var onScroll = function () {
            fr.classList.toggle('is-visible', window.scrollY > window.innerHeight * 0.5);
          };
          onScroll();
          window.addEventListener('scroll', onScroll, { passive: true });
        }
      })();
    </script>

    {/* Editable-copy overlay. The middleware injects the owner's saved
        text as a <script id="zahara-content"> JSON blob in <head>; this
        applies it to every [data-content-key] element. Runs synchronously
        here (after the content is in the DOM, before Motion boots) so any
        overridden heading is in place BEFORE the word-reveal splitter runs.
        No network call — the data is already inline. */}
    <script is:inline>
      (function () {
        var tag = document.getElementById('zahara-content');
        if (!tag) return;
        var data;
        try { data = JSON.parse(tag.textContent || '{}'); } catch (e) { return; }
        var lang = document.documentElement.getAttribute('lang') === 'en' ? 'en' : 'he';
        var nodes = document.querySelectorAll('[data-content-key]');
        for (var i = 0; i < nodes.length; i++) {
          var node = nodes[i];
          var entry = data[node.getAttribute('data-content-key')];
          if (!entry) continue;
          var v = entry[lang];
          // A present override is applied even when empty — an explicit ''
          // means the owner cleared the field to HIDE this text.
          if (typeof v !== 'string') continue;
          if (node.hasAttribute('data-content-html')) node.innerHTML = v;
          else node.textContent = v;
        }
      })();
    </script>

    {/* Motion owns every animation primitive — reveals, section HUD,
        parallax, progress bar, past-hero hand-off. Native browser scroll
        only; no Lenis. */}
    <Motion lang={lang} />

    {/* Accessibility toolkit — required on Israeli public-facing sites. */}
    <Accessibility lang={lang} />

    {/* Cookie consent — only rendered when a Google tag is active. Until the
        visitor accepts, Consent Mode v2 (set in <head>) keeps analytics/ads
        cookies off, so a site with no gtag never shows this and sets no
        tracking cookies at all. */}
    {gtagId && <ConsentBanner lang={lang} />}
  </body>
</html>
