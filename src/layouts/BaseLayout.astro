---
import '../styles/global.css';
import Header        from '../components/Header.astro';
import Footer        from '../components/Footer.astro';
import Motion        from '../components/Motion.astro';
import Accessibility from '../components/Accessibility.astro';
import { RESTAURANT } from '../data/restaurant';
import { PHOTOS } from '../data/photos';

export interface Props {
  title:           string;
  description?:    string;
  lang?:           'he' | 'en';
  /** Set true on pages whose hero is a full-bleed photo behind the header. */
  transparentHeader?: boolean;
}

const {
  title,
  lang = 'he',
  transparentHeader = false,
} = Astro.props;
const dir = lang === 'he' ? 'rtl' : 'ltr';

const defaultDescription = lang === 'he'
  ? "זהרה — מסעדת שף כשרה במלון נוצ׳ה, ירושלים. מטבח ים-תיכוני עכשווי, טכניקה צרפתית, השפעות אסייתיות. שף רועי אחדות."
  : "Zahara — a kosher chef's restaurant inside Nucha Hotel, Jerusalem. Contemporary Mediterranean kitchen with French technique and Asian influences. Chef Roi Achdut.";

const description = Astro.props.description || defaultDescription;
const brandName   = RESTAURANT.name[lang];
const fullTitle   = `${title} — ${brandName}`;

const path    = Astro.url.pathname;
const altPath = lang === 'he'
  ? (path === '/' ? '/en/' : `/en${path}`)
  : (path.replace(/^\/en/, '') || '/');

const schema = {
  '@context': 'https://schema.org',
  '@type':    'Restaurant',
  name:             RESTAURANT.name.en,
  alternateName:    RESTAURANT.name.he,
  description,
  address: {
    '@type':         'PostalAddress',
    streetAddress:   RESTAURANT.address.streetAddress,
    addressLocality: RESTAURANT.address.city,
    addressCountry:  RESTAURANT.address.country,
  },
  telephone:           `+972-${RESTAURANT.phone.display.replace(/^0/, '')}`,
  servesCuisine:       ['Contemporary', 'Mediterranean', 'French', 'Asian'],
  acceptsReservations: 'True',
  priceRange:          '$$$',
  hasMenu:             `${Astro.url.origin}/menu/`,
  openingHoursSpecification: [{
    '@type':    'OpeningHoursSpecification',
    dayOfWeek:  [...RESTAURANT.hours.days],
    opens:      RESTAURANT.hours.opens,
    closes:     RESTAURANT.hours.closes,
  }],
  isPartOf: { '@type': 'Hotel', name: RESTAURANT.hotel.en },
};
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color"   content="#F4EDDF" />
    <meta name="format-detection" content="telephone=yes" />

    <link rel="canonical"      href={Astro.url.href} />
    <link rel="alternate" hreflang={lang}                         href={Astro.url.href} />
    <link rel="alternate" hreflang={lang === 'he' ? 'en' : 'he'} href={new URL(altPath, Astro.url.origin).href} />
    <link rel="alternate" hreflang="x-default"                   href={new URL('/', Astro.url.origin).href} />

    <meta property="og:type"           content="website" />
    <meta property="og:title"          content={fullTitle} />
    <meta property="og:description"    content={description} />
    <meta property="og:url"            content={Astro.url.href} />
    <meta property="og:locale"         content={lang === 'he' ? 'he_IL' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'he' ? 'en_US' : 'he_IL'} />
    <meta property="og:site_name"      content="Zahara" />
    <meta property="og:image"          content={new URL(PHOTOS.hero.src, Astro.url.origin).href} />
    <meta property="og:image:alt"      content={PHOTOS.hero.alt[lang]} />
    <meta name="twitter:card"          content="summary_large_image" />
    <meta name="twitter:title"         content={fullTitle} />
    <meta name="twitter:description"   content={description} />
    <meta name="twitter:image"         content={new URL(PHOTOS.hero.src, Astro.url.origin).href} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Frank+Ruhl+Libre:wght@300;400;500;700&family=Heebo:wght@300;400;500;600&family=Inter:wght@300;400;500;600&family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..600,0..100;1,9..144,300..600,0..100&display=swap"
      rel="stylesheet"
    />

    {/* Theme + palette pre-paint — runs SYNCHRONOUSLY before <body>
        renders so the page paints once in the visitor's chosen theme
        AND with any palette overrides they've saved on /admin/colors/.
        Without the localStorage palette read here, admin/colors changes
        only applied to whichever public tab was open at the moment
        the admin saved (via BroadcastChannel); navigating to a different
        page reset to defaults. Reading localStorage on every load is
        what actually makes the colour editor feel "global". */}
    <script is:inline>
      (function () {
        var root = document.documentElement;

        // ── 1. Theme (two states only: light + dark) ──────────────
        try {
          var saved = localStorage.getItem('zahara-theme');
          root.setAttribute('data-theme', saved === 'dark' ? 'dark' : 'light');
        } catch (_) {
          root.setAttribute('data-theme', 'light');
        }

        // ── 2. Palette overrides ──────────────────────────────────
        // Layer order on a deployed site:
        //   :root defaults (light tokens)
        //   ← server middleware <style> (admin's saved palette, if any)
        //   ← these inline overrides from localStorage (mirrors above)
        //   ← html[data-theme="dark"] (specificity beats all of the above)
        // We track which props we set so a subsequent reset can clear
        // exactly those without touching, e.g., --a11y-font-scale.
        var applied = new Set();
        function applyOverrides(ov) {
          if (!ov) return;
          for (var key of Array.from(applied)) {
            if (!(key in ov)) {
              root.style.removeProperty(key);
              applied.delete(key);
            }
          }
          for (var k in ov) {
            var v = ov[k];
            if (typeof k === 'string' && k.indexOf('--') === 0 && typeof v === 'string') {
              root.style.setProperty(k, v);
              applied.add(k);
            }
          }
        }
        function clearAll() {
          for (var key of Array.from(applied)) root.style.removeProperty(key);
          applied.clear();
        }
        try {
          var paletteRaw = localStorage.getItem('zahara-color-overrides');
          if (paletteRaw) applyOverrides(JSON.parse(paletteRaw));
        } catch (_) { /* localStorage blocked or bad JSON — fine */ }

        // ── 3. Live cross-tab updates ─────────────────────────────
        try {
          var bc = new BroadcastChannel('zahara-colors');
          bc.addEventListener('message', function (ev) {
            var d = ev && ev.data;
            if (!d) return;
            if (d.type === 'reset') { clearAll(); return; }
            if (d.type === 'colors-changed') applyOverrides(d.overrides || {});
          });
        } catch (_) { /* BroadcastChannel unsupported — refresh to see */ }

        // ── 4. Cross-tab THEME sync via storage events ───────────
        try {
          window.addEventListener('storage', function (e) {
            if (e.key === 'zahara-theme') {
              root.setAttribute('data-theme', e.newValue === 'dark' ? 'dark' : 'light');
            }
          });
        } catch (_) {}
      })();
    </script>

    {/* Per-page head injection — pages that want to preload images
        (e.g. the home page's cinematic menu chapter photos) can drop
        <link rel="preload"> tags via the named "head" slot. */}
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">
      {lang === 'he' ? 'דלג לתוכן' : 'Skip to content'}
    </a>
    <div class="scroll-progress" aria-hidden="true">
      <div class="scroll-progress__bar"></div>
    </div>
    <Header lang={lang} transparent={transparentHeader} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    {/* Motion owns every animation primitive — reveals, section HUD,
        parallax, progress bar, past-hero hand-off. Native browser scroll
        only; no Lenis. */}
    <Motion />

    {/* Accessibility toolkit — required on Israeli public-facing sites. */}
    <Accessibility lang={lang} />
  </body>
</html>
