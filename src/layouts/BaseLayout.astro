---
import '../styles/global.css';
import Header        from '../components/Header.astro';
import Footer        from '../components/Footer.astro';
import Motion        from '../components/Motion.astro';
import Accessibility from '../components/Accessibility.astro';
import { RESTAURANT } from '../data/restaurant';
import { PHOTOS } from '../data/photos';

// ── Analytics / Ads — opt-in via Cloudflare Pages environment variables ──
// Set these as "Variables" (not Secrets) in the Cloudflare Pages dashboard
// under Settings → Environment Variables so they are baked into the build.
//
//   PUBLIC_GOOGLE_ADS_ID        — Google Ads conversion tag, e.g. AW-XXXXXXXXX
//   PUBLIC_GA_MEASUREMENT_ID    — Google Analytics 4, e.g. G-XXXXXXXXXX
//   PUBLIC_GSC_VERIFICATION     — Google Search Console meta verification code
//
// Leave any variable unset to omit the corresponding tag entirely.
const googleAdsId     = import.meta.env.PUBLIC_GOOGLE_ADS_ID     || '';
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID  || '';
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION   || '';
// Use Ads ID for gtag if set, otherwise fall back to GA4 ID
const gtagId          = googleAdsId || gaMeasurementId;

export interface Props {
  title:           string;
  description?:    string;
  lang?:           'he' | 'en';
  /** Set true on pages whose hero is a full-bleed photo behind the header. */
  transparentHeader?: boolean;
}

const {
  title,
  lang = 'he',
  transparentHeader = false,
} = Astro.props;
const dir = lang === 'he' ? 'rtl' : 'ltr';

const defaultDescription = lang === 'he'
  ? "זהרה — מסעדת שף כשרה במלון נוצ׳ה, ירושלים. מטבח ים-תיכוני עכשווי, טכניקה צרפתית, השפעות אסייתיות. שף רועי אחדות."
  : "Zahara — a kosher chef's restaurant inside Nucha Hotel, Jerusalem. Contemporary Mediterranean kitchen with French technique and Asian influences. Chef Roi Achdut.";

const description = Astro.props.description || defaultDescription;
const brandName   = RESTAURANT.name[lang];
const fullTitle   = `${title} — ${brandName}`;

const path    = Astro.url.pathname;
const altPath = lang === 'he'
  ? (path === '/' ? '/en/' : `/en${path}`)
  : (path.replace(/^\/en/, '') || '/');

const schema = {
  '@context': 'https://schema.org',
  '@type':    'Restaurant',
  name:             RESTAURANT.name.en,
  alternateName:    RESTAURANT.name.he,
  description,
  address: {
    '@type':         'PostalAddress',
    streetAddress:   RESTAURANT.address.streetAddress,
    addressLocality: RESTAURANT.address.city,
    addressCountry:  RESTAURANT.address.country,
  },
  telephone:           `+972-${RESTAURANT.phone.display.replace(/^0/, '')}`,
  servesCuisine:       ['Contemporary', 'Mediterranean', 'French', 'Asian'],
  acceptsReservations: 'True',
  priceRange:          '$$$',
  hasMenu:             `${Astro.url.origin}/menu/`,
  openingHoursSpecification: [{
    '@type':    'OpeningHoursSpecification',
    dayOfWeek:  [...RESTAURANT.hours.days],
    opens:      RESTAURANT.hours.opens,
    closes:     RESTAURANT.hours.closes,
  }],
  isPartOf: { '@type': 'Hotel', name: RESTAURANT.hotel.en },
};
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon"             type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon"                     href="/favicon.svg" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color"   content="#F4EDDF" />
    <meta name="format-detection" content="telephone=yes" />

    <link rel="canonical"      href={Astro.url.href} />
    <link rel="alternate" hreflang={lang}                         href={Astro.url.href} />
    <link rel="alternate" hreflang={lang === 'he' ? 'en' : 'he'} href={new URL(altPath, Astro.url.origin).href} />
    <link rel="alternate" hreflang="x-default"                   href={new URL('/', Astro.url.origin).href} />

    <meta property="og:type"           content="website" />
    <meta property="og:title"          content={fullTitle} />
    <meta property="og:description"    content={description} />
    <meta property="og:url"            content={Astro.url.href} />
    <meta property="og:locale"         content={lang === 'he' ? 'he_IL' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'he' ? 'en_US' : 'he_IL'} />
    <meta property="og:site_name"      content="Zahara" />
    <meta property="og:image"          content={new URL(PHOTOS.hero.src, Astro.url.origin).href} />
    <meta property="og:image:alt"      content={PHOTOS.hero.alt[lang]} />
    <meta name="twitter:card"          content="summary_large_image" />
    <meta name="twitter:title"         content={fullTitle} />
    <meta name="twitter:description"   content={description} />
    <meta name="twitter:image"         content={new URL(PHOTOS.hero.src, Astro.url.origin).href} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />

    {/* Google Search Console ownership verification — add PUBLIC_GSC_VERIFICATION
        as a Cloudflare Pages build variable to activate. */}
    {gscVerification && (
      <meta name="google-site-verification" content={gscVerification} />
    )}

    {/* Google tag (Ads + Analytics) — loaded only when PUBLIC_GOOGLE_ADS_ID or
        PUBLIC_GA_MEASUREMENT_ID is set as a Cloudflare Pages build variable.
        Uses async loading so it never blocks first paint. */}
    {gtagId && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gtagId}`}></script>
        <script is:inline define:vars={{ gtagId, googleAdsId, gaMeasurementId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          if (googleAdsId) gtag('config', googleAdsId);
          if (gaMeasurementId && gaMeasurementId !== googleAdsId) gtag('config', gaMeasurementId);
        </script>
      </>
    )}

    {/* Fonts are self-hosted in /public/fonts/ via src/styles/font-faces.css.
        Single bilingual family (Alef, Regular + Bold) covers display + body
        for both languages. No Google CDN requests — no third-party IP
        logging on page load. To change fonts: edit src/styles/font-config.css */}

    {/* Theme + palette pre-paint — runs SYNCHRONOUSLY before <body>
        renders so the page paints once in the visitor's chosen theme
        AND with any palette overrides they've saved on /admin/colors/.

        The palette is injected as a real <style> element holding two
        blocks — `:root{…light…}` and `html[data-theme="dark"]{…dark…}` —
        NOT as inline styles on <html>. This is deliberate: inline styles
        beat every selector, so the previous inline approach made dark
        mode impossible to apply over a saved light palette. With a
        <style> block the cascade is honest:
          :root defaults  <  injected :root light  <  html[data-theme=dark]
        so toggling the theme actually changes the page. */}
    <script is:inline>
      (function () {
        var root = document.documentElement;

        // ── 1. Theme (two states only: light + dark) ──────────────
        try {
          var saved = localStorage.getItem('zahara-theme');
          root.setAttribute('data-theme', saved === 'light' ? 'light' : 'dark');
        } catch (_) {
          root.setAttribute('data-theme', 'dark');
        }

        // ── 2. Palette overrides (light + dark) ───────────────────
        // Normalise any stored value into { light:{}, dark:{} } — older
        // installs saved a flat { "--token":"#hex" } map (light only).
        function normalisePair(raw) {
          var pair = { light: {}, dark: {} };
          if (!raw || typeof raw !== 'object') return pair;
          var looksFlat = false, k;
          for (k in raw) { if (k.indexOf('--') === 0) { looksFlat = true; break; } }
          var src = looksFlat ? { light: raw } : raw;
          ['light', 'dark'].forEach(function (mode) {
            var m = src[mode];
            if (m && typeof m === 'object') {
              for (var t in m) {
                if (t.indexOf('--') === 0 && typeof m[t] === 'string') pair[mode][t] = m[t];
              }
            }
          });
          return pair;
        }
        function bodyOf(map) {
          var out = '';
          for (var k in map) out += k + ':' + map[k] + ';';
          return out;
        }
        function cssFor(pair) {
          var css = '';
          var l = bodyOf(pair.light), d = bodyOf(pair.dark);
          if (l) css += ':root{' + l + '}';
          if (d) css += 'html[data-theme="dark"]{' + d + '}';
          return css;
        }
        var styleEl = null;
        function applyOverrides(raw) {
          var css = cssFor(normalisePair(raw));
          if (!css) { if (styleEl) styleEl.textContent = ''; return; }
          if (!styleEl) {
            styleEl = document.createElement('style');
            styleEl.id = 'zahara-palette-overrides';
            document.head.appendChild(styleEl);
          }
          styleEl.textContent = css;
        }
        function clearAll() { if (styleEl) styleEl.textContent = ''; }
        try {
          var paletteRaw = localStorage.getItem('zahara-color-overrides');
          if (paletteRaw) applyOverrides(JSON.parse(paletteRaw));
        } catch (_) { /* localStorage blocked or bad JSON — fine */ }

        // ── 3. Live cross-tab updates ─────────────────────────────
        try {
          var bc = new BroadcastChannel('zahara-colors');
          bc.addEventListener('message', function (ev) {
            var d = ev && ev.data;
            if (!d) return;
            if (d.type === 'reset') { clearAll(); return; }
            if (d.type === 'colors-changed') applyOverrides(d.overrides || {});
          });
        } catch (_) { /* BroadcastChannel unsupported — refresh to see */ }

        // ── 4. Cross-tab THEME sync via storage events ───────────
        try {
          window.addEventListener('storage', function (e) {
            if (e.key === 'zahara-theme') {
              root.setAttribute('data-theme', e.newValue === 'dark' ? 'dark' : 'light');
            }
          });
        } catch (_) {}
      })();
    </script>

    {/* Per-page head injection — pages that want to preload images
        (e.g. the home page's cinematic menu chapter photos) can drop
        <link rel="preload"> tags via the named "head" slot. */}
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">
      {lang === 'he' ? 'דלג לתוכן' : 'Skip to content'}
    </a>
    <div class="scroll-progress" aria-hidden="true">
      <div class="scroll-progress__bar"></div>
    </div>
    <Header lang={lang} transparent={transparentHeader} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />

    {/* Editable-copy overlay. The middleware injects the owner's saved
        text as a <script id="zahara-content"> JSON blob in <head>; this
        applies it to every [data-content-key] element. Runs synchronously
        here (after the content is in the DOM, before Motion boots) so any
        overridden heading is in place BEFORE the word-reveal splitter runs.
        No network call — the data is already inline. */}
    <script is:inline>
      (function () {
        var tag = document.getElementById('zahara-content');
        if (!tag) return;
        var data;
        try { data = JSON.parse(tag.textContent || '{}'); } catch (e) { return; }
        var lang = document.documentElement.getAttribute('lang') === 'en' ? 'en' : 'he';
        var nodes = document.querySelectorAll('[data-content-key]');
        for (var i = 0; i < nodes.length; i++) {
          var node = nodes[i];
          var entry = data[node.getAttribute('data-content-key')];
          var v = entry && entry[lang];
          if (typeof v !== 'string' || v === '') continue;
          if (node.hasAttribute('data-content-html')) node.innerHTML = v;
          else node.textContent = v;
        }
      })();
    </script>

    {/* Motion owns every animation primitive — reveals, section HUD,
        parallax, progress bar, past-hero hand-off. Native browser scroll
        only; no Lenis. */}
    <Motion />

    {/* Accessibility toolkit — required on Israeli public-facing sites. */}
    <Accessibility lang={lang} />
  </body>
</html>
