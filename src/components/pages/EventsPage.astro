---
// EventsPage — dedicated private/corporate event inquiry page, linked from
// the header. Same editorial structure as the About page (intro, bleed
// photo, benefits, form) but the form is locked to event mode: the
// general/event toggle is hidden and every event-only field is shown.

import BaseLayout    from '../../layouts/BaseLayout.astro';
import BleedPhoto    from '../sections/BleedPhoto.astro';
import ContactForm   from '../sections/ContactForm.astro';
import { pick, contact as copy, eventsPage as pageCopy } from '../../data/i18n';
import { PHOTOS }    from '../../data/photos';
import type { Lang } from '../../data/i18n';

export interface Props { lang: Lang }

const { lang } = Astro.props;
const t        = pick(copy, lang);
const page     = pick(pageCopy, lang);
const title    = page.pageTitle;
const description = page.pageDescription;

const benefits = [t.benefitPrivate, t.benefitChef, t.benefitKosher, t.benefitFull];
---

<BaseLayout title={title} seoTitle={page.seoTitle} lang={lang} description={description}>
  <section class="page-intro wrap">
    <div class="stagger reveal-on-scroll">
      <p class="eyebrow">{t.eventsPageEyebrow}</p>
      <h1
        class="display"
        data-word-reveal
        data-word-reveal-delay="0.08"
        data-word-reveal-step="0.07"
        set:html={t.eventsPageHeading}
      />
      <p class="lede-prose">{t.eventsPageLede}</p>
    </div>
  </section>

  <BleedPhoto lang={lang} photo={PHOTOS.menuEvents} height="clamp(280px, 50vh, 480px)" />

  <section class="section-tight events-benefits-band">
    <div class="wrap">
      <ul class="benefits stagger reveal-on-scroll">
        {benefits.map((label, i) => (
          <li class="benefit">
            <span class="benefit__num">0{i + 1}</span>
            <span class="benefit__text">{label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <style>
    /* Warm diagonal gradient band behind the event benefits — two editable
       colour stops (--grad-warm-*) under a fixed dark wash for contrast.
       The text inside flips to the on-photo cream so it reads on the dark
       ground. */
    .events-benefits-band {
      background:
        linear-gradient(180deg,
          color-mix(in srgb, var(--shadow) 32%, transparent) 0%,
          color-mix(in srgb, var(--shadow) 16%, transparent) 30%,
          color-mix(in srgb, var(--shadow) 58%, transparent) 100%),
        linear-gradient(135deg, var(--grad-warm-from), var(--grad-warm-to));
      color: var(--paper-on-photo);
    }
    .events-benefits-band .benefit__num { color: var(--gold); }
    .events-benefits-band .benefit__text { color: var(--paper-on-photo); }
    /* Hairline grid lines flip to the on-photo tone so they read as quiet
       dividers on the dark gradient instead of disappearing. */
    .events-benefits-band .benefits {
      border-block-start-color: color-mix(in srgb, var(--paper-on-photo) 20%, transparent);
      border-inline-start-color: color-mix(in srgb, var(--paper-on-photo) 20%, transparent);
    }
    .events-benefits-band .benefit {
      border-block-end-color: color-mix(in srgb, var(--paper-on-photo) 20%, transparent);
      border-inline-end-color: color-mix(in srgb, var(--paper-on-photo) 20%, transparent);
    }
  </style>

  <ContactForm lang={lang} defaultMode="event" showToggle={false} />
</BaseLayout>
