---
// EventsPage — dedicated private/corporate event inquiry page, linked from
// the header. Same editorial structure as the About page (intro, bleed
// photo, benefits, form) but the form is locked to event mode: the
// general/event toggle is hidden and every event-only field is shown.

import BaseLayout    from '../../layouts/BaseLayout.astro';
import BleedPhoto    from '../sections/BleedPhoto.astro';
import ContactForm   from '../sections/ContactForm.astro';
import { pick, contact as copy, eventsPage as pageCopy } from '../../data/i18n';
import { PHOTOS }    from '../../data/photos';
import type { Lang } from '../../data/i18n';

export interface Props { lang: Lang }

const { lang } = Astro.props;
const t        = pick(copy, lang);
const page     = pick(pageCopy, lang);
const title    = page.pageTitle;
const description = page.pageDescription;

const benefits = [
  { label: t.benefitPrivate, key: 'events.benefit1' },
  { label: t.benefitChef,    key: 'events.benefit2' },
  { label: t.benefitKosher,  key: 'events.benefit3' },
  { label: t.benefitFull,    key: 'events.benefit4' },
];
---

<BaseLayout title={title} seoTitle={page.seoTitle} lang={lang} description={description}>
  <section class="page-intro wrap">
    <div class="stagger reveal-on-scroll">
      <p class="eyebrow" data-content-key="events.eyebrow">{t.eventsPageEyebrow}</p>
      <h1
        class="display"
        data-word-reveal
        data-word-reveal-delay="0.08"
        data-word-reveal-step="0.07"
        data-content-key="events.heading"
        set:html={t.eventsPageHeading}
      />
      <p class="lede-prose" data-content-key="events.lede">{t.eventsPageLede}</p>
    </div>
  </section>

  {/* Band height (~50vh) → near-square mobile crop, not the full-screen tall default. */}
  <BleedPhoto lang={lang} photo={PHOTOS.menuEvents} height="clamp(280px, 50vh, 480px)"
              mobileCrop={[[640, 680], [820, 870], [1080, 1150]]} />

  <section class="section-tight events-benefits-band">
    <div class="wrap">
      <ul class="benefits stagger reveal-on-scroll">
        {benefits.map((b, i) => (
          <li class="benefit">
            <span class="benefit__num">0{i + 1}</span>
            <span class="benefit__text" data-content-key={b.key}>{b.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <style>
    /* Events benefits band — fully driven by its own --events-band-* tokens
       (editable individually in /admin/colors). Light mode keeps the band in
       the cream family so it follows the page scheme; dark mode is a warm
       near-black atmosphere. No shared --shadow / --paper-on-photo / --gold
       here, so tuning the band never drags the rest of the site along. */
    .events-benefits-band {
      background: linear-gradient(160deg, var(--events-band-from), var(--events-band-to));
      color: var(--events-band-text);
    }
    .events-benefits-band .benefit__num  { color: var(--events-band-num); }
    .events-benefits-band .benefit__text { color: var(--events-band-text); }
    .events-benefits-band .benefits {
      border-block-start-color: var(--events-band-divider);
      border-inline-start-color: var(--events-band-divider);
    }
    .events-benefits-band .benefit {
      border-block-end-color: var(--events-band-divider);
      border-inline-end-color: var(--events-band-divider);
    }
  </style>

  <ContactForm lang={lang} defaultMode="event" showToggle={false} />
</BaseLayout>
