---
import BaseLayout    from '../../layouts/BaseLayout.astro';
import Photo         from '../Photo.astro';
import { pick, location as copy } from '../../data/i18n';
import { RESTAURANT } from '../../data/restaurant';
import { PHOTOS }    from '../../data/photos';
import type { Lang } from '../../data/i18n';

export interface Props { lang: Lang }

const { lang } = Astro.props;
const t        = pick(copy, lang);
const isHe     = lang === 'he';
const title    = isHe ? 'מיקום' : 'Location';

const dial     = lang === 'he' ? RESTAURANT.phone.dialHe : RESTAURANT.phone.dialEn;
const encoded  = encodeURIComponent(RESTAURANT.address.maps);
const wazeUrl  = `https://waze.com/ul?q=${encoded}`;
const gmapsUrl = `https://www.google.com/maps/search/?api=1&query=${encoded}`;
const mapEmbed = `https://www.google.com/maps?q=${encoded}&output=embed`;
---

<BaseLayout title={title} lang={lang}>
  <section class="page-intro wrap">
    <div class="stagger reveal-on-scroll">
      <p class="eyebrow">{t.eyebrow}</p>
      <h1
        class="display"
        data-word-reveal
        data-word-reveal-delay="0.08"
        data-word-reveal-step="0.07"
      >{t.heading}</h1>
      <p class="lede-prose">{t.lede}</p>
    </div>
  </section>

  <section class="section-tight wrap">
    {/* Map is not auto-loaded — clicking "Show map" sets the iframe src,
        preventing Google from receiving the visitor's IP on page load. */}
    <div class="reveal-on-scroll map-wrapper" data-map-embed={mapEmbed}>
      <div class="map-consent" data-map-consent>
        <p class="map-consent__note">
          {isHe
            ? 'המפה מסופקת על ידי Google. לחצו להצגה.'
            : 'Map provided by Google. Click to display.'}
        </p>
        <button class="btn" type="button" data-map-btn>
          {isHe ? 'הצג מפה' : 'Show map'}
        </button>
      </div>
      <iframe
        class="map-frame"
        data-map-frame
        src="about:blank"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={t.mapTitle}
        hidden
      ></iframe>
    </div>

    <div class="directions-grid stagger reveal-on-scroll">
      <a class="btn btn--block btn--ghost" href={wazeUrl}  target="_blank" rel="noopener">{t.waze}</a>
      <a class="btn btn--block btn--ghost" href={gmapsUrl} target="_blank" rel="noopener">{t.gmaps}</a>
      <a class="btn btn--block btn--ghost" href={`tel:${dial}`}>{t.call}</a>
    </div>
  </section>

  <hr class="rule" />

  <section class="section">
    <div class="wrap">
      <div class="photo-block">
        <div class="img-mask reveal-on-scroll">
          <Photo src={PHOTOS.interior.src} alt={PHOTOS.interior.alt[lang]} aspect="4/5" />
        </div>
        <div class="photo-block__content stagger reveal-on-scroll">
          <p class="eyebrow">{t.infoEyebrow}</p>
          <h2
            class="display"
            data-word-reveal
            data-word-reveal-delay="0.06"
            data-word-reveal-step="0.06"
            set:html={t.infoHeading}
          />
          <p set:html={t.infoByCar} />
          <p set:html={t.infoByTransit} />
          <p set:html={t.infoAccessibility} />
          <p set:html={t.infoBooking} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const wrapper = document.querySelector('[data-map-embed]') as HTMLElement | null;
  const btn     = document.querySelector('[data-map-btn]');
  const consent = document.querySelector('[data-map-consent]') as HTMLElement | null;
  const frame   = document.querySelector('[data-map-frame]') as HTMLIFrameElement | null;

  if (btn && wrapper && consent && frame) {
    btn.addEventListener('click', () => {
      const src = wrapper.dataset.mapEmbed || '';
      frame.src = src;
      frame.removeAttribute('hidden');
      frame.style.display = '';
      // .map-consent has display:flex which beats the [hidden] attribute,
      // so force display:none explicitly.
      consent.hidden = true;
      consent.style.display = 'none';
      // Remember consent so the map auto-loads on next visit.
      try { sessionStorage.setItem('zahara-map-shown', '1'); } catch (_) {}
    });
    // Auto-load if user already accepted this session.
    try {
      if (sessionStorage.getItem('zahara-map-shown')) {
        const src = wrapper.dataset.mapEmbed || '';
        frame.src = src;
        frame.removeAttribute('hidden');
        frame.style.display = '';
        consent.hidden = true;
        consent.style.display = 'none';
      }
    } catch (_) {}
  }
</script>

<style>
  .map-wrapper { position: relative; }
  .map-consent {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    min-height: 320px;
    border: 1px solid var(--rule-soft);
    background: var(--paper-deep);
    border-radius: 2px;
    padding: var(--space-l);
    text-align: center;
  }
  /* display:flex overrides [hidden] — explicit override needed */
  .map-consent[hidden], .map-consent[style*="display: none"] { display: none !important; }

  .map-frame {
    display: block;
    width: 100%;
    min-height: 400px;
    border: 0;
    border-radius: 2px;
  }
  .map-consent__note {
    font-size: var(--step--1);
    color: var(--ink-muted);
    margin: 0;
  }
</style>
