---
// Privacy policy page — required under Israeli Privacy Protection Law
// (חוק הגנת הפרטיות, תשמ"א-1981) and the Privacy Protection Regulations (2017)
// for any site that collects personal data (name, phone, email via contact form).

import BaseLayout from '../../layouts/BaseLayout.astro';
import { RESTAURANT } from '../../data/restaurant';
import { pick, privacyPage as pageCopy } from '../../data/i18n';
import type { Lang } from '../../data/i18n';

export interface Props { lang: Lang }
const { lang } = Astro.props;
const page = pick(pageCopy, lang);
const today = new Date().toISOString().slice(0, 10);
const phoneDial = lang === 'he' ? RESTAURANT.phone.dialHe : RESTAURANT.phone.dialEn;
const phoneText = lang === 'he' ? RESTAURANT.phone.display : RESTAURANT.phone.intlDisplay;
---

<BaseLayout title={page.pageTitle} lang={lang} description={page.pageDescription}>
  <article class="privacy-page wrap">
    <header class="privacy-page__head">
      <p class="eyebrow">{page.pageEyebrow}</p>
      <h1 class="display">{page.pageTitle}</h1>
      <p class="privacy-page__updated">
        {page.updatedLabel} · {today}
      </p>
    </header>

    <section class="privacy-page__body prose">
      <p>
        <strong>{RESTAURANT.name[lang]}</strong> {page.dataIntro}
      </p>

      <h2>{page.dataHeading}</h2>
      <p>{page.dataIntro}</p>
      <ul>
        <li>{page.dataItem1}</li>
        <li>{page.dataItem2}</li>
        <li>{page.dataItem3}</li>
        <li>{page.dataItem4}</li>
      </ul>
      <p>{page.dataPrivacyNote}</p>

      <h2>{page.usageHeading}</h2>
      <p>{page.usageIntro}</p>
      <ul>
        <li>{page.usageItem1}</li>
        <li>{page.usageItem2}</li>
      </ul>
      <p>{page.usageNote}</p>

      <h2>{page.thirdPartyHeading}</h2>
      <p set:html={page.thirdPartyParagraph1} />
      <p>{page.thirdPartyParagraph2}</p>

      <h2>{page.retentionHeading}</h2>
      <p>{page.retentionText}</p>

      <h2>{page.rightsHeading}</h2>
      <p>{page.rightsText}</p>
      <ul>
        <li>{page.contactPhoneLabel}: <a href={`tel:${phoneDial}`}>{phoneText}</a></li>
        <li>{page.contactEmailLabel}: <a href={`mailto:${RESTAURANT.email}`}>{RESTAURANT.email}</a></li>
      </ul>
      <p>{page.rightsResponse}</p>

      <h2>{page.changesHeading}</h2>
      <p>{page.changesText}</p>

      <h2>{page.contactHeading}</h2>
      <p>{page.contactText}</p>
      <ul>
        <li><strong>{page.contactRestaurant} {RESTAURANT.name[lang]}</strong></li>
        <li>{page.contactAddressLabel}: {RESTAURANT.address[lang]}</li>
        <li>{page.contactPhoneLabel}: <a href={`tel:${phoneDial}`}>{phoneText}</a></li>
        <li>{page.contactEmailLabel}: <a href={`mailto:${RESTAURANT.email}`}>{RESTAURANT.email}</a></li>
      </ul>
    </section>
  </article>
</BaseLayout>

<style>
  .privacy-page {
    padding-block: clamp(6rem, 12vw, 9rem) var(--space-2xl);
    max-width: 48rem;
  }
  .privacy-page__head { margin-block-end: var(--space-l); }
  .privacy-page__head h1 {
    font-family: var(--font-display-he);
    font-weight: 400;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0.6rem 0 0;
  }
  html[lang="en"] .privacy-page__head h1 { font-family: var(--font-display-en); }
  .privacy-page__updated {
    margin: 1rem 0 0;
    font-size: var(--step--2);
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .privacy-page__body h2 {
    font-family: var(--font-display-he);
    font-weight: 500;
    font-size: var(--step-2);
    margin: 2rem 0 0.6rem;
    color: var(--ink);
  }
  html[lang="en"] .privacy-page__body h2 { font-family: var(--font-display-en); font-weight: 400; }
  .privacy-page__body p,
  .privacy-page__body ul {
    margin: 0.6rem 0;
    color: var(--ink-soft);
    line-height: 1.75;
    font-weight: 300;
  }
  .privacy-page__body ul { padding-inline-start: 1.4rem; }
  .privacy-page__body li { margin-block: 0.3rem; }
  .privacy-page__body a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .privacy-page__body a:hover { color: var(--accent-deep); }
</style>
