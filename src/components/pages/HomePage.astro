  <div data-section-name={sec.hero}>
    <HeroBleed lang={lang} photo={PHOTOS.hero} />
  </div>

  <!-- {/* Editorial masthead — quiet magazine-style identity stamp.
      The single touch of "issue / city / year" framing the cover. */}
  <aside class="issue-stamp reveal-on-scroll" aria-label={t.issueLine}>
    <div class="wrap wrap--tight issue-stamp__inner">
      <span class="issue-stamp__line">{t.issueLine}</span>
