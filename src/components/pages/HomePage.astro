---
// HomePage — the editorial cinematic home page.
//
// This file used to fork into a "v1 editorial" and a "v2 cinematic"
// HomePageV2. They've been merged: V2's structure is the only home now,
// with three changes that came out of the last review:
//
//   1. No Lenis smooth-scroll — native browser scroll is silkier on
//      track-pads and weak GPUs. Parallax + reveals still work via the
//      vanilla Motion runtime; we just drop GSAP/ScrollTrigger pinning.
//   2. No `data-pin-cycle` on the cinematic menu — the chapters STACK
//      in normal flow (each `min-height: 100vh`), and the pin-cycle
//      CSS clamping the container to one viewport was hiding chapters
//      2-4 entirely.
//   3. A quiet magazine-masthead "issue line" sits below the hero, and
//      a "table of contents" plate introduces the menu — both add a
//      uniquely editorial moment without any flashy motion.
//
// Cinematic menu data sourcing:
//   • HE food   → server-rendered from menu-he.ts (instant first paint)
//   • Everything else hydrates client-side from /api/menu/{slug}.

import BaseLayout    from '../../layouts/BaseLayout.astro';
import HeroBleed     from '../sections/HeroBleed.astro';
import InfoStrip     from '../sections/InfoStrip.astro';
import BleedPhoto    from '../sections/BleedPhoto.astro';
import PhotoBlock    from '../sections/PhotoBlock.astro';
import PullQuote     from '../sections/PullQuote.astro';
import Gallery       from '../sections/Gallery.astro';
import InstagramFeed from '../sections/InstagramFeed.astro';

import { pick, home as copy } from '../../data/i18n';
import { PHOTOS, MENU_CATEGORY_PHOTOS } from '../../data/photos';
import type { PhotoEntry } from '../../data/photos';
import { path } from '../../lib/paths';
import { resized, resizedSrcset, resizedMobileCoverSrcset } from '../../lib/photo';
import { menuHe } from '../../data/menu-he';
import type { Lang } from '../../data/i18n';

// Chapter-photo widths. The browser picks one based on viewport size
// and DPR; we never need the full 6000px original — even 2400 is well
// over what a 4K display shows. 800 covers mobile, 1200 most laptops,
// 1800 retina, 2400 4K.
// Finer width steps so the browser can pick a variant close to the actual
// displayed size instead of jumping (e.g. a ~1400px-wide full-bleed image
// was pulling the 1800 variant). Each width is a separate cached CF transform.
const CHAPTER_WIDTHS = [800, 1100, 1400, 1700, 2100, 2560] as const;

export interface Props { lang: Lang }

const { lang } = Astro.props;
const t        = pick(copy, lang);

const title           = t.pageTitle;
const description     = t.pageDescription;
const kitchenCaption  = t.kitchenCaption;

// Gallery: a four-shot base edit (interior, chef, bar, wine) that always
// shows, plus up to six optional slots the admin can fill in /admin/images.
// Empty optional slots are hidden client-side, so the gallery grows from 4
// up to 10 photos without ever showing a blank frame.
const galleryPhotos   = [
  PHOTOS.interior, PHOTOS.chef, PHOTOS.bar, PHOTOS.wine,
];
const galleryOptional = [
  PHOTOS.gallery5, PHOTOS.gallery6, PHOTOS.gallery7,
  PHOTOS.gallery8, PHOTOS.gallery9, PHOTOS.gallery10,
];
// Per-photo caption content keys (edited per photo in /admin/images),
// parallel to the photo arrays above.
const galleryCaptionKeys  = ['interior', 'chef', 'bar', 'wine'].map(k => `gallery.caption.${k}`);
const galleryOptionalCaptionKeys =
  ['gallery5', 'gallery6', 'gallery7', 'gallery8', 'gallery9', 'gallery10'].map(k => `gallery.caption.${k}`);

const sec = {
  hero:      t.secHero,
  story:     t.secStory,
  kitchen:   t.secKitchen,
  menu:      t.secMenu,
  gallery:   t.secGallery,
  instagram: t.secInstagram,
  events:    t.secEvents,
};

// ── Cinematic menu chapters ────────────────────────────────────
// HE food sections are server-rendered from menuHe; the rest start
// empty and hydrate from /api/menu/{slug}. Layout is stable either way.
type Item = { name: string; description?: string; price: string };

// HE food sections come from the static menuHe data. For EN we fall
// through to client-side hydration (see the chapter loop below), so this
// helper is only ever called when lang === 'he'.
const findSection = (title: string): Item[] =>
  menuHe.find((s) => s.title === title)?.items.map((it) => ({
    name: it.name, description: it.description, price: it.price,
  })) ?? [];

const initialFoodStart: Item[] = lang === 'he'
  ? findSection('משהו להתחלה').slice(0, 5)
  : [];
const initialFoodMain: Item[]  = lang === 'he'
  ? findSection('כמעט הגענו').slice(0, 5)
  : [];

interface Chapter {
  id:        'food-start' | 'food-main' | 'cocktails' | 'dessert';
  menuTab:   'food' | 'cocktails' | 'dessert';
  apiSlug:   string | null;
  sectionTitle?: string;
  take:      number;
  number:    string;
  eyebrow:   string;
  title:     string;
  /** Caption shown on the table-of-contents card above the chapters. */
  tocLine:   string;
  photo:     PhotoEntry;
  initial:   Item[];
}

const chapters: Chapter[] = [
  {
    id: 'food-start', menuTab: 'food', take: 5,
    apiSlug: lang === 'he' ? 'he' : 'en',
    // Section title is language-specific — the API returns sections
    // whose `title` matches the data file for that language. Hardcoding
    // the HE title here used to silently drop the EN menu items on the
    // English home page.
    sectionTitle: lang === 'he' ? 'משהו להתחלה' : 'Beginnings',
    number: '01',
    eyebrow: t.homeChapterStartEyebrow,
    title:   t.homeChapterStartTitle,
    tocLine: t.homeChapterStartTocLine,
    photo:   MENU_CATEGORY_PHOTOS.food,
    initial: initialFoodStart,
  },
  {
    id: 'food-main', menuTab: 'food', take: 5,
    apiSlug: lang === 'he' ? 'he' : 'en',
    sectionTitle: lang === 'he' ? 'כמעט הגענו' : 'Almost There',
    number: '02',
    eyebrow: t.homeChapterMainEyebrow,
    title:   t.homeChapterMainTitle,
    tocLine: t.homeChapterMainTocLine,
    photo:   PHOTOS.kitchen,
    initial: initialFoodMain,
  },
  {
    id: 'cocktails', menuTab: 'cocktails', take: 5,
    apiSlug: 'cocktails',
    number: '03',
    eyebrow: t.homeChapterCocktailsEyebrow,
    title:   t.homeChapterCocktailsTitle,
    tocLine: t.homeChapterCocktailsTocLine,
    photo:   MENU_CATEGORY_PHOTOS.cocktails,
    initial: [],
  },
  {
    id: 'dessert', menuTab: 'dessert', take: 3,
    apiSlug: lang === 'he' ? 'dessert' : 'dessert_en',
    number: '04',
    eyebrow: t.homeChapterDessertEyebrow,
    title:   t.homeChapterDessertTitle,
    tocLine: t.homeChapterDessertTocLine,
    photo:   MENU_CATEGORY_PHOTOS.dessert,
    initial: [],
  },
];

const menuIntroEyebrow = t.menuIntroEyebrow;
const chapterCountLbl  = t.chapterCountLabel;
const fullMenuLabelFor = (tab: 'food' | 'cocktails' | 'dessert') => {
  if (tab === 'cocktails') return t.fullMenuLabelCocktails;
  if (tab === 'dessert')   return t.fullMenuLabelDessert;
  return t.fullMenuLabelFood;
};

const menuPath = path('menu', lang);
const ctaHrefFor = (tab: 'food' | 'cocktails' | 'dessert') =>
  `${menuPath}#tab-${tab}`;

// Which API slug holds the starred favourites for each menu tile. Food + wine
// are language-specific; cocktails share one slug across languages.
const tileSlugFor = (tab: 'food' | 'wine' | 'cocktails' | 'dessert'): string => {
  if (tab === 'wine')      return lang === 'he' ? 'wine' : 'wine_en';
  if (tab === 'cocktails') return 'cocktails';
  if (tab === 'dessert')   return lang === 'he' ? 'dessert' : 'dessert_en';
  return lang === 'he' ? 'he' : 'en'; // food
};
const tileFavesLabel = t.menuTileFavesLabel;
const tileViewFull   = t.menuTileViewFull;

// Hydration payload for the inline script — keeps only the fields it needs.
const hydrationPayload = chapters.map((c) => ({
  id:           c.id,
  apiSlug:      c.apiSlug,
  sectionTitle: c.sectionTitle ?? null,
  take:         c.take,
}));
const emptyLabel = t.emptyLabel;
