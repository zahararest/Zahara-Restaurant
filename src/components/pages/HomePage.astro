<script is:inline define:vars={{ hydrationPayload, lang, emptyLabel }}>
  // Hydrate chapters that have empty initial items (cocktails, desserts,
  // and EN food) by fetching /api/menu/{slug} and rendering the first
  // N items. Mirrors how MenuEmbed loads its panels.

  const esc = (s) => String(s ?? '')
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

  // Deduplicate concurrent fetches for the same slug (food-start and
  // food-main both hit /api/menu/he — one request, two consumers).
  const fetchCache = new Map();
  function fetchMenu(slug) {
    if (!fetchCache.has(slug)) {
      fetchCache.set(slug, fetch(`/api/menu/${slug}`, { cache: 'default' }).then((r) => {
        if (!r.ok) throw new Error('fetch failed');
        return r.json();
      }));
    }
    return fetchCache.get(slug);
  }

  async function hydrateChapter(cfg) {
    if (!cfg.apiSlug) return;
    const host = document.querySelector(`[data-cinema-items][data-chapter-id="${cfg.id}"]`);
    if (!host) return;
    // HE food chapters are server-rendered with real items already; the rest
    // start as placeholders. We always fetch (to pick up admin-chosen
    // "featured" items), but only overwrite real server items when there's
    // actually something to show — never blank them on an empty/failed fetch.
    const hadRealItems = !host.querySelector('.menu-cinema__item--placeholder');

    try {
      const data = await fetchMenu(cfg.apiSlug);
      const sections = Array.isArray(data) ? data : (data?.sections ?? []);

      // Find the target items: either a specific section by title (food
      // chapters) or flatten across all sections (cocktails, dessert).
      let items = [];
      if (cfg.sectionTitle) {
        const sec = sections.find((s) => s.title === cfg.sectionTitle);
        items = sec?.items ?? [];
      } else {
        items = sections.flatMap((s) => s?.items ?? []);
      }

      // Admin-chosen items win; otherwise fall back to the first N.
      const featured = items.filter((it) => it && it.featured);
      let chosen;
      if (featured.length)     chosen = featured.slice(0, cfg.take);
      else if (!hadRealItems)  chosen = items.slice(0, cfg.take);
      else                     return; // server-rendered items, no featured → leave as-is

      if (chosen.length === 0) {
        if (hadRealItems) return; // keep the server items rather than blanking
        host.innerHTML = `<li class="menu-cinema__item menu-cinema__item--empty">
          <div class="menu-cinema__item-main">
            <em class="menu-cinema__item-name">${emptyLabel}</em>
          </div>
        </li>`;
        return;
      }

      host.innerHTML = chosen.map((it) => `
        <li class="menu-cinema__item">
          <div class="menu-cinema__item-main">
            <strong class="menu-cinema__item-name">${esc(it.name)}</strong>
            ${it.description ? `<span class="menu-cinema__item-desc">${esc(it.description)}</span>` : ''}
          </div>
          <span class="menu-cinema__item-price">${esc(it.price)}</span>
        </li>`).join('');
    } catch (err) {
      // Silently leave whatever's there; better than a broken page.
      console.warn('[Home menu] hydration failed for', cfg.id, err);
    }
  }

  hydrationPayload.forEach(hydrateChapter);

  // ── "Our Story" box — click the head to expand/collapse the text ──
  document.querySelectorAll('[data-story-box]').forEach((box) => {
    const head = box.querySelector('.story-box__head');
    if (!head) return;
    head.addEventListener('click', () => {
      const open = box.classList.toggle('is-open');
      head.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  });

  // ── Cinematic chapter "settle-in" ────────────────────────────
  // Each menu-cinema chapter starts its photo slightly enlarged
  // (scale 1.08). When the chapter enters view, we add `.is-settled`,
  // which transitions the scale back to 1 over ~2.4s, then kicks in
  // a slow continuous breath (see global.css). Feels like a camera
  // arriving at the scene instead of cuts between still photos.
  //
  // One-shot: once a chapter settles, it stays settled — no replay on
  // scroll-back.
  const cinematicReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!cinematicReduce && 'IntersectionObserver' in window) {
    const chapters = document.querySelectorAll('.menu-cinema__chapter');
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add('is-settled');
          io.unobserve(e.target);
        }
      }
    }, { rootMargin: '0px 0px -15% 0px', threshold: 0 });
    chapters.forEach((c) => io.observe(c));
  } else {
    // Reduced motion: skip the dolly-out so the photo lands at scale 1
    // immediately.
    document.querySelectorAll('.menu-cinema__chapter').forEach((c) => c.classList.add('is-settled'));
  }
</script>

