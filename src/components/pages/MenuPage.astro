---
import BaseLayout    from '../../layouts/BaseLayout.astro';
import MenuEmbed     from '../MenuEmbed.astro';
import IntroPhoto    from '../sections/IntroPhoto.astro';
import { pick, menu as copy } from '../../data/i18n';
import { PHOTOS }    from '../../data/photos';
import type { Lang } from '../../data/i18n';

export interface Props { lang: Lang }

const { lang } = Astro.props;
const t        = pick(copy, lang);
const title    = lang === 'he' ? 'תפריט' : 'Menu';
---

<BaseLayout title={title} lang={lang} transparentHeader>
  <IntroPhoto
    lang={lang}
    photo={PHOTOS.menuIntro}
    eyebrow={t.eyebrow}
    heading={t.heading}
    lede={t.lede}
  />

  <section class="section-tight wrap">
    <MenuEmbed lang={lang} />
  </section>
</BaseLayout>
