---
// Accessibility statement page — mandatory under Israeli regulations
// (תקנות שוויון זכויות לאנשים עם מוגבלות (התאמות נגישות לשירות), התשע״ג–2013).
// The statement must list: the standard the site aims to meet, the
// accessibility features available, known limitations, and a contact
// for accessibility issues.

import BaseLayout from '../../layouts/BaseLayout.astro';
import { RESTAURANT } from '../../data/restaurant';
import { pick, accessibilityPage as pageCopy } from '../../data/i18n';
import type { Lang } from '../../data/i18n';

export interface Props { lang: Lang }
const { lang } = Astro.props;
const page = pick(pageCopy, lang);
const today = new Date().toISOString().slice(0, 10);
---

<BaseLayout title={page.pageTitle} lang={lang}>
  <article class="a11y-page wrap">
    <header class="a11y-page__head">
      <p class="eyebrow">{page.pageEyebrow}</p>
      <h1 class="display">{page.pageTitle}</h1>
      <p class="a11y-page__updated">
        {page.updatedLabel} · {today}
      </p>
    </header>

    <section class="a11y-page__body prose">
      <p>
        <strong>{RESTAURANT.name[lang]}</strong> {page.standardText}
      </p>

      <h2>{page.standardHeading}</h2>

      <h2>{page.availabilityHeading}</h2>
      <ul>
        <li>{page.availabilityItem1}</li>
        <li>{page.availabilityItem2}</li>
        <li>{page.availabilityItem3}</li>
        <li>{page.availabilityItem4}</li>
        <li>{page.availabilityItem5}</li>
        <li>{page.availabilityItem6}</li>
        <li>{page.availabilityItem7}</li>
        <li>{page.availabilityItem8}</li>
        <li>{page.availabilityItem9}</li>
        <li>{page.availabilityItem10}</li>
      </ul>

      <h2>{page.navigationHeading}</h2>
      <p>{page.navigationText}</p>

      <h2>{page.limitationsHeading}</h2>
      <p>{page.limitationsText}</p>

      <h2>{page.contactHeading}</h2>
      <p>{page.contactText}</p>
      <ul>
        <li>{page.contactPhoneLabel}: <a href={`tel:${RESTAURANT.phone[lang === 'he' ? 'dialHe' : 'dialEn']}`}>{RESTAURANT.phone[lang === 'he' ? 'display' : 'intlDisplay']}</a></li>
        <li>{page.contactEmailLabel}: <a href={`mailto:${RESTAURANT.email}`}>{RESTAURANT.email}</a></li>
        <li>{page.contactAddressLabel}: {RESTAURANT.address[lang]}</li>
      </ul>
      <p>{page.responseText}</p>
    </section>
  </article>
</BaseLayout>

<style>
  .a11y-page {
    padding-block: clamp(6rem, 12vw, 9rem) var(--space-2xl);
    max-width: 48rem;
  }
  .a11y-page__head { margin-block-end: var(--space-l); }
  .a11y-page__head h1 {
    font-family: var(--font-display-he);
    font-weight: 400;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0.6rem 0 0;
  }
  html[lang="en"] .a11y-page__head h1 { font-family: var(--font-display-en); }
  .a11y-page__updated {
    margin: 1rem 0 0;
    font-size: var(--step--2);
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .a11y-page__body h2 {
    font-family: var(--font-display-he);
    font-weight: 500;
    font-size: var(--step-2);
    margin: 2rem 0 0.6rem;
    color: var(--ink);
  }
  html[lang="en"] .a11y-page__body h2 { font-family: var(--font-display-en); font-weight: 400; }
  .a11y-page__body p,
  .a11y-page__body ul {
    margin: 0.6rem 0;
    color: var(--ink-soft);
    line-height: 1.75;
    font-weight: 300;
  }
  .a11y-page__body ul { padding-inline-start: 1.4rem; }
  .a11y-page__body li { margin-block: 0.3rem; }
  .a11y-page__body a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .a11y-page__body a:hover { color: var(--accent-deep); }
</style>
