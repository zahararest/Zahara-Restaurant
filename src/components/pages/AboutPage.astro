---
// AboutPage — the renamed Contact page. It now folds in the old Location
// page: the intro + bleed photo, the map and directions, the parking /
// transit / accessibility details, the general/event contact form, and the
// direct phone + email postscript. One page for "who we are and how to
// reach us."

import BaseLayout    from '../../layouts/BaseLayout.astro';
import BleedPhoto    from '../sections/BleedPhoto.astro';
import ContactForm   from '../sections/ContactForm.astro';
import Photo         from '../Photo.astro';
import { pick, contact as copy, location as loc, aboutPage as pageCopy } from '../../data/i18n';
import { PHOTOS }    from '../../data/photos';
import { RESTAURANT } from '../../data/restaurant';
import type { Lang } from '../../data/i18n';

export interface Props { lang: Lang }

const { lang } = Astro.props;
const t        = pick(copy, lang);
const l        = pick(loc, lang);
const page     = pick(pageCopy, lang);
const title    = page.pageTitle;
const description = page.pageDescription;

const dial     = lang === 'he' ? RESTAURANT.phone.dialHe    : RESTAURANT.phone.dialEn;

// Kashrut certificate — opens full size (no crop) via the override-aware
// /photos route. No shipped default; the block hides itself client-side until
// the owner uploads the certificate in /admin/images.
const kosherCert = PHOTOS.kosherCert.src;

// ── Map + directions (folded in from the old Location page) ──────────────
const encoded  = encodeURIComponent(RESTAURANT.address.maps);
const wazeUrl  = `https://waze.com/ul?q=${encoded}`;
const gmapsUrl = `https://www.google.com/maps/search/?api=1&query=${encoded}`;
const mapEmbed = `https://www.google.com/maps?q=${encoded}&output=embed`;
---

<BaseLayout title={title} seoTitle={page.seoTitle} lang={lang} description={description}>
  <div class="about-page">
  <section class="page-intro wrap">
    <div class="stagger reveal-on-scroll">
      <p class="eyebrow">{t.aboutEyebrow}</p>
      <h1
        class="display"
        data-word-reveal
        data-word-reveal-delay="0.08"
        data-word-reveal-step="0.07"
        set:html={t.aboutHeading}
      />
      <p class="lede-prose">{t.aboutLede}</p>
    </div>
  </section>

  <BleedPhoto lang={lang} photo={PHOTOS.contact} height="clamp(280px, 50vh, 480px)" />

  {/* ── Where we are ──────────────────────────────────────────────────── */}
  <section class="section-tight wrap">
    <div class="stagger reveal-on-scroll" style="margin-block-end: var(--space-l);">
      <p class="eyebrow">{l.eyebrow}</p>
      <h2
        class="display"
        data-word-reveal
        data-word-reveal-delay="0.06"
        data-word-reveal-step="0.06"
      >{l.heading}</h2>
      <p class="lede-prose">{l.lede}</p>
    </div>

    {/* Map loads lazily — a visitor who never scrolls here doesn't ping Google. */}
    <div class="reveal-on-scroll map-wrapper">
      <iframe
        class="map-frame"
        src={mapEmbed}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={l.mapTitle}
      ></iframe>
    </div>

    <div class="directions-grid stagger reveal-on-scroll">
      <a class="btn btn--block btn--ghost" href={wazeUrl}  target="_blank" rel="noopener">{l.waze}</a>
      <a class="btn btn--block btn--ghost" href={gmapsUrl} target="_blank" rel="noopener">{l.gmaps}</a>
      <a class="btn btn--block btn--ghost" href={`tel:${dial}`}>{l.call}</a>
    </div>
  </section>

  {/* ── How the space is designed (four seating areas) ────────────────── */}
  <section class="section">
    <div class="wrap">
      <div class="photo-block">
        <div class="img-mask reveal-on-scroll">
          <Photo src={PHOTOS.location.src} alt={PHOTOS.location.alt[lang]} aspect="4/5" />
        </div>
        <div class="photo-block__content stagger reveal-on-scroll">
          <p class="eyebrow">{t.designEyebrow}</p>
          <h2
            class="display"
            data-word-reveal
            data-word-reveal-delay="0.06"
            data-word-reveal-step="0.06"
            set:html={t.designHeading}
          />
          <p class="lede-prose">{t.designLede}</p>
          <p set:html={t.designInside} />
          <p set:html={t.designBar} />
          <p set:html={t.designClosed} />
          <p set:html={t.designOpen} />
        </div>
      </div>
    </div>
  </section>

  {/* ── Kashrut certificate ────────────────────────────────────────────
      A clear, restrained way for guests to see the certificate while
      browsing. Hidden client-side until the owner uploads it. */}
  <section class="section wrap" data-kosher-block>
    <div class="about-kosher stagger reveal-on-scroll" data-kosher-cell>
      <p class="eyebrow">{t.kosherEyebrow}</p>
      <h2
        class="display"
        data-word-reveal
        data-word-reveal-delay="0.06"
        data-word-reveal-step="0.06"
      >{t.kosherHeading}</h2>
      <p class="lede-prose">{t.kosherNote}</p>
      <button class="btn btn--ghost about-kosher__cta" type="button"
              data-kosher-open data-kosher-cert>{t.kosherCertCta}</button>
    </div>
  </section>

  {/* Hover/peek preview — position: fixed so overflow:hidden on parent cannot clip it */}
  <div class="info-kosher__preview" id="kosher-preview" aria-hidden="true">
    <img class="info-kosher__thumb" src={kosherCert} alt="" width="210" height="297" loading="lazy" decoding="async" />
  </div>

  {/* Lightbox dialog */}
  <dialog class="kosher-dialog" id="kosher-dialog" aria-label={t.kosherHeading}>
    <button class="kosher-dialog__close" type="button"
            aria-label={lang === 'he' ? 'סגור' : 'Close'} data-kosher-close>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
    <img class="kosher-dialog__img" src={kosherCert} alt={t.kosherHeading} />
  </dialog>

  <hr class="rule" />

  {/* Direct contact details — shown above the form so visitors can reach
      out directly without filling in the form if they prefer. */}
  <div class="section-tight wrap about-contact-direct reveal-on-scroll">
    <p class="eyebrow">{lang === 'he' ? 'פנו אלינו ישירות' : 'Reach us directly'}</p>
    <div class="about-contact-direct__links">
      <a href={`mailto:${RESTAURANT.email}`} class="about-contact-direct__link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m2 7 10 7 10-7"/>
        </svg>
        {RESTAURANT.email}
      </a>
      <a href={`tel:${dial}`} class="about-contact-direct__link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z"/>
        </svg>
        {lang === 'he' ? RESTAURANT.phone.display : RESTAURANT.phone.intlDisplay}
      </a>
    </div>
  </div>

  {/* General contact form. Event inquiries now live on the dedicated
      /events/ page, so the event toggle is hidden here. */}
  <ContactForm lang={lang} showToggle={false} />
  </div>
</BaseLayout>

<script>
  // Kashrut certificate — hover preview + same-page lightbox, mirroring the
  // home-page InfoStrip. No shipped default: probe once and hide the whole
  // section if the cert hasn't been uploaded (404) rather than leave dead UI.
  (() => {
    const dialog  = document.getElementById('kosher-dialog')  as HTMLDialogElement | null;
    const preview = document.getElementById('kosher-preview') as HTMLElement | null;
    const cell    = document.querySelector('[data-kosher-cell]') as HTMLElement | null;
    const block   = document.querySelector('[data-kosher-block]') as HTMLElement | null;
    if (!dialog || !preview || !cell || !block) return;

    // Non-null after the guard — reassert so closures inherit the narrowed type.
    const _preview = preview!;
    const _cell    = cell!;

    // ── Probe: if cert not uploaded yet, hide all cert UI ──────────────────
    const certSrc = (dialog.querySelector('img') as HTMLImageElement)?.src;
    const probe   = new Image();
    probe.onerror = () => {
      block.hidden = true;
      _preview.remove();
      dialog.remove();
    };
    probe.src = certSrc ?? '';

    // Anchor — the "View certificate" button. The preview (position:fixed)
    // is pinned directly beneath it and tracks its rect on scroll, so it
    // stays glued under the button rather than drifting.
    const anchor = (_cell.querySelector('.about-kosher__cta') as HTMLElement) ?? _cell;

    function positionPreview() {
      const r        = anchor.getBoundingClientRect();
      const previewW = _preview.offsetWidth || 200;
      const gap      = 10;

      const halfW = previewW / 2;
      let left = r.left + r.width / 2;
      left = Math.max(halfW + 8, Math.min(left, window.innerWidth - halfW - 8));

      _preview.style.top  = `${r.bottom + gap}px`;
      _preview.style.left = `${left}px`;
    }

    function showPreview() {
      positionPreview();
      _preview.classList.add('is-visible');
    }
    function hidePreview() {
      _preview.classList.remove('is-visible');
    }

    // ── Hover — only on pointer devices (suppress on touch) ────────────────
    if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
      _cell.addEventListener('mouseenter', showPreview);
      _cell.addEventListener('mouseleave', hidePreview);
    }
    // Keep it pinned beneath the button as the page scrolls — rAF-throttled
    // so the layout read runs at most once per frame.
    let rafPending = false;
    window.addEventListener('scroll', () => {
      if (rafPending || !_preview.classList.contains('is-visible')) return;
      rafPending = true;
      requestAnimationFrame(() => {
        rafPending = false;
        if (_preview.classList.contains('is-visible')) positionPreview();
      });
    }, { passive: true });

    // ── Click → open lightbox (same page, no new tab) ──────────────────────
    _cell.querySelectorAll('[data-kosher-open]').forEach((btn) => {
      btn.addEventListener('click', () => dialog.showModal());
    });

    // ── Close lightbox ──────────────────────────────────────────────────────
    dialog.querySelectorAll('[data-kosher-close]').forEach((btn) => {
      btn.addEventListener('click', () => dialog.close());
    });
    dialog.addEventListener('click', (e) => { if (e.target === dialog) dialog.close(); });
  })();
</script>

<style>
  /* The About page stacks several full sections; the default --space-2xl
     padding stacked them too far apart (the photos → form → footer gaps
     read as empty screens). Tighten the rhythm here only — other pages
     keep the standard section spacing. */
  .about-page :global(.section)       { padding-block: var(--space-l); }
  .about-page :global(.section-tight) { padding-block: var(--space-m); }
  /* Last section before the footer: no trailing gap on top of the
     footer's own padding. */
  .about-page > :global(.section:last-child),
  .about-page :global(.section-tight:last-of-type) {
    padding-block-end: var(--space-l);
  }

  /* Kashrut certificate — a centered editorial block (eyebrow → heading →
     note → ghost link), in the same restrained vocabulary as the rest of
     the page. */
  .about-kosher {
    display: grid;
    justify-items: center;
    text-align: center;
    gap: var(--space-s);
    max-width: var(--readable-max);
    margin-inline: auto;
  }
  .about-kosher .lede-prose { margin-inline: auto; }
  .about-kosher__cta { margin-block-start: var(--space-xs, 0.5rem); }

  /* ── Kosher hover preview — fixed so no ancestor clip can hide it ──────── */
  .info-kosher__preview {
    position: fixed;
    transform: translateX(-50%) translateY(0.5rem);
    width: clamp(160px, 20vw, 210px);
    background: var(--paper-card);
    border: 1px solid var(--rule);
    padding: 0.4rem;
    box-shadow: 0 12px 40px color-mix(in srgb, var(--shadow) 40%, transparent);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease, transform 0.22s ease;
    z-index: 200;
  }
  .info-kosher__preview.is-visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  .info-kosher__thumb { width: 100%; height: auto; display: block; }

  /* ── Lightbox dialog ───────────────────────────────────────────────────── */
  .kosher-dialog {
    position: fixed;
    inset: 0;
    margin: auto;
    padding: 0;
    border: 0;
    width: min(90vw, 560px);
    max-height: min(90svh, 800px);
    background: var(--paper-card);
    box-shadow: 0 32px 100px color-mix(in srgb, var(--shadow) 58%, transparent);
    overflow: hidden;
    border-radius: 2px;
  }
  .kosher-dialog::backdrop {
    background: color-mix(in srgb, var(--shadow) 70%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .kosher-dialog__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .kosher-dialog__close {
    position: absolute;
    top: 0.5rem;
    inset-inline-end: 0.5rem;
    width: 2.75rem;   /* 44px touch target */
    height: 2.75rem;
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--shadow) 45%, transparent);
    border: 1px solid color-mix(in srgb, var(--paper-on-photo) 25%, transparent);
    border-radius: 50%;
    color: var(--paper-on-photo);
    cursor: pointer;
    z-index: 2;
    transition: background 0.2s ease;
  }
  .kosher-dialog__close:hover { background: color-mix(in srgb, var(--shadow) 65%, transparent); }
  .kosher-dialog__close svg { width: 1rem; height: 1rem; }

  @media (max-width: 480px) {
    .kosher-dialog { width: 95vw; }
    .info-kosher__preview { width: min(160px, 44vw); }
  }

  .map-wrapper { position: relative; }
  .map-frame {
    display: block;
    width: 100%;
    min-height: 400px;
    border: 0;
    border-radius: 2px;
  }

  /* Direct contact block — email + phone as icon-prefixed links */
  .about-contact-direct { padding-block-end: 0; }
  .about-contact-direct__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s) var(--space-l);
    margin-block-start: var(--space-s);
  }
  .about-contact-direct__link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-display);
    font-size: var(--step-1);
    color: var(--ink);
    text-decoration: none;
    border-block-end: 1px solid var(--rule-soft);
    padding-block-end: 0.15rem;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .about-contact-direct__link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .about-contact-direct__link svg {
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
    color: var(--accent);
  }
  @media (max-width: 540px) {
    .about-contact-direct__links { flex-direction: column; gap: var(--space-xs); }
    .about-contact-direct__link  { font-size: var(--step-0); }
  }
</style>
