---
// AboutPage — the renamed Contact page. It now folds in the old Location
// page: the intro + bleed photo, the map and directions, the parking /
// transit / accessibility details, the general/event contact form, and the
// direct phone + email postscript. One page for "who we are and how to
// reach us."

import BaseLayout    from '../../layouts/BaseLayout.astro';
import BleedPhoto    from '../sections/BleedPhoto.astro';
import ContactForm   from '../sections/ContactForm.astro';
import Photo         from '../Photo.astro';
import { pick, contact as copy, location as loc } from '../../data/i18n';
import { PHOTOS }    from '../../data/photos';
import { RESTAURANT } from '../../data/restaurant';
import type { Lang } from '../../data/i18n';

export interface Props { lang: Lang }

const { lang } = Astro.props;
const t        = pick(copy, lang);
const l        = pick(loc, lang);
const title    = lang === 'he' ? 'אודות' : 'About';

const benefits = [t.benefitPrivate, t.benefitChef, t.benefitKosher, t.benefitFull];

const dial     = lang === 'he' ? RESTAURANT.phone.dialHe    : RESTAURANT.phone.dialEn;
const phoneTxt = lang === 'he' ? RESTAURANT.phone.display    : RESTAURANT.phone.intlDisplay;

// ── Map + directions (folded in from the old Location page) ──────────────
const encoded  = encodeURIComponent(RESTAURANT.address.maps);
const wazeUrl  = `https://waze.com/ul?q=${encoded}`;
const gmapsUrl = `https://www.google.com/maps/search/?api=1&query=${encoded}`;
const mapEmbed = `https://www.google.com/maps?q=${encoded}&output=embed`;
---

<BaseLayout title={title} lang={lang}>
  <section class="page-intro wrap">
    <div class="stagger reveal-on-scroll">
      <p class="eyebrow">{t.aboutEyebrow}</p>
      <h1
        class="display"
        data-word-reveal
        data-word-reveal-delay="0.08"
        data-word-reveal-step="0.07"
        set:html={t.aboutHeading}
      />
      <p class="lede-prose">{t.aboutLede}</p>
    </div>
  </section>

  <BleedPhoto lang={lang} photo={PHOTOS.contact} height="clamp(280px, 50vh, 480px)" />

  {/* ── Where we are ──────────────────────────────────────────────────── */}
  <section class="section-tight wrap">
    <div class="stagger reveal-on-scroll" style="margin-block-end: var(--space-l);">
      <p class="eyebrow">{l.eyebrow}</p>
      <h2
        class="display"
        data-word-reveal
        data-word-reveal-delay="0.06"
        data-word-reveal-step="0.06"
      >{l.heading}</h2>
      <p class="lede-prose">{l.lede}</p>
    </div>

    {/* Map loads lazily — a visitor who never scrolls here doesn't ping Google. */}
    <div class="reveal-on-scroll map-wrapper">
      <iframe
        class="map-frame"
        src={mapEmbed}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={l.mapTitle}
      ></iframe>
    </div>

    <div class="directions-grid stagger reveal-on-scroll">
      <a class="btn btn--block btn--ghost" href={wazeUrl}  target="_blank" rel="noopener">{l.waze}</a>
      <a class="btn btn--block btn--ghost" href={gmapsUrl} target="_blank" rel="noopener">{l.gmaps}</a>
      <a class="btn btn--block btn--ghost" href={`tel:${dial}`}>{l.call}</a>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="photo-block">
        <div class="img-mask reveal-on-scroll">
          <Photo src={PHOTOS.location.src} alt={PHOTOS.location.alt[lang]} aspect="4/5" />
        </div>
        <div class="photo-block__content stagger reveal-on-scroll">
          <p class="eyebrow">{l.infoEyebrow}</p>
          <h2
            class="display"
            data-word-reveal
            data-word-reveal-delay="0.06"
            data-word-reveal-step="0.06"
            set:html={l.infoHeading}
          />
          <p set:html={l.infoByCar} />
          <p set:html={l.infoByTransit} />
          <p set:html={l.infoAccessibility} />
          <p set:html={l.infoBooking} />
        </div>
      </div>
    </div>
  </section>

  <hr class="rule" />

  {/* ── Get in touch ──────────────────────────────────────────────────── */}
  <section class="section-tight">
    <div class="wrap">
      <ul class="benefits stagger reveal-on-scroll">
        {benefits.map((label, i) => (
          <li class="benefit">
            <span class="benefit__num">0{i + 1}</span>
            <span class="benefit__text">{label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <ContactForm lang={lang} />

  {/* Direct contact details — phone and email as a quiet postscript. */}
  <section class="section-tight">
    <div class="wrap wrap--tight">
      <div class="reach-us reveal-on-scroll">
        <p class="eyebrow">{t.reachUsEyebrow}</p>
        <dl class="reach-us__list">
          <div class="reach-us__row">
            <dt>{t.reachUsPhoneLabel}</dt>
            <dd><a href={`tel:${dial}`}>{phoneTxt}</a></dd>
          </div>
          <div class="reach-us__row">
            <dt>{t.reachUsEmailLabel}</dt>
            <dd><a href={`mailto:${RESTAURANT.email}`}>{RESTAURANT.email}</a></dd>
          </div>
        </dl>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .map-wrapper { position: relative; }
  .map-frame {
    display: block;
    width: 100%;
    min-height: 400px;
    border: 0;
    border-radius: 2px;
  }
</style>
