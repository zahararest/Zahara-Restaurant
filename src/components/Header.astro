---
import { pick, header as labels } from '../data/i18n';
import { RESTAURANT }              from '../data/restaurant';
import { path, altLangHref, NAV_ORDER, type RouteKey, type NavKey } from '../lib/paths';
const rooftopUrl = RESTAURANT.rooftopUrl;
import type { Lang }               from '../data/i18n';

export interface Props {
  lang?:        Lang;
  /** Set true on pages whose hero is a full-bleed photo behind the header. */
  transparent?: boolean;
}

const { lang = 'he', transparent = false } = Astro.props;
const t        = pick(labels, lang);
const currPath = Astro.url.pathname;

const navItems: { href: string; label: string; key: NavKey }[] = NAV_ORDER.map((key: NavKey) => ({
  key,
  href:  path(key, lang),
  label: t[key],
}));

const otherLangHref = altLangHref(currPath, lang);

const isCurrent = (href: string) => {
  const norm = (s: string) => s.replace(/\/$/, '') || '/';
  return norm(currPath) === norm(href);
};

const headerClass = `site-header${transparent ? ' is-on-photo' : ''}`;
---

<header class={headerClass} id="site-header" data-transparent={transparent}>
  <div class="wrap site-header__inner">
    <button
      class="burger"
      id="burger"
      type="button"
      aria-label={t.burgerAria}
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <span></span><span></span><span></span>
    </button>

    <nav class="nav nav-row" aria-label={t.navAria}>
      {navItems.map(item => (
        <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a>
      ))}
    </nav>

    {/* Venue switcher — a segmented pill: Zahara (here, highlighted) ↔ Nucha
        Rooftop. Tapping Zahara when already home scrolls to the top. The
        highlight is the active segment's own background, so it's always
        perfectly aligned. */}
    <div class="site-switch" role="group" aria-label={t.switchVenue}>
      <a href={path('home', lang)} class="site-switch__seg site-switch__seg--brand is-active"
         data-switch-home aria-label={t.brandAria}>
        {t.brandText}
      </a>
      {rooftopUrl
        ? (
          <a href={rooftopUrl} class="site-switch__seg" target="_blank" rel="noopener">
            <span class="site-switch__name">{t.rooftop}</span>
          </a>
        )
        : (
          <button class="site-switch__seg site-switch__seg--soon" type="button"
                  data-switch-rooftop
                  aria-label={`${t.rooftop} · ${t.rooftopSoon}`}>
            <span class="site-switch__name">{t.rooftop}</span>
            <span class="site-switch__soon">{t.rooftopSoon}</span>
          </button>
        )
      }
    </div>

    <div class="header-cta">
      {/* Rooftop now lives behind the brand's ‹ arrow; Reserve is a floating
          button (see BaseLayout). */}

      {/* Social — Instagram + WhatsApp + Facebook icon links */}
      <div class="header-social">
        <a href={RESTAURANT.instagram} target="_blank" rel="noopener" aria-label={t.instagramAria}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
        </a>
        <a href={RESTAURANT.whatsapp} target="_blank" rel="noopener" aria-label={t.whatsappAria}>
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>
        <a href={RESTAURANT.facebook} target="_blank" rel="noopener" aria-label={t.facebookAria}>
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H8v3h3v7h3v-7h2.5l.5-3H14V9z"/>
          </svg>
        </a>
      </div>

      {/* Utility controls: theme + lang — visually separated */}
      <div class="header-utils">
        <button
          class="theme-toggle"
          type="button"
          data-theme-toggle
          aria-label={t.themeToggle}
          title={t.themeToggle}
        >
          <span class="theme-toggle__icon" data-theme-icon aria-hidden="true">●</span>
          <span class="visually-hidden" data-theme-state></span>
        </button>
        <a href={otherLangHref} class="lang-toggle" aria-label={t.langToggleAria}>
          {t.langToggle}
        </a>
      </div>
    </div>
  </div>
</header>

{/* Mobile drawer lives OUTSIDE <header> on purpose: the header carries a
    backdrop-filter on inner pages, which would make it the containing block
    for this position:fixed drawer and shrink it to the header's height
    (the "half-open" bug). As a body-level sibling it always fills the
    viewport. */}
<div class="mobile-nav" id="mobile-nav" aria-hidden="true">
  <ul>
    {navItems.map(item => (
      <li><a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a></li>
    ))}
  </ul>
  <div class="mobile-nav__cta">
    {rooftopUrl
      ? <a class="btn btn--ghost" href={rooftopUrl} target="_blank" rel="noopener">{t.rooftop}</a>
      : <a class="btn btn--ghost mobile-nav__rooftop-soon" href={path('home', lang)}>{t.rooftop} · {t.rooftopSoon}</a>
    }
    <a class="btn" href={RESTAURANT.reservationUrl} target="_blank" rel="noopener">{t.reserve}</a>
    <div class="mobile-nav__social">
      <a href={RESTAURANT.instagram} target="_blank" rel="noopener" aria-label="Instagram">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
      </a>
      <a href={RESTAURANT.whatsapp} target="_blank" rel="noopener" aria-label="WhatsApp">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </a>
      <a href={RESTAURANT.facebook} target="_blank" rel="noopener" aria-label="Facebook">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H8v3h3v7h3v-7h2.5l.5-3H14V9z"/>
        </svg>
      </a>
    </div>
    <a class="text-link" href={otherLangHref}>{t.langToggle}</a>
  </div>
</div>

<script>
  const header      = document.getElementById('site-header');
  const transparent = header?.dataset.transparent === 'true';

  if (header) {
    // On transparent pages (those with a full-bleed photo hero), the header
    // stays glued to the photography all the way down — no opaque-paper state.
    if (transparent) header.classList.add('is-on-photo');

    const onScroll = () => {
      const scrolled = window.scrollY > 8;
      // Transparent pages still get a `is-scrolled` flag (so we can darken
      // the gradient a touch once the user leaves the very top) but never
      // lose `is-on-photo`.
      header.classList.toggle('is-scrolled', scrolled);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  const burger = document.getElementById('burger');
  const drawer = document.getElementById('mobile-nav');

  function closeNav() {
    burger?.classList.remove('is-open');
    drawer?.classList.remove('is-open');
    drawer?.setAttribute('aria-hidden',  'true');
    burger?.setAttribute('aria-expanded', 'false');
    document.body.classList.remove('nav-open');
  }
  function openNav() {
    burger?.classList.add('is-open');
    drawer?.classList.add('is-open');
    drawer?.setAttribute('aria-hidden',  'false');
    burger?.setAttribute('aria-expanded', 'true');
    document.body.classList.add('nav-open');
  }

  burger?.addEventListener('click', () => {
    if (drawer?.classList.contains('is-open')) closeNav();
    else                                       openNav();
  });

  drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeNav));

  window.addEventListener('resize', () => {
    if (window.innerWidth > 860 && drawer?.classList.contains('is-open')) closeNav();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer?.classList.contains('is-open')) closeNav();
  });

  // ── Venue switcher — clicking the active (Zahara) segment when already on
  // its page scrolls to the top instead of reloading. ─────────────────────
  const switchHome = document.querySelector<HTMLAnchorElement>('[data-switch-home]');
  if (switchHome) {
    switchHome.addEventListener('click', (e) => {
      const norm = (s: string) => s.replace(/\/$/, '') || '/';
      const here   = norm(window.location.pathname);
      const target = norm(new URL(switchHome.href).pathname);
      if (here === target) {
        e.preventDefault();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });
  }

  // ── Rooftop segment — dual-purpose while the rooftop site isn't live yet:
  //   • scrolled past the first screen → scroll back to the top
  //   • already at the very top        → this is where it WILL switch sites;
  //     for now it's a no-op (rooftopUrl is null).
  // Once RESTAURANT.rooftopUrl is set the segment renders as a plain <a>
  // and this handler no longer exists. ─────────────────────────────────────
  const switchRooftop = document.querySelector<HTMLButtonElement>('[data-switch-rooftop]');
  if (switchRooftop) {
    // "First part of the page" = roughly the first viewport. Anything past
    // that and a tap means "take me back up".
    const pastFirstScreen = () => window.scrollY > window.innerHeight * 0.6;
    switchRooftop.addEventListener('click', () => {
      if (pastFirstScreen()) {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
      // else: at the top — reserved for the future site switch. No-op for now.
    });
  }

  // ── Theme toggle (two states: light ↔ dark) ──────────────────────────
  // Per-browser; saved in localStorage as `zahara-theme`. The pre-paint
  // script in BaseLayout already set <html data-theme="light|dark">; this
  // handler just renders the right icon and flips on click. Cross-tab
  // sync is handled by the storage listener in BaseLayout, so we don't
  // duplicate it here.
  (function setupThemeToggle() {
    const root = document.documentElement;
    const btn  = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
    if (!btn) return;
    const iconEl  = btn.querySelector<HTMLElement>('[data-theme-icon]');
    const stateEl = btn.querySelector<HTMLElement>('[data-theme-state]');
    const isHe    = root.getAttribute('lang') === 'he';
    const NAMES: Record<'light' | 'dark', string>   = isHe
      ? { light: 'בהיר', dark: 'כהה' }
      : { light: 'Light', dark: 'Dark' };
    // Sun for light (click to go dark), moon for dark (click to go light).
    const ICONS: Record<'light' | 'dark', string>   = { light: '☀', dark: '☾' };

    type Theme = 'light' | 'dark';

    function render(theme: Theme) {
      if (iconEl)  iconEl.textContent  = ICONS[theme];
      if (stateEl) stateEl.textContent = NAMES[theme];
      btn!.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
      btn!.dataset.themeCurrent = theme;
    }
    function current(): Theme {
      return root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
    }
    function apply(theme: Theme) {
      root.setAttribute('data-theme', theme);
      try { localStorage.setItem('zahara-theme', theme); } catch (_) {}
      render(theme);
    }

    render(current());
    btn.addEventListener('click', () => {
      apply(current() === 'dark' ? 'light' : 'dark');
    });
    // Cross-tab UI sync (the storage event already triggered the <html>
    // attribute swap in BaseLayout — we just re-render the icon here).
    try {
      window.addEventListener('storage', (e) => {
        if (e.key === 'zahara-theme') render(current());
      });
    } catch (_) {}
  })();
</script>
