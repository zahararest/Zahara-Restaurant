---
import { pick, header as labels } from '../data/i18n';
import { RESTAURANT }              from '../data/restaurant';
import { path, altLangHref, NAV_ORDER, type RouteKey } from '../lib/paths';
import type { Lang }               from '../data/i18n';

export interface Props {
  lang?:        Lang;
  /** Set true on pages whose hero is a full-bleed photo behind the header. */
  transparent?: boolean;
}

const { lang = 'he', transparent = false } = Astro.props;
const t        = pick(labels, lang);
const currPath = Astro.url.pathname;

const navItems: { href: string; label: string; key: RouteKey }[] = NAV_ORDER.map(key => ({
  key,
  href:  path(key, lang),
  label: t[key],
}));

const otherLangHref = altLangHref(currPath, lang);

const isCurrent = (href: string) => {
  const norm = (s: string) => s.replace(/\/$/, '') || '/';
  return norm(currPath) === norm(href);
};

const headerClass = `site-header${transparent ? ' is-on-photo' : ''}`;
---

<header class={headerClass} id="site-header" data-transparent={transparent}>
  <div class="wrap site-header__inner">
    <button
      class="burger"
      id="burger"
      type="button"
      aria-label={lang === 'he' ? 'תפריט ניווט' : 'Navigation menu'}
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <span></span><span></span><span></span>
    </button>

    <nav class="nav nav-row" aria-label={lang === 'he' ? 'ניווט ראשי' : 'Primary'}>
      {navItems.map(item => (
        <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a>
      ))}
    </nav>

    <a href={path('home', lang)} class="brand" aria-label={lang === 'he' ? 'זהרה — עמוד הבית' : 'Zahara — Home'}>
      {lang === 'he' ? 'זהרה' : 'Zahara'}
    </a>

    <div class="header-cta">
      <a class="header-reserve" href={RESTAURANT.reservationUrl} target="_blank" rel="noopener">
        {t.reserve}
      </a>
      <a href={otherLangHref} class="lang-toggle" aria-label={lang === 'he' ? 'English' : 'עברית'}>
        {t.langToggle}
      </a>
    </div>
  </div>

  <div class="mobile-nav" id="mobile-nav" aria-hidden="true">
    <ul>
      {navItems.map(item => (
        <li><a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a></li>
      ))}
    </ul>
    <div class="mobile-nav__cta">
      <a class="btn"       href={RESTAURANT.reservationUrl} target="_blank" rel="noopener">{t.reserve}</a>
      <a class="text-link" href={otherLangHref}>{t.langToggle}</a>
    </div>
  </div>
</header>

<script>
  const header      = document.getElementById('site-header');
  const transparent = header?.dataset.transparent === 'true';

  if (header) {
    // On transparent pages (those with a full-bleed photo hero), the header
    // stays glued to the photography all the way down — no opaque-paper state.
    if (transparent) header.classList.add('is-on-photo');

    const onScroll = () => {
      const scrolled = window.scrollY > 8;
      // Transparent pages still get a `is-scrolled` flag (so we can darken
      // the gradient a touch once the user leaves the very top) but never
      // lose `is-on-photo`.
      header.classList.toggle('is-scrolled', scrolled);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  const burger = document.getElementById('burger');
  const drawer = document.getElementById('mobile-nav');

  function closeNav() {
    burger?.classList.remove('is-open');
    drawer?.classList.remove('is-open');
    drawer?.setAttribute('aria-hidden',  'true');
    burger?.setAttribute('aria-expanded', 'false');
    document.body.classList.remove('nav-open');
  }
  function openNav() {
    burger?.classList.add('is-open');
    drawer?.classList.add('is-open');
    drawer?.setAttribute('aria-hidden',  'false');
    burger?.setAttribute('aria-expanded', 'true');
    document.body.classList.add('nav-open');
  }

  burger?.addEventListener('click', () => {
    if (drawer?.classList.contains('is-open')) closeNav();
    else                                       openNav();
  });

  drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeNav));

  window.addEventListener('resize', () => {
    if (window.innerWidth > 860 && drawer?.classList.contains('is-open')) closeNav();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer?.classList.contains('is-open')) closeNav();
  });
</script>
