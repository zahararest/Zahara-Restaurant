---
import { pick, header as labels } from '../data/i18n';
import { RESTAURANT }              from '../data/restaurant';
import { path, altLangHref, NAV_ORDER, type RouteKey } from '../lib/paths';
const rooftopUrl = RESTAURANT.rooftopUrl;
import type { Lang }               from '../data/i18n';

export interface Props {
  lang?:        Lang;
  /** Set true on pages whose hero is a full-bleed photo behind the header. */
  transparent?: boolean;
}

const { lang = 'he', transparent = false } = Astro.props;
const t        = pick(labels, lang);
const currPath = Astro.url.pathname;

const navItems: { href: string; label: string; key: RouteKey }[] = NAV_ORDER.map(key => ({
  key,
  href:  path(key, lang),
  label: t[key],
}));

const otherLangHref = altLangHref(currPath, lang);

const isCurrent = (href: string) => {
  const norm = (s: string) => s.replace(/\/$/, '') || '/';
  return norm(currPath) === norm(href);
};

const headerClass = `site-header${transparent ? ' is-on-photo' : ''}`;
---

<header class={headerClass} id="site-header" data-transparent={transparent}>
  <div class="wrap site-header__inner">
    <button
      class="burger"
      id="burger"
      type="button"
      aria-label={lang === 'he' ? 'תפריט ניווט' : 'Navigation menu'}
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <span></span><span></span><span></span>
    </button>

    <nav class="nav nav-row" aria-label={lang === 'he' ? 'ניווט ראשי' : 'Primary'}>
      {navItems.map(item => (
        <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a>
      ))}
    </nav>

    <a href={path('home', lang)} class="brand" aria-label={lang === 'he' ? 'זהרה — עמוד הבית' : 'Zahara — Home'}>
      {lang === 'he' ? 'זהרה' : 'Zahara'}
    </a>

    <div class="header-cta">
      {/* Primary actions: Rooftop + Reserve */}
      {rooftopUrl
        ? (
          <a class="header-rooftop" href={rooftopUrl} target="_blank" rel="noopener">
            {t.rooftop}
          </a>
        )
        : (
          <span class="header-rooftop header-rooftop--soon"
                aria-label={`${t.rooftop} · ${t.rooftopSoon}`}>
            {t.rooftop}
            <span class="header-rooftop__badge" aria-hidden="true">{t.rooftopSoon}</span>
          </span>
        )
      }
      <a class="header-reserve" href={RESTAURANT.reservationUrl} target="_blank" rel="noopener">
        {t.reserve}
      </a>

      {/* Utility controls: theme + lang — visually separated */}
      <div class="header-utils">
        <button
          class="theme-toggle"
          type="button"
          data-theme-toggle
          aria-label={t.themeToggle}
          title={t.themeToggle}
        >
          <span class="theme-toggle__icon" data-theme-icon aria-hidden="true">●</span>
          <span class="visually-hidden" data-theme-state></span>
        </button>
        <a href={otherLangHref} class="lang-toggle" aria-label={lang === 'he' ? 'English' : 'עברית'}>
          {t.langToggle}
        </a>
      </div>
    </div>
  </div>

  <div class="mobile-nav" id="mobile-nav" aria-hidden="true">
    <ul>
      {navItems.map(item => (
        <li><a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a></li>
      ))}
    </ul>
    <div class="mobile-nav__cta">
      {rooftopUrl
        ? <a class="btn btn--ghost" href={rooftopUrl} target="_blank" rel="noopener">{t.rooftop}</a>
        : <span class="mobile-nav__rooftop-soon">{t.rooftop} · {t.rooftopSoon}</span>
      }
      <a class="btn" href={RESTAURANT.reservationUrl} target="_blank" rel="noopener">{t.reserve}</a>
      <a class="text-link" href={otherLangHref}>{t.langToggle}</a>
    </div>
  </div>
</header>

<script>
  const header      = document.getElementById('site-header');
  const transparent = header?.dataset.transparent === 'true';

  if (header) {
    // On transparent pages (those with a full-bleed photo hero), the header
    // stays glued to the photography all the way down — no opaque-paper state.
    if (transparent) header.classList.add('is-on-photo');

    const onScroll = () => {
      const scrolled = window.scrollY > 8;
      // Transparent pages still get a `is-scrolled` flag (so we can darken
      // the gradient a touch once the user leaves the very top) but never
      // lose `is-on-photo`.
      header.classList.toggle('is-scrolled', scrolled);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  const burger = document.getElementById('burger');
  const drawer = document.getElementById('mobile-nav');

  function closeNav() {
    burger?.classList.remove('is-open');
    drawer?.classList.remove('is-open');
    drawer?.setAttribute('aria-hidden',  'true');
    burger?.setAttribute('aria-expanded', 'false');
    document.body.classList.remove('nav-open');
  }
  function openNav() {
    burger?.classList.add('is-open');
    drawer?.classList.add('is-open');
    drawer?.setAttribute('aria-hidden',  'false');
    burger?.setAttribute('aria-expanded', 'true');
    document.body.classList.add('nav-open');
  }

  burger?.addEventListener('click', () => {
    if (drawer?.classList.contains('is-open')) closeNav();
    else                                       openNav();
  });

  drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeNav));

  window.addEventListener('resize', () => {
    if (window.innerWidth > 860 && drawer?.classList.contains('is-open')) closeNav();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer?.classList.contains('is-open')) closeNav();
  });

  // ── Theme toggle (two states: light ↔ dark) ──────────────────────────
  // Per-browser; saved in localStorage as `zahara-theme`. The pre-paint
  // script in BaseLayout already set <html data-theme="light|dark">; this
  // handler just renders the right icon and flips on click. Cross-tab
  // sync is handled by the storage listener in BaseLayout, so we don't
  // duplicate it here.
  (function setupThemeToggle() {
    const root = document.documentElement;
    const btn  = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
    if (!btn) return;
    const iconEl  = btn.querySelector<HTMLElement>('[data-theme-icon]');
    const stateEl = btn.querySelector<HTMLElement>('[data-theme-state]');
    const isHe    = root.getAttribute('lang') === 'he';
    const NAMES: Record<'light' | 'dark', string>   = isHe
      ? { light: 'בהיר', dark: 'כהה' }
      : { light: 'Light', dark: 'Dark' };
    // Sun for light (click to go dark), moon for dark (click to go light).
    const ICONS: Record<'light' | 'dark', string>   = { light: '☀', dark: '☾' };

    type Theme = 'light' | 'dark';

    function render(theme: Theme) {
      if (iconEl)  iconEl.textContent  = ICONS[theme];
      if (stateEl) stateEl.textContent = NAMES[theme];
      btn!.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
      btn!.dataset.themeCurrent = theme;
    }
    function current(): Theme {
      return root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
    }
    function apply(theme: Theme) {
      root.setAttribute('data-theme', theme);
      try { localStorage.setItem('zahara-theme', theme); } catch (_) {}
      render(theme);
    }

    render(current());
    btn.addEventListener('click', () => {
      apply(current() === 'dark' ? 'light' : 'dark');
    });
    // Cross-tab UI sync (the storage event already triggered the <html>
    // attribute swap in BaseLayout — we just re-render the icon here).
    try {
      window.addEventListener('storage', (e) => {
        if (e.key === 'zahara-theme') render(current());
      });
    } catch (_) {}
  })();
</script>
