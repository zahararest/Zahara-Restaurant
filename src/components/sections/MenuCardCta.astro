---
export interface Props {
  eyebrow: string;
  heading: string;
  body:    string;
  cta:     { label: string; href: string };
}

const { eyebrow, heading, body, cta } = Astro.props;
---

<section class="section-tight" id="menu">
  <div class="wrap wrap--tight">
    <div class="menu-card stagger reveal-on-scroll">
      <span class="menu-card__eyebrow">{eyebrow}</span>
      <h3
        class="display"
        data-word-reveal
        data-word-reveal-delay="0.05"
        data-word-reveal-step="0.05"
      >{heading}</h3>
      <p>{body}</p>
      <div class="btn-row" style="justify-content: center; margin-block-start: 0.5rem;">
        <a class="btn" href={cta.href}>{cta.label}</a>
      </div>
    </div>
  </div>
</section>
