---
// InstagramFeed — one small "moment" box + a reels reveal.
//
// Hydrates from /api/instagram:
//   • stories[] — every live story frame; the box lets you switch between them.
//   • item      — latest post/reel, shown only when no story is live.
//   • reels[]   — recent reels, revealed under a button beneath the box.
// Each box has a button that opens the shown item on Instagram, labelled by
// what it is. Falls back to a branded "Follow us" box when nothing's available.

import { pick, home as copy } from '../../data/i18n';
import { RESTAURANT } from '../../data/restaurant';
import type { Lang }  from '../../data/i18n';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = pick(copy, lang);
const htmlLang = lang === 'he' ? 'he' : 'en';
---

<section class="section-tight ig-section reveal-on-scroll">
  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow eyebrow--center" data-content-key="home.igEyebrow">{t.igEyebrow}</p>
      <h2
        class="display"
        data-word-reveal
        data-word-reveal-delay="0.06"
        data-word-reveal-step="0.06"
        data-content-key="home.igHeading"
      >{t.igHeading}</h2>
    </div>

    {/* Small featured box + (optional) reels toggle, all built by JS. Starts
        as a skeleton box. */}
    <div class="ig-feature" data-ig-feature>
      <div class="ig-box ig-box--skeleton">
        <span class="ig-box__img" aria-hidden="true"></span>
      </div>
    </div>

    {/* Reels strip — hidden until the button under the box is pressed. */}
    <div class="ig-reels" id="ig-reels" data-ig-reels is-open>
      <div class="ig-reels__scroll" data-ig-reels-scroll role="list" aria-label={t.igAriaStrip}></div>
    </div>

    {/* Profile handle, always present. */}
    <div class="ig-follow reveal-on-scroll">
      <a
        class="ig-follow__link"
        href={RESTAURANT.instagram}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${t.igFollow} · ${t.igHandle}`}
      >
        <svg class="ig-follow__icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
        <span class="ig-follow__handle">{t.igHandle}</span>
        <span class="ig-follow__label">↗</span>
      </a>
    </div>
  </div>
</section>

<script is:inline define:vars={{ instagramUrl: RESTAURANT.instagram, t, htmlLang }}>
  (function () {
    const feature   = document.querySelector('[data-ig-feature]');
    const reelsWrap = document.querySelector('[data-ig-reels]');
    const reelsScroll = document.querySelector('[data-ig-reels-scroll]');
    if (!feature) return;

    const escAttr = (s) => String(s == null ? '' : s).replace(/"/g, '&quot;');
    const escHtml = (s) => String(s == null ? '' : s)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

    // Honour the OS "reduce motion" setting — no auto-advance, no fill timer.
    const reduceMotion = window.matchMedia &&
      window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Compact "5h" / "2d" relative time like the app shows on a story frame.
    let rtf = null;
    try { rtf = new Intl.RelativeTimeFormat(htmlLang, { numeric: 'auto', style: 'narrow' }); }
    catch (_) { rtf = null; }
    function timeAgo(ts) {
      if (!ts || !rtf) return '';
      const then = new Date(ts).getTime();
      if (isNaN(then)) return '';
      const secs = Math.round((then - Date.now()) / 1000); // negative = past
      const mins = Math.round(secs / 60);
      if (Math.abs(secs) < 60)  return rtf.format(secs,  'second');
      if (Math.abs(mins) < 60)  return rtf.format(mins,  'minute');
      const hrs = Math.round(mins / 60);
      if (Math.abs(hrs) < 24)   return rtf.format(hrs,   'hour');
      return rtf.format(Math.round(hrs / 24), 'day');
    }

    // Defer the call until the section nears the viewport (it sits low on the
    // page; fetching on load only lengthens the initial request chain).
    function whenNear(el, cb) {
      if (!('IntersectionObserver' in window)) { cb(); return; }
      const io = new IntersectionObserver((entries) => {
        if (entries.some((e) => e.isIntersecting)) { io.disconnect(); cb(); }
      }, { rootMargin: '600px 0px' });
      io.observe(el);
    }

    function buttonLabel(kind) {
      if (kind === 'story') return t.igWatchStory;
      if (kind === 'reel')  return t.igViewReel;
      return t.igViewPost;
    }

    function renderFallback() {
      feature.innerHTML =
        '<a class="ig-box ig-box--cta" href="' + escAttr(instagramUrl) + '"' +
        ' target="_blank" rel="noopener noreferrer" aria-label="' + escAttr(t.igFollow) + '">' +
          '<span class="ig-box__cta-inner">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">' +
              '<rect x="2" y="2" width="20" height="20" rx="5"/>' +
              '<circle cx="12" cy="12" r="4"/>' +
              '<circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>' +
            '</svg>' +
            '<span>' + escHtml(t.igEmpty) + '</span>' +
            '<span class="ig-box__cta-handle">' + escHtml(t.igHandle) + '</span>' +
          '</span>' +
        '</a>';
    }

    // ── The featured box ──────────────────────────────────────────────────
    // The story variant is a faithful little Instagram story viewer: filling
    // progress bars that auto-advance, tap-zones to step between frames, an
    // avatar ring + handle + relative time. Posts/reels are a single still.
    const STORY_MS = 5000;

    function renderBox(frames, kind, profile) {
      // `frames` is an array (stories may have many; posts/reels have one).
      let idx = 0;
      const multi = frames.length > 1;
      const isStory = kind === 'story';
      const label = buttonLabel(kind);
      const handle = String(t.igHandle || '');
      const initial = (handle.replace(/^@/, '')[0] || 'Z').toUpperCase();

      // Story-style progress bars across the very top — one segment per frame,
      // each with an inner fill the timer animates, like the real app.
      const avatarHtml = (profile && profile.avatarUrl)
        ? '<img src="' + escAttr(profile.avatarUrl) + '" alt="" referrerpolicy="no-referrer" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;" />'
        : escHtml(initial);
      const segs = isStory
        ? '<span class="ig-box__segs" aria-hidden="true">' +
            frames.map(() => '<span class="ig-box__seg"><i class="ig-box__seg-fill"></i></span>').join('') +
          '</span>'
        : '';
      // Story header: gradient avatar ring + handle + relative time.
      const header = isStory
        ? '<span class="ig-box__head">' +
            '<span class="ig-box__avatar" aria-hidden="true">' + avatarHtml + '</span>' +
            '<span class="ig-box__handle">' + escHtml(handle.replace(/^@/, '')) + '</span>' +
            '<time class="ig-box__time"></time>' +
          '</span>'
        : '';
      // Big play glyph only for reels (posts are stills; stories show chrome).
      const play = kind === 'reel'
        ? '<span class="ig-box__play" aria-hidden="false"></span>'
        : '';
      // Small circular prev/next controls — like a story carousel. They sit
      // ABOVE the box's own click (which opens Instagram) and stopPropagation,
      // so the image area opens the post while the chevrons only navigate.
      const nav = (isStory && multi)
        ? '<button type="button" class="ig-box__nav ig-box__nav--prev" aria-label="' + escAttr(t.igPrevStory) + '">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 6l-6 6 6 6"/></svg>' +
          '</button>' +
          '<button type="button" class="ig-box__nav ig-box__nav--next" aria-label="' + escAttr(t.igNextStory) + '">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 6l6 6-6 6"/></svg>' +
          '</button>'
        : '';

      // The whole box is the link now — a label cue sits at the foot, but it's
      // non-interactive (pointer-events:none) so a tap anywhere opens the post.
      const html =
        '<div class="ig-box ig-box--media' + (isStory ? ' ig-box--story' : '') + (multi ? ' is-multi' : '') + '"' +
          ' role="link" tabindex="0" aria-label="' + escAttr(label) + '">' +
          '<img class="ig-box__img" alt="" loading="eager" fetchpriority="low" decoding="async" referrerpolicy="no-referrer" />' +
          '<span class="ig-box__scrim ig-box__scrim--top" aria-hidden="true"></span>' +
          '<span class="ig-box__scrim ig-box__scrim--bottom" aria-hidden="true"></span>' +
          segs + header + play + nav +
          '<span class="ig-box__bar">' +
            '<span class="ig-box__btn">' + escHtml(label) + '</span>' +
          '</span>' +
        '</div>';

      feature.innerHTML = html;

      const box    = feature.querySelector('.ig-box');
      const img    = feature.querySelector('.ig-box__img');
      const timeEl = feature.querySelector('.ig-box__time');
      const fills  = Array.prototype.slice.call(feature.querySelectorAll('.ig-box__seg-fill'));

      // The current frame's destination — the box click + keyboard open this.
      let currentHref = instagramUrl;
      function open() { window.open(currentHref, '_blank', 'noopener,noreferrer'); }

      // ── Auto-advance timer (stories only) ────────────────────────────────
      let raf = 0, startTs = 0, lastNow = 0, paused = false;
      function clearTimer() { if (raf) { cancelAnimationFrame(raf); raf = 0; } }
      function setFill(n, pct) { if (fills[n]) fills[n].style.width = pct + '%'; }

      function tick(now) {
        if (startTs === 0) { startTs = now; lastNow = now; }
        // While paused, slide the start forward so elapsed time freezes — the
        // bar holds its position instead of snapping back on resume.
        if (paused) { startTs += now - lastNow; lastNow = now; raf = requestAnimationFrame(tick); return; }
        lastNow = now;
        const p = Math.min((now - startTs) / STORY_MS, 1);
        setFill(idx, p * 100);
        if (p < 1) { raf = requestAnimationFrame(tick); }
        else if (idx < frames.length - 1) { show(idx + 1); }
        else if (multi) { show(0); }          // loop back to the first frame
      }
      function play_() {
        clearTimer();
        if (!isStory || reduceMotion) return;
        startTs = 0; lastNow = 0;
        raf = requestAnimationFrame(tick);
      }

      function show(i) {
        clearTimer();
        idx = (i + frames.length) % frames.length;
        const f = frames[idx];
        img.src = f.image;
        currentHref = f.permalink || instagramUrl;
        if (timeEl) timeEl.textContent = timeAgo(f.timestamp);
        // Bars left of the current frame read as watched, the rest as pending.
        fills.forEach((_, n) => setFill(n, n < idx ? 100 : 0));
        play_();
      }

      // Any image failing (expired/blocked CDN URL) drops the box to the CTA.
      img.addEventListener('error', () => { clearTimer(); renderFallback(); }, { once: true });
      show(0);

      // Tap / click anywhere on the box (except the chevrons) opens the post.
      box.addEventListener('click', (e) => {
        if (e.target.closest('.ig-box__nav')) return;
        open();
      });
      box.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(); }
        if (isStory && multi) {
          if (e.key === 'ArrowRight') { show(idx + 1); e.preventDefault(); }
          if (e.key === 'ArrowLeft')  { show(idx - 1); e.preventDefault(); }
        }
      });

      // The box may be rendered early (idle preload) long before the reader
      // scrolls to it — so hold playback paused until it's actually on screen,
      // and the story always begins at the first frame when seen.
      if (isStory && 'IntersectionObserver' in window) {
        paused = true;
        const vis = new IntersectionObserver((es) => {
          paused = !es.some((e) => e.isIntersecting);
        }, { threshold: 0.4 });
        vis.observe(box);
      }

      if (isStory && multi) {
        const prevBtn = feature.querySelector('.ig-box__nav--prev');
        const nextBtn = feature.querySelector('.ig-box__nav--next');
        prevBtn.addEventListener('click', (e) => { e.stopPropagation(); show(idx - 1); });
        nextBtn.addEventListener('click', (e) => { e.stopPropagation(); show(idx + 1); });
        // Hold / hover pauses playback so the reader can linger, like the app.
        box.addEventListener('pointerenter', () => { paused = true; });
        box.addEventListener('pointerleave', () => { paused = false; });
      }
    }

    // ── Reels reveal ──────────────────────────────────────────────────────
    function setupReels(reels) {
      if (!reels || !reels.length || !reelsWrap || !reelsScroll) return;

      reelsScroll.innerHTML = reels.map((r, i) =>
        '<a class="ig-reel" href="' + escAttr(r.permalink || instagramUrl) + '"' +
        ' target="_blank" rel="noopener noreferrer" role="listitem" style="--i:' + i + '"' +
        ' aria-label="' + escAttr(r.caption ? r.caption.slice(0, 60) : t.igViewReel) + '">' +
          '<img class="ig-reel__img" src="' + escAttr(r.image) + '" alt=""' +
          ' loading="lazy" decoding="async" referrerpolicy="no-referrer"' +
          ' onerror="this.closest(\'.ig-reel\').remove()" />' +
          '<span class="ig-reel__play" aria-hidden="false"></span>' +
        '</a>'
      ).join('');

      const toggle = document.createElement('button');
      toggle.type = 'button';
      toggle.className = 'ig-reels-toggle';
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-controls', 'ig-reels');
      toggle.textContent = t.igHideReels;
      requestAnimationFrame(() => reelsWrap.classList.add('is-open'));
      feature.appendChild(toggle);

      toggle.addEventListener('click', () => {
        const isHidden = reelsWrap.hasAttribute('hidden');
        
        if (isHidden) {
          // 1. Make it present immediately
          reelsWrap.removeAttribute('hidden');
          // 2. Force a repaint so the CSS transition triggers
          void reelsWrap.offsetWidth; 
          reelsWrap.classList.add('is-open');
          
          toggle.setAttribute('aria-expanded', 'true');
          toggle.textContent = t.igHideReels;
        } else {
          // 3. Start the exit transition
          reelsWrap.classList.remove('is-open');
          toggle.setAttribute('aria-expanded', 'false');
          toggle.textContent = t.igShowReels;
          
          // 4. Hide only after the transition finishes (matches your 450ms timeout)
          const hide = () => reelsWrap.setAttribute('hidden', '');
          reelsWrap.addEventListener('transitionend', hide, { once: true });
          setTimeout(hide, 450); 
        }
      });
    }

    let loadStarted = false;
    function loadFeature() {
      if (loadStarted) return;          // idle + scroll can both fire; run once
      loadStarted = true;
      fetch('/api/instagram', { cache: 'default' })
        .then((res) => { if (!res.ok) throw new Error('no feed'); return res.json(); })
        .then((data) => {
          if (!data) { renderFallback(); return; }
          const profile = data.profile;
          const stories = Array.isArray(data.stories) ? data.stories.filter((s) => s && s.image) : [];
          if (stories.length) {
            renderBox(stories, 'story',profile);
          } else if (data.item && data.item.image) {
            renderBox([data.item], data.kind || 'post',profile);
          } else {
            renderFallback();
          }
          setupReels(Array.isArray(data.reels) ? data.reels.filter((r) => r && r.image) : []);
        })
        .catch(renderFallback);
    }

    // Load eagerly during idle time so the box (and its image) are ready well
    // before the section scrolls into view — without competing with the
    // initial render / LCP. A near-viewport observer is the fast-scroll
    // fallback in case the page never goes idle before the user gets here.
    const section = feature.closest('.ig-section') || feature;
    whenNear(section, loadFeature);
    function idleLoad() {
      if ('requestIdleCallback' in window) requestIdleCallback(loadFeature, { timeout: 2500 });
      else setTimeout(loadFeature, 1200);
    }
    if (document.readyState === 'complete') idleLoad();
    else window.addEventListener('load', idleLoad, { once: true });
  })();
</script>

<!-- is:global is REQUIRED here: the featured box, story chrome and reels are
     built at runtime via innerHTML (see the script above), so those elements
     never receive Astro's scoped data-astro-cid attribute. A normal scoped
     <style> would compile to `.ig-box[data-astro-cid-…]` and silently fail to
     match the JS-injected DOM — leaving the box a huge, unstyled image. Every
     selector below is .ig-* prefixed (or under .ig-section), so going global
     is safe. -->
<style is:global>
  /* Quiet "follow us" moment near the foot of the page — a single small box,
     not a full editorial section. */
  section.ig-section {
    overflow: hidden;
    padding-block: var(--space-l) var(--space-m);
  }
  .ig-section .section-head { margin-block-end: var(--space-m); }
  .ig-section .eyebrow { margin-block-end: 0.35rem; }
  .ig-section .display { font-size: var(--step-2); margin: 0; }

  /* ── Featured box (small) ───────────────────────────────────────────── */
  .ig-feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.9rem;
  }
  /* A small box, capped so it never dominates the page. Posts/reels/skeleton
     use a 4:5 portrait; a live story gets the tall phone-screen 9:16 shape so
     it reads like the real story viewer. Deliberately compact — this is a
     glance, not a feature. */
  .ig-box {
    position: relative;
    display: block;
    width: auto;
    max-width: clamp(200px, 55vw, 225px);
    margin-inline: auto;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 2px;
    background: var(--paper-deep);
    text-decoration: none;
    color: var(--paper-on-photo);
  }
  /* The story card keeps Instagram's rounded phone shape — an intentional
     break from the site's 2px rule, because here we *are* embedding the app. */
  /* Live story → the tall phone-screen 9:16 shape, sized so it's the focal IG
     element without dominating: a touch wider on phones, capped on desktop. */
  .ig-box--story {
    width: 100%;
    max-width: clamp(264px, 74vw, 340px);
    aspect-ratio: 9 / 16;
    max-height: min(82vh, 600px);
    /* Instagram's rounded phone shape — an intentional break from the site's
       2px rule, because here we *are* embedding the app. */
    border-radius: 18px;
    box-shadow:
      0 14px 36px -10px rgba(0, 0, 0, 0.6),
      0 0 0 1px rgba(255, 255, 255, 0.08);
  }
  /* The whole media box is the link to Instagram now. */
  .ig-box--media { cursor: pointer; }
  .ig-box--media:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
  .ig-box__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: var(--paper-deep);
    transition: transform 0.7s var(--ease-out);
  }
  .ig-box--media:hover .ig-box__img { transform: scale(1.03); }

  /* Top + bottom scrims — keep the story chrome (bars, handle, time, cue)
     legible over any photo, the way the real app gradients the edges. */
  .ig-box__scrim {
    position: absolute;
    inset-inline: 0;
    z-index: 1;
    pointer-events: none;
  }
  .ig-box__scrim--top {
    inset-block-start: 0;
    height: 38%;
    background: linear-gradient(to bottom,
      color-mix(in srgb, var(--shadow) 58%, transparent) 0%, transparent 100%);
  }
  .ig-box__scrim--bottom {
    inset-block-end: 0;
    height: 42%;
    background: linear-gradient(to top,
      color-mix(in srgb, var(--shadow) 68%, transparent) 0%, transparent 100%);
  }

  /* Skeleton shimmer (GPU-composited translate). */
  .ig-box--skeleton .ig-box__img { position: relative; overflow: hidden; }
  .ig-box--skeleton .ig-box__img::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(90deg, transparent 0%, var(--paper-edge) 50%, transparent 100%);
    transform: translateX(-100%);
    animation: igSkeleton 1.5s ease infinite;
  }
  @keyframes igSkeleton { 100% { transform: translateX(100%); } }

  /* Story segment bars (top) — a track with a fill the JS timer grows. */
  .ig-box__segs {
    position: absolute;
    inset-block-start: 0.45rem;
    inset-inline: 0.5rem;
    z-index: 5;
    display: flex;
    gap: 0.18rem;
  }
  .ig-box__seg {
    position: relative;
    flex: 1;
    height: 2px;
    border-radius: 2px;
    overflow: hidden;
    background: color-mix(in srgb, var(--paper-on-photo) 32%, transparent);
  }
  .ig-box__seg-fill {
    position: absolute;
    inset-block: 0;
    inset-inline-start: 0;
    width: 0;
    background: var(--paper-on-photo);
  }

  /* Story header — gradient avatar ring + handle + relative time, like the app.
     Sits above the tap-zones so it never swallows a tap. */
  .ig-box__head {
    position: absolute;
    inset-block-start: 0.9rem;
    inset-inline: 0.6rem;
    z-index: 6;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    pointer-events: none;
    text-shadow: 0 1px 4px rgba(0,0,0,0.55);
  }
  .ig-box__avatar {
    flex-shrink: 0;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-size: var(--step--2);
    color: var(--paper-on-photo);
    background:
      linear-gradient(var(--shadow), var(--shadow)) padding-box,
      conic-gradient(from 200deg, #f9ce34, #ee2a7b, #6228d7, #f9ce34) border-box;
    border: 2px solid transparent;
  }
  .ig-box__handle {
    font-size: var(--step--1);
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--paper-on-photo);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ig-box__time {
    flex-shrink: 0;
    font-size: var(--step--2);
    font-weight: 500;
    color: color-mix(in srgb, var(--paper-on-photo) 78%, transparent);
  }
  .ig-box__time:empty { display: none; }

  /* Play glyph for video stories/reels. */
  .ig-box__play {
    position: absolute; inset: 0; z-index: 2;
    display: grid; place-items: center; pointer-events: none;
  }
  .ig-box__play::before {
    content: '';
    width: 2.6rem; height: 2.6rem;
    border-radius: 50%;
    background: color-mix(in srgb, var(--shadow) 45%, transparent);
    backdrop-filter: blur(2px);
  }
  .ig-box__play::after {
    content: '';
    position: absolute;
    width: 0; height: 0;
    border-style: solid;
    border-width: 0.45rem 0 0.45rem 0.74rem;
    border-color: transparent transparent transparent var(--paper-on-photo);
    margin-inline-start: 0.18rem;
  }

  /* Prev / next — small round controls centred on the side edges, like the
     arrows on a story carousel. They sit above the box's own click (which
     opens Instagram) and stopPropagation, so the image area opens the post. */
  .ig-box__nav {
    position: absolute;
    inset-block-start: 50%;
    transform: translateY(-50%);
    z-index: 4;
    display: grid;
    place-items: center;
    width: 1.9rem;
    height: 1.9rem;
    border: 0;
    border-radius: 50%;
    background: color-mix(in srgb, var(--shadow) 42%, transparent);
