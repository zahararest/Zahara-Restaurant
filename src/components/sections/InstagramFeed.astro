---
// InstagramFeed — one featured moment.
//
// Hydrates from /api/instagram, which returns the account's CURRENT story if
// one is live, otherwise the latest post/reel. We show that single item as a
// portrait card with a button that opens it on Instagram, labelled by what it
// is ("Watch story" / "View reel" / "View post"). Falls back to a branded
// "Follow us" CTA when nothing is available (or no token is configured).

import { pick, home as copy } from '../../data/i18n';
import { RESTAURANT } from '../../data/restaurant';
import type { Lang }  from '../../data/i18n';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = pick(copy, lang);
---

<section class="section-tight ig-section reveal-on-scroll">
  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow eyebrow--center" data-content-key="home.igEyebrow">{t.igEyebrow}</p>
      <h2
        class="display"
        data-word-reveal
        data-word-reveal-delay="0.06"
        data-word-reveal-step="0.06"
        data-content-key="home.igHeading"
      >{t.igHeading}</h2>
    </div>

    {/* Single featured card. Starts as a skeleton, then JS swaps in the live
        story / latest post, or the follow-CTA fallback. */}
    <div class="ig-feature" data-ig-feature>
      <a class="ig-feature__card ig-feature__card--skeleton"
         href={RESTAURANT.instagram} target="_blank" rel="noopener noreferrer"
         aria-label={`${t.igFollow} · ${t.igHandle}`}>
        <span class="ig-feature__img" aria-hidden="true"></span>
      </a>
    </div>

    {/* Profile handle, always present below the feature. */}
    <div class="ig-follow reveal-on-scroll">
      <a
        class="ig-follow__link"
        href={RESTAURANT.instagram}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${t.igFollow} · ${t.igHandle}`}
      >
        <svg class="ig-follow__icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
        <span class="ig-follow__handle">{t.igHandle}</span>
        <span class="ig-follow__label">↗</span>
      </a>
    </div>
  </div>
</section>

<script is:inline define:vars={{ instagramUrl: RESTAURANT.instagram, t }}>
  (function () {
    const feature = document.querySelector('[data-ig-feature]');
    if (!feature) return;

    const escAttr = (s) => String(s == null ? '' : s).replace(/"/g, '&quot;');
    const escHtml = (s) => String(s == null ? '' : s)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

    // Defer the network call until the section is near the viewport — it sits
    // near the bottom of the page, so fetching on load only lengthens the
    // initial request chain for content nobody has scrolled to yet.
    function whenNear(el, cb) {
      if (!('IntersectionObserver' in window)) { cb(); return; }
      const io = new IntersectionObserver((entries) => {
        if (entries.some((e) => e.isIntersecting)) { io.disconnect(); cb(); }
      }, { rootMargin: '600px 0px' });
      io.observe(el);
    }

    function renderFallback() {
      feature.innerHTML =
        '<a class="ig-feature__card ig-feature__card--cta" href="' + escAttr(instagramUrl) + '"' +
        ' target="_blank" rel="noopener noreferrer" aria-label="' + escAttr(t.igFollow) + '">' +
          '<span class="ig-feature__cta-inner">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">' +
              '<rect x="2" y="2" width="20" height="20" rx="5"/>' +
              '<circle cx="12" cy="12" r="4"/>' +
              '<circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>' +
            '</svg>' +
            '<span>' + escHtml(t.igEmpty) + '</span>' +
            '<span class="ig-feature__cta-handle">' + escHtml(t.igHandle) + '</span>' +
          '</span>' +
        '</a>';
    }

    function buttonLabel(kind) {
      if (kind === 'story') return t.igWatchStory;
      if (kind === 'reel')  return t.igViewReel;
      return t.igViewPost;
    }

    function renderItem(item, kind) {
      const href  = item.permalink || instagramUrl;
      const label = buttonLabel(kind);
      const isVideo = item.media_type === 'VIDEO' || kind === 'reel' || kind === 'story';
      const liveTag = kind === 'story'
        ? '<span class="ig-feature__live">' + escHtml(t.igLiveNow) + '</span>'
        : '';
      const playIcon = isVideo
        ? '<span class="ig-feature__play" aria-hidden="true"></span>'
        : '';

      feature.innerHTML =
        '<a class="ig-feature__card" href="' + escAttr(href) + '"' +
        ' target="_blank" rel="noopener noreferrer" aria-label="' + escAttr(label) + '">' +
          '<img class="ig-feature__img" src="' + escAttr(item.image) + '"' +
          ' alt="' + escAttr(item.caption ? item.caption.slice(0, 80) : t.igHandle) + '"' +
          ' loading="lazy" decoding="async" referrerpolicy="no-referrer" />' +
          liveTag +
          playIcon +
          '<span class="ig-feature__bar">' +
            '<span class="ig-feature__btn">' + escHtml(label) + '</span>' +
          '</span>' +
        '</a>';

      // If the photo fails to load (expired/blocked CDN URL), drop to the CTA.
      const img = feature.querySelector('.ig-feature__img');
      if (img) img.addEventListener('error', renderFallback, { once: true });
    }

    function loadFeature() {
      fetch('/api/instagram', { cache: 'default' })
        .then((res) => { if (!res.ok) throw new Error('no feed'); return res.json(); })
        .then((data) => {
          if (data && data.item && data.item.image) renderItem(data.item, data.kind);
          else renderFallback();
        })
        .catch(renderFallback);
    }

    whenNear(feature.closest('.ig-section') || feature, loadFeature);
  })();
</script>

<style>
  /* Quiet "follow us" moment near the foot of the page — tighter than a main
     editorial section, one featured photo rather than a strip of squares. */
  section.ig-section {
    overflow: hidden;
    padding-block: var(--space-l) var(--space-m);
  }
  .ig-section .section-head { margin-block-end: var(--space-m); }
  .ig-section .eyebrow { margin-block-end: 0.35rem; }
  .ig-section .display { font-size: var(--step-2); margin: 0; }

  /* ── Featured card ──────────────────────────────────────────────────── */
  .ig-feature {
    display: flex;
    justify-content: center;
  }
  .ig-feature__card {
    position: relative;
    display: block;
    width: 100%;
    max-width: 22rem;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 2px;
    background: var(--paper-deep);
    text-decoration: none;
    color: var(--paper-on-photo);
  }
  .ig-feature__card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }
  .ig-feature__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: var(--paper-deep);
    transition: transform 0.7s var(--ease-out);
  }
  .ig-feature__card:hover .ig-feature__img { transform: scale(1.03); }

  /* Skeleton shimmer (GPU-composited translate, not background-position). */
  .ig-feature__card--skeleton .ig-feature__img { position: relative; overflow: hidden; }
  .ig-feature__card--skeleton .ig-feature__img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 0%, var(--paper-edge) 50%, transparent 100%);
    transform: translateX(-100%);
    animation: igSkeleton 1.5s ease infinite;
  }
  @keyframes igSkeleton { 100% { transform: translateX(100%); } }
  @media (prefers-reduced-motion: reduce) {
    .ig-feature__card--skeleton .ig-feature__img::after { animation: none; }
    .ig-feature__card:hover .ig-feature__img { transform: none; }
  }

  /* "Story · live now" tag, top-start. */
  .ig-feature__live {
    position: absolute;
    inset-block-start: 0.7rem;
    inset-inline-start: 0.7rem;
    z-index: 2;
    font-size: var(--step--2);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--paper-on-photo);
    background: color-mix(in srgb, var(--accent) 88%, transparent);
    padding: 0.25rem 0.6rem;
    border-radius: 2px;
  }

  /* Play glyph for video stories/reels (CSS triangle, no asset). */
  .ig-feature__play {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: grid;
    place-items: center;
    pointer-events: none;
  }
  .ig-feature__play::before {
    content: '';
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 50%;
    background: color-mix(in srgb, var(--shadow) 45%, transparent);
    backdrop-filter: blur(2px);
  }
  .ig-feature__play::after {
    content: '';
    position: absolute;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0.55rem 0 0.55rem 0.9rem;
    border-color: transparent transparent transparent var(--paper-on-photo);
    margin-inline-start: 0.2rem;
  }

  /* Bottom bar holding the type-labelled button. */
  .ig-feature__bar {
    position: absolute;
    inset-inline: 0;
    inset-block-end: 0;
    z-index: 2;
    display: flex;
    justify-content: center;
    padding: 1rem;
    background: linear-gradient(to top,
      color-mix(in srgb, var(--shadow) 82%, transparent) 0%,
      transparent 100%);
  }
  .ig-feature__btn {
    font-size: var(--step--1);
    letter-spacing: 0.08em;
    color: var(--paper-on-photo);
    padding-bottom: 2px;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 85%, transparent);
    transition: border-color 0.25s ease;
  }
  .ig-feature__card:hover .ig-feature__btn { border-bottom-color: var(--paper-on-photo); }

  /* Fallback CTA card */
  .ig-feature__card--cta { display: grid; place-items: center; }
  .ig-feature__cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--ink-muted);
    font-size: var(--step--1);
    padding: var(--space-m);
    text-align: center;
  }
  .ig-feature__cta-inner svg { width: 2rem; height: 2rem; color: var(--ink-muted); }
  .ig-feature__cta-handle { font-size: var(--step--2); color: var(--accent); letter-spacing: 0.05em; }

  /* Follow link below the feature */
  .ig-follow {
    display: flex;
    justify-content: center;
    margin-block-start: var(--space-m);
  }
  .ig-follow__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--step--1);
    letter-spacing: 0.08em;
    text-decoration: none;
    color: var(--ink-muted);
    transition: color 0.2s;
  }
  .ig-follow__link:hover { color: var(--ink); }
  .ig-follow__icon { width: 1.1rem; height: 1.1rem; flex-shrink: 0; }
  .ig-follow__label { font-size: 0.8em; }
</style>
