---
import Photo            from '../Photo.astro';
import type { Lang }    from '../../data/i18n';
import type { PhotoEntry } from '../../data/photos';

export interface Props {
  lang:       Lang;
  photo:      PhotoEntry;
  eyebrow:    string;
  /** Heading HTML — may contain inline <br /> markers (rendered with set:html). */
  heading:    string;
  /** Paragraphs in order. May contain inline HTML (rendered with set:html). */
  paragraphs: readonly string[];
  /** Optional CTA at the bottom of the block. */
  cta?:       { label: string; href: string; key?: string };
  /** Optional secondary CTA, shown as a ghost button beside `cta`. */
  cta2?:      { label: string; href: string; key?: string };
  /** Place the photo on the trailing edge (mirrored layout). */
  reverse?:   boolean;
  /** Optional admin-editable content keys (data-content-key). */
  eyebrowKey?:    string;
  headingKey?:    string;
  paragraphKeys?: readonly string[];
}

const { lang, photo, eyebrow, heading, paragraphs, cta, cta2, reverse = false,
        eyebrowKey, headingKey, paragraphKeys } = Astro.props;
const classList = reverse ? 'photo-block photo-block--reverse' : 'photo-block';
---

<section class="section">
  <div class="wrap">
    <div class={classList}>
      <div class="reveal-on-scroll">
        <Photo src={photo.src} alt={photo.alt[lang]} aspect="4/5" />
      </div>
      <div class="photo-block__content stagger reveal-on-scroll">
        <p class="eyebrow" data-content-key={eyebrowKey}>{eyebrow}</p>
        <h2
          class="display"
          data-word-reveal
          data-word-reveal-delay="0.06"
          data-word-reveal-step="0.06"
          data-content-key={headingKey}
          data-content-html={headingKey ? '' : undefined}
          set:html={heading}
        />
        {paragraphs.map((p, i) => (
          <p
            data-content-key={paragraphKeys?.[i]}
            data-content-html={paragraphKeys?.[i] ? '' : undefined}
            set:html={p}
          />
        ))}
        {(cta || cta2) && (
          <div class="btn-row">
            {cta  && <a class="btn"          href={cta.href}  data-content-key={cta.key}>{cta.label}</a>}
            {cta2 && <a class="btn btn--ghost" href={cta2.href} data-content-key={cta2.key}>{cta2.label}</a>}
          </div>
        )}
      </div>
    </div>
  </div>
</section>
