---
import { resized, resizedSrcset } from '../../lib/photo';
import type { Lang }       from '../../data/i18n';
import type { PhotoEntry } from '../../data/photos';

export interface Props {
  lang:     Lang;
  photo:    PhotoEntry;
  caption?: string;
  /** Override the default tall hero height. Pass any CSS height. */
  height?:  string;
  /** Promote to eager loading for above-the-fold bleed photos. */
  eager?:   boolean;
}

const { lang, photo, caption, height, eager = false } = Astro.props;
const classList = caption ? 'bleed-photo bleed-photo--caption' : 'bleed-photo';
// Finer steps so a ~1400px-wide bleed picks ~1400, not the 1800 variant.
const BLEED_WIDTHS = [800, 1100, 1400, 1700, 2100, 2560] as const;
---

<figure class={classList} data-caption={caption} style={height ? `height: ${height};` : undefined}>
  <img
    src={resized(photo.src, 1800)}
    srcset={resizedSrcset(photo.src, BLEED_WIDTHS)}
    sizes="100vw"
    alt={photo.alt[lang]}
    loading={eager ? 'eager' : 'lazy'}
    decoding="async"
  />
</figure>
