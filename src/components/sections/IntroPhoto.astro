---
// Photo-backed intro for sub-pages (menu, etc.) — shorter than HeroBleed,
// but uses the same overlay treatment so a transparent header sits nicely
// on top of it.

import { resized, resizedSrcset, resizedMobileCoverSrcset }  from '../../lib/photo';
import type { Lang }       from '../../data/i18n';
import type { PhotoEntry } from '../../data/photos';

export interface Props {
  lang:    Lang;
  photo:   PhotoEntry;
  eyebrow: string;
  /** Heading text. May contain inline HTML (rendered with set:html). */
  heading: string;
  lede?:   string;
  /** Optional admin-editable content keys (data-content-key) per text. */
  eyebrowKey?: string;
  headingKey?: string;
  ledeKey?:    string;
}

const { lang, photo, eyebrow, heading, lede, eyebrowKey, headingKey, ledeKey } = Astro.props;
const INTRO_WIDTHS = [800, 1200, 1800, 2400] as const;
// On phones .intro-photo is ~62vh (clamp 360–520px) → roughly 3:4. Request a
// subject-aware portrait crop via /photos-m (the admin mobile upload, or a crop
// of the desktop image when none is set) sized to that aspect.
const INTRO_MOBILE_COVER = [[640, 850], [820, 1090], [1080, 1440]] as const;
---

<section class="intro-photo" aria-label={eyebrow}>
  <div class="intro-photo__media" data-hero-parallax aria-hidden="true">
    <picture>
      <source
        media="(max-width: 600px)"
        srcset={resizedMobileCoverSrcset(photo.src, INTRO_MOBILE_COVER)}
        sizes="100vw"
      />
      <img
        class="intro-photo__img ken-burns"
        src={resized(photo.src, 1800)}
        srcset={resizedSrcset(photo.src, INTRO_WIDTHS)}
        sizes="100vw"
        alt={photo.alt[lang]}
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </picture>
  </div>
  <div class="intro-photo__overlay" aria-hidden="true"></div>
  <div class="intro-photo__inner">
    <p class="eyebrow eyebrow--on-photo fade-up" data-content-key={eyebrowKey}>{eyebrow}</p>
    <h1
      class="display intro-photo__title"
      data-word-reveal
      data-word-reveal-delay="0.12"
      data-word-reveal-step="0.07"
      data-content-key={headingKey}
      set:html={heading}
    />
    {lede && <p class="intro-photo__lede fade-up" data-content-key={ledeKey}>{lede}</p>}
  </div>
</section>
