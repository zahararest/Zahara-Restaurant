---
import { pick, home as copy } from '../../data/i18n';
import { RESTAURANT }          from '../../data/restaurant';
import { PHOTOS }              from '../../data/photos';
import { path }                from '../../lib/paths';
import type { Lang }           from '../../data/i18n';

export interface Props { lang: Lang }

const { lang } = Astro.props;
const t        = pick(copy, lang);
const dial     = lang === 'he' ? RESTAURANT.phone.dialHe    : RESTAURANT.phone.dialEn;
const display  = lang === 'he' ? RESTAURANT.phone.display    : RESTAURANT.phone.intlDisplay;

const kosherCert = PHOTOS.kosherCert.src;
const closeLabel = lang === 'he' ? 'סגור' : 'Close';
---

<div class="info-strip">
  <div class="wrap">
    <div class="info-strip__grid stagger reveal-on-scroll">
      <div class="info-strip__cell">
        <div class="meta-block__label" data-content-key="info.hoursLabel">{t.infoHoursLabel}</div>
        <div class="meta-block__value" data-content-key="info.hoursValue">{t.infoHoursValue}</div>
      </div>

      <div class="info-strip__cell">
        <div class="meta-block__label" data-content-key="info.addressLabel">{t.infoAddressLabel}</div>
        <a class="meta-block__value" href={path('about', lang)} data-content-key="info.addressValue">{t.infoAddressValue}</a>
      </div>

      <div class="info-strip__cell">
        <div class="meta-block__label" data-content-key="info.reservLabel">{t.infoReservLabel}</div>
        <a class="meta-block__value"   href={`tel:${dial}`} data-content-key="info.reservValue">{display}</a>
        <a class="info-strip__sub"     href={RESTAURANT.reservationUrl} target="_blank" rel="noopener" data-content-key="info.reservTabit">{t.infoTabit}</a>
      </div>

      <div class="info-strip__cell info-strip__cell--kosher" data-kosher-cell>
        <div class="meta-block__label" data-content-key="info.kosherLabel">{t.infoKosherLabel}</div>
        <button class="meta-block__value info-kosher__trigger" type="button"
                data-kosher-open data-content-key="info.kosherValue">{t.infoKosherValue}</button>
        <button class="info-strip__sub info-kosher__sub" type="button"
                data-kosher-open data-content-key="info.kosherView">{t.infoKosherView}</button>
      </div>
    </div>
  </div>
</div>

{/* Hover/peek preview — position: fixed so overflow:hidden on parent cannot clip it */}
<div class="info-kosher__preview" id="kosher-preview" aria-hidden="true">
  <img class="info-kosher__thumb" src={kosherCert} alt="" width="210" height="297" loading="lazy" decoding="async" />
</div>

{/* Lightbox dialog */}
<dialog class="kosher-dialog" id="kosher-dialog" aria-label={t.infoKosherLabel}>
  <button class="kosher-dialog__close" type="button" aria-label={closeLabel} data-kosher-close>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"
         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M18 6 6 18M6 6l12 12"/>
    </svg>
  </button>
  <img class="kosher-dialog__img" src={kosherCert} alt={t.infoKosherLabel} />
</dialog>

<script>
  (() => {
    const dialog  = document.getElementById('kosher-dialog')  as HTMLDialogElement | null;
    const preview = document.getElementById('kosher-preview') as HTMLElement | null;
    const cell    = document.querySelector('[data-kosher-cell]') as HTMLElement | null;

    if (!dialog || !preview || !cell) return;

    // Non-null after the guard — reassert so closures inherit the narrowed type.
    const _preview = preview!;
    const _cell    = cell!;

    // ── Probe: if cert not uploaded yet, hide all cert UI ──────────────────
    const certSrc = (dialog.querySelector('img') as HTMLImageElement)?.src;
    const probe   = new Image();
    probe.onerror = () => {
      _cell.style.display = 'none';
      _preview.remove();
      dialog.remove();
    };
    probe.src = certSrc ?? '';

    // Anchor element — the "View certificate" link. The preview is always
    // pinned directly beneath it (it's position:fixed, so we track the
    // anchor's live rect and keep the preview glued under it as you scroll).
    const anchor = (_cell.querySelector('.info-kosher__sub') as HTMLElement) ?? _cell;

    function positionPreview() {
      const r        = anchor.getBoundingClientRect();
      const previewW = _preview.offsetWidth || 200;
      const gap      = 10;

      const halfW = previewW / 2;
      let left = r.left + r.width / 2;    // centred on the link (transform -50%)
      left = Math.max(halfW + 8, Math.min(left, window.innerWidth - halfW - 8));

      _preview.style.top  = `${r.bottom + gap}px`;
      _preview.style.left = `${left}px`;
    }

    let peekTimer: ReturnType<typeof setTimeout> | null = null;

    function showPreview() {
      positionPreview();
      _preview.classList.add('is-visible');
    }
    function hidePreview() {
      _preview.classList.remove('is-visible');
      if (peekTimer) { clearTimeout(peekTimer); peekTimer = null; }
    }
    function peekFor(ms: number) {
      if (peekTimer) clearTimeout(peekTimer);
      showPreview();
      peekTimer = setTimeout(hidePreview, ms);
    }

    // ── Hover — only on pointer devices (suppress on touch) ────────────────
    if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
      _cell.addEventListener('mouseenter', showPreview);
      _cell.addEventListener('mouseleave', hidePreview);
    }
    // Keep the preview pinned beneath the "View certificate" link as the
    // page scrolls. rAF-throttled so the getBoundingClientRect read happens
    // at most once per frame instead of synchronously on every scroll event
    // (which forced a reflow per event and stuttered near this section).
    let rafPending = false;
    window.addEventListener('scroll', () => {
      if (rafPending || !_preview.classList.contains('is-visible')) return;
      rafPending = true;
      requestAnimationFrame(() => {
        rafPending = false;
        if (_preview.classList.contains('is-visible')) positionPreview();
      });
    }, { passive: true });

    // ── Click → open lightbox ───────────────────────────────────────────────
    _cell.querySelectorAll('[data-kosher-open]').forEach((btn) => {
      btn.addEventListener('click', () => dialog.showModal());
    });

    // ── Close lightbox ──────────────────────────────────────────────────────
    dialog.querySelectorAll('[data-kosher-close]').forEach((btn) => {
      btn.addEventListener('click', () => dialog.close());
    });
    dialog.addEventListener('click', (e) => { if (e.target === dialog) dialog.close(); });

    // ── Auto-peek once, while the kosher cell is fully on screen ───────────
    // Firing here (rather than after the strip scrolls away) means the
    // preview can anchor directly beneath the cell the visitor is looking at.
    if ('IntersectionObserver' in window) {
      let fired = false;
      const io = new IntersectionObserver((entries) => {
        if (fired) return;
        const entry = entries[0];
        if (entry.isIntersecting && entry.intersectionRatio >= 0.99) {
          fired = true;
          peekFor(3000);
          io.disconnect();
        }
      }, { threshold: [0, 0.5, 0.99, 1] });
      io.observe(_cell);
    }
  })();
</script>

<style>
  /* ── Kosher trigger buttons ───────────────────────────────────────────── */
  .info-kosher__trigger,
  .info-kosher__sub {
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    font: inherit;
    color: inherit;
    text-align: center;
  }
  .info-kosher__sub {
    font-size: var(--step--2);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    transition: color 0.2s ease;
  }
  .info-kosher__sub:hover { color: var(--accent-deep); }

  /* ── Preview — fixed so overflow:hidden parents can't clip it ─────────── */
  .info-kosher__preview {
    position: fixed;
    transform: translateX(-50%) translateY(0.5rem);
    width: clamp(160px, 20vw, 210px);
    background: var(--paper-card);
    border: 1px solid var(--rule);
    padding: 0.4rem;
    box-shadow: 0 12px 40px color-mix(in srgb, var(--shadow) 40%, transparent);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease, transform 0.22s ease;
    z-index: 200;
  }
  .info-kosher__preview.is-visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  .info-kosher__thumb {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Lightbox dialog ───────────────────────────────────────────────────── */
  .kosher-dialog {
    position: fixed;
    inset: 0;
    margin: auto;
    padding: 0;
    border: 0;
    width: min(90vw, 560px);
    max-height: min(90svh, 800px);
    background: var(--paper-card);
    box-shadow: 0 32px 100px color-mix(in srgb, var(--shadow) 58%, transparent);
    overflow: hidden;
    border-radius: 2px;
  }
  .kosher-dialog::backdrop {
    background: color-mix(in srgb, var(--shadow) 70%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .kosher-dialog__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .kosher-dialog__close {
    position: absolute;
    top: 0.5rem;
    inset-inline-end: 0.5rem;
    width: 2.75rem;   /* 44px touch target */
    height: 2.75rem;
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--shadow) 45%, transparent);
    border: 1px solid color-mix(in srgb, var(--paper-on-photo) 25%, transparent);
    border-radius: 50%;
    color: var(--paper-on-photo);
    cursor: pointer;
    z-index: 2;
    transition: background 0.2s ease;
  }
  .kosher-dialog__close:hover { background: color-mix(in srgb, var(--shadow) 65%, transparent); }
  .kosher-dialog__close svg { width: 1rem; height: 1rem; }

  @media (max-width: 480px) {
    .kosher-dialog { width: 95vw; }
    /* Preview too wide for narrow screens — shrink it */
    .info-kosher__preview { width: min(160px, 44vw); }
  }

  /* Story-scene colour overrides */
  :global(.story-scene) .info-kosher__trigger { color: var(--paper-on-photo); }
  :global(.story-scene) .info-kosher__sub     { color: var(--gold); }
  :global(.story-scene) .info-kosher__sub:hover { color: var(--paper-on-photo); }
</style>
