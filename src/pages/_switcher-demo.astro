---
// TEMPORARY preview page — three site-switcher designs to choose from.
// Visit /switcher-demo/ , try each, then tell me which to ship.
// Delete this file once a design is picked.
import '../styles/global.css';
---

<!doctype html>
<html lang="he" dir="rtl" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Site switcher — preview</title>
  <style>
    body { margin: 0; min-height: 100vh;
      background:
        radial-gradient(120% 80% at 50% -10%, color-mix(in srgb, var(--accent) 22%, transparent), transparent 60%),
        linear-gradient(160deg, #1a130c, #0c0907 60%, #14100b);
      color: var(--paper-on-photo); font-family: var(--font-body); padding: clamp(1.5rem, 5vw, 4rem); }
    .lead { max-width: 60ch; margin: 0 auto 2.5rem; text-align: center; }
    .lead h1 { font-family: var(--font-display); font-size: clamp(1.8rem,5vw,2.8rem); margin: 0 0 .6rem; }
    .lead p { color: color-mix(in srgb, var(--paper-on-photo) 78%, transparent); margin: .2rem 0; }
    .grid { display: grid; gap: clamp(1rem,3vw,2rem); max-width: 1100px; margin: 0 auto; }
    .demo { border: 1px solid color-mix(in srgb, var(--paper-on-photo) 18%, transparent); border-radius: 4px;
      background: color-mix(in srgb, #000 28%, transparent); backdrop-filter: blur(4px); overflow: visible; }
    .demo__tag { padding: .8rem 1.2rem; font-size: .72rem; letter-spacing: .22em; text-transform: uppercase;
      font-weight: 600; color: var(--accent); border-bottom: 1px solid color-mix(in srgb, var(--paper-on-photo) 14%, transparent); }
    .demo__stage { position: relative; min-height: 92px; display: flex; align-items: center;
      justify-content: center; gap: 1rem; padding: 1.4rem; }
    .demo__hint { padding: 0 1.2rem 1rem; font-size: .8rem; color: color-mix(in srgb, var(--paper-on-photo) 60%, transparent); text-align: center; }
    .wordmark { font-family: var(--font-display); font-size: 1.6rem; letter-spacing: .1em; color: var(--paper-on-photo); }

    /* ── Option 1 · Segmented toggle ─────────────────────────── */
    .seg { position: relative; display: inline-flex; border: 1px solid color-mix(in srgb, var(--paper-on-photo) 35%, transparent);
      border-radius: 999px; padding: 3px; background: color-mix(in srgb, #000 30%, transparent); }
    .seg__pill { position: absolute; inset-block: 3px; inset-inline-start: 3px; width: calc(50% - 3px);
      border-radius: 999px; background: var(--accent); transition: inset-inline-start .35s cubic-bezier(.2,.7,.2,1); z-index: 0; }
    .seg.is-roof .seg__pill { inset-inline-start: 50%; }
    .seg__btn { position: relative; z-index: 1; appearance: none; background: none; border: 0; cursor: pointer;
      font: inherit; font-size: .8rem; letter-spacing: .12em; text-transform: uppercase; font-weight: 600;
      color: color-mix(in srgb, var(--paper-on-photo) 78%, transparent); padding: .5rem 1.1rem; border-radius: 999px;
      display: inline-flex; align-items: center; gap: .4rem; transition: color .3s; white-space: nowrap; }
    .seg__btn.is-active { color: #1a130c; }
    .seg__soon { font-size: .56rem; letter-spacing: .1em; padding: .1em .4em; border-radius: 999px;
      background: color-mix(in srgb, var(--paper-on-photo) 22%, transparent); }
    .seg.is-roof .seg__btn:last-child .seg__soon { background: color-mix(in srgb, #1a130c 25%, transparent); }

    /* ── Option 2 · Split-screen portal ──────────────────────── */
    .chev { appearance: none; background: none; border: 0; cursor: pointer; color: inherit; font-size: 1.3rem;
      line-height: 1; padding: .2rem .4rem; opacity: .85; transition: opacity .2s, transform .3s; }
    .chev:hover { opacity: 1; }
    .portal { position: fixed; inset: 0; z-index: 50; display: grid; grid-template-columns: 1fr 1fr;
      opacity: 0; pointer-events: none; transition: opacity .4s ease; }
    .portal.is-open { opacity: 1; pointer-events: auto; }
    .portal__half { position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: .6rem; text-decoration: none; color: var(--paper-on-photo); overflow: hidden;
      transform: translateY(20px); transition: transform .5s cubic-bezier(.2,.7,.2,1), filter .4s; filter: brightness(.85); }
    .portal.is-open .portal__half { transform: translateY(0); }
    .portal__half:hover { filter: brightness(1.05); }
    .portal__half--za   { background: radial-gradient(120% 100% at 50% 0%, #3a2c1a, #15100a); }
    .portal__half--roof { background: radial-gradient(120% 100% at 50% 0%, #2a2030, #0e0b12); }
    .portal__name { font-family: var(--font-display); font-size: clamp(1.6rem,5vw,3rem); letter-spacing: .12em; }
    .portal__tag { font-size: .75rem; letter-spacing: .2em; text-transform: uppercase; color: var(--accent); }
    .portal__close { position: fixed; inset-block-start: 1.2rem; inset-inline-end: 1.4rem; z-index: 51; appearance: none;
      background: none; border: 1px solid color-mix(in srgb,var(--paper-on-photo) 40%,transparent); color: var(--paper-on-photo);
      width: 2.6rem; height: 2.6rem; border-radius: 50%; font-size: 1.3rem; cursor: pointer; }

    /* ── Option 3 · Wordmark morph ───────────────────────────── */
    .morph { appearance: none; background: none; border: 0; cursor: pointer; color: inherit; display: inline-flex;
      align-items: center; gap: .5rem; padding: .3rem; }
    .morph__faces { position: relative; display: inline-grid; }
    .morph__face { grid-area: 1/1; font-family: var(--font-display); letter-spacing: .1em; color: var(--paper-on-photo);
      white-space: nowrap; transition: opacity .4s, transform .4s; backface-visibility: hidden; }
    .morph__face--za   { font-size: 1.6rem; }
    .morph__face--roof { font-size: 1.35rem; opacity: 0; transform: translateY(0.5rem); display: inline-flex; align-items: center; gap: .5rem; }
    .morph.is-roof .morph__face--za   { opacity: 0; transform: translateY(-0.5rem); }
    .morph.is-roof .morph__face--roof { opacity: 1; transform: translateY(0); }
    .morph__soon { font-size: .56rem; letter-spacing: .1em; padding: .12em .45em; border-radius: 999px;
      background: var(--accent); color: #1a130c; text-transform: uppercase; }
    .morph .chev { transition: transform .4s; }
    .morph.is-roof .chev { transform: rotate(180deg); }
  </style>
</head>
<body>
  <div class="lead">
    <h1>Site switcher — three ideas</h1>
    <p>Try each one. Tell me the number you like and I'll wire it into the real header (Nucha Rooftop shows a "soon" state until its site is live).</p>
  </div>

  <div class="grid">
    <!-- Option 1 -->
    <section class="demo">
      <div class="demo__tag">Option 1 · Segmented toggle switch</div>
      <div class="demo__stage">
        <span class="wordmark">זהרה</span>
        <div class="seg" id="seg">
          <span class="seg__pill"></span>
          <button class="seg__btn is-active" data-seg="za">Zahara</button>
          <button class="seg__btn" data-seg="roof">Rooftop <span class="seg__soon">soon</span></button>
        </div>
      </div>
      <p class="demo__hint">Tap the other side — the gold pill slides. (When the rooftop site is live, that tap navigates there.)</p>
    </section>

    <!-- Option 2 -->
    <section class="demo">
      <div class="demo__tag">Option 2 · Split-screen venue portal</div>
      <div class="demo__stage">
        <span class="wordmark">זהרה</span>
        <button class="chev" id="portalOpen" aria-label="Switch venue">‹</button>
      </div>
      <p class="demo__hint">Tap the ‹ — a two-venue chooser slides over the screen. (Photos go in the panels on the real site.)</p>
    </section>

    <!-- Option 3 -->
    <section class="demo">
      <div class="demo__tag">Option 3 · Wordmark morph</div>
      <div class="demo__stage">
        <button class="morph" id="morph" aria-label="Switch venue">
          <span class="morph__faces">
            <span class="morph__face morph__face--za">זהרה</span>
            <span class="morph__face morph__face--roof">Nucha Rooftop <span class="morph__soon">soon</span></span>
          </span>
          <span class="chev" aria-hidden="true">‹</span>
        </button>
      </div>
      <p class="demo__hint">Tap the wordmark — it crossfades between זהרה and Nucha Rooftop in place.</p>
    </section>
  </div>

  <!-- Portal overlay (Option 2) -->
  <div class="portal" id="portal">
    <a class="portal__half portal__half--za" href="#">
      <span class="portal__name">זהרה</span>
      <span class="portal__tag">Restaurant · you're here</span>
    </a>
    <a class="portal__half portal__half--roof" href="#">
      <span class="portal__name">NUCHA ROOFTOP</span>
      <span class="portal__tag">Coming soon ↗</span>
    </a>
    <button class="portal__close" id="portalClose" aria-label="Close">×</button>
  </div>

  <script is:inline>
    // Option 1
    var seg = document.getElementById('seg');
    seg.querySelectorAll('.seg__btn').forEach(function (b) {
      b.addEventListener('click', function () {
        seg.classList.toggle('is-roof', b.dataset.seg === 'roof');
        seg.querySelectorAll('.seg__btn').forEach(function (x) { x.classList.toggle('is-active', x === b); });
      });
    });
    // Option 2
    var portal = document.getElementById('portal');
    document.getElementById('portalOpen').addEventListener('click', function () { portal.classList.add('is-open'); });
    document.getElementById('portalClose').addEventListener('click', function () { portal.classList.remove('is-open'); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') portal.classList.remove('is-open'); });
    // Option 3
    var morph = document.getElementById('morph');
    morph.addEventListener('click', function () { morph.classList.toggle('is-roof'); });
  </script>
</body>
</html>
