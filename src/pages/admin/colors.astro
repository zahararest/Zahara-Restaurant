---
// Live colour editor for the Zahara palette.
//
// All edits write to localStorage AND broadcast via
// BroadcastChannel('zahara-colors') so any open site tab updates in
// real time. Production deploys are untouched — these are per-browser
// overrides only. Use "Export CSS" to copy a permanent palette into
// src/styles/global.css when you're satisfied.

const TITLE = 'Color editor · Zahara';

interface Token {
  token: string;
  label: string;
  def:   string;
  /** Plain-language hint shown beneath the label. */
  hint?: string;
  /** Used by the preview to highlight elements that depend on this
   *  token. Each preview element carries data-uses="…". */
  shortName: string;
}
interface Group {
  group: string;
  intro: string;
  tokens: Token[];
}

// Hints are descriptions of where each token ACTUALLY shows up on the
// public site. Keep them honest — if the preview pulses an element for
// a token that doesn't really change, users lose trust fast. The Show
// (👁) button on each row lights up every fragment in the preview pane
// that lists this token in its data-uses, so the description and the
// pulses must agree.
const groups: Group[] = [
  {
    group: 'Paper & surfaces',
    intro: 'The cream / paper tones. <code>--paper</code> is the page itself; the others are progressively raised or specialised surfaces.',
    tokens: [
      { token: '--paper',          shortName: 'paper',          label: 'Paper (page bg)',
        hint:  'The page background everywhere — home, menu, contact, location. Also the gallery and the mobile navigation drawer.',
        def:   '#F0E8D2' },
      { token: '--paper-deep',     shortName: 'paper-deep',     label: 'Paper deep',
        hint:  'Footer background. The info-strip band under the hero. The "issue stamp" masthead line. Quietly raised surfaces against the page.',
        def:   '#E5DCC4' },
      { token: '--paper-edge',     shortName: 'paper-edge',     label: 'Paper edge',
        hint:  'Strong borders on raised cards — the menu-page cocktail cards and the contact-form card edge.',
        def:   '#D8CCAE' },
      { token: '--paper-card',     shortName: 'paper-card',     label: 'Paper card',
        hint:  'Filled card surfaces on the /menu/ page (cocktail cards) and on /contact/ (form panel + reach-us card). Does NOT affect the home page menu chapters — those sit on photographs.',
        def:   '#F7F0DB' },
      { token: '--paper-on-photo', shortName: 'paper-on-photo', label: 'Paper on photo',
        hint:  'All light text and buttons placed OVER a photograph: the floating header on hero pages, hero CTA buttons, every menu-cinema chapter title / item / price on the home page, "section on photo" body text.',
        def:   '#F4ECCF' },
    ],
  },
  {
    group: 'Ink (text)',
    intro: 'Text colours from solid through faint. Photo overlays and shadow halos do NOT use these tokens — they use a private <code>--shadow</code>. So changing ink here only changes actual text.',
    tokens: [
      { token: '--ink',       shortName: 'ink',       label: 'Ink (body text)',
        hint:  'All headlines, primary body text on paper backgrounds, dark buttons (Reserve, scroll-to-top, accessibility toggle). Does not tint the floating header on photos.',
        def:   '#1A1410' },
      { token: '--ink-soft',  shortName: 'ink-soft',  label: 'Ink soft',
        hint:  'Long-form paragraph text on the home story, photo-block paragraphs, the hero lede.',
        def:   '#3D362E' },
      { token: '--ink-muted', shortName: 'ink-muted', label: 'Ink muted',
        hint:  'Every eyebrow label, form field labels, footer notes, the table-of-contents captions, info-strip labels.',
        def:   '#8A7E68' },
      { token: '--ink-faint', shortName: 'ink-faint', label: 'Ink faint',
        hint:  'The dotted leader between TOC chapter titles and captions, secondary metadata, the wine-price separator.',
        def:   '#B6A98C' },
    ],
  },
  {
    group: 'Rules & dividers',
    intro: 'Horizontal rules and borders. The visible ones separate sections; the soft ones live inside cards.',
    tokens: [
      { token: '--rule',      shortName: 'rule',      label: 'Rule (visible)',
        hint:  'Strong dividers between major sections, form input borders, the accessibility-panel border.',
        def:   '#CFC3A4' },
      { token: '--rule-soft', shortName: 'rule-soft', label: 'Rule soft',
        hint:  'Quiet dividers inside cards and form rows, between menu items, and the menu-page sticky-tab underline.',
        def:   '#E2D8BB' },
    ],
  },
  {
    group: 'Primary accent',
    intro: 'The single accent colour the site leans on for emphasis — eyebrow rules, prices, hover underlines, sliding tab indicators.',
    tokens: [
      { token: '--accent',      shortName: 'accent',      label: 'Accent (primary)',
        hint:  'Eyebrow rule mark, every menu price (home + menu page), the sliding tab indicator on /menu/ and /contact/, hover underlines.',
        def:   '#A88947' },
      { token: '--accent-deep', shortName: 'accent-deep', label: 'Accent deep',
        hint:  'Hover state for accent-coloured links and the "Reach us" email/phone underline on /contact/.',
        def:   '#7A6231' },
      { token: '--accent-soft', shortName: 'accent-soft', label: 'Accent soft tint',
        hint:  'Background tint for selected text and the pull-quote panel.',
        def:   '#EAE0BD' },
    ],
  },
  {
    group: 'Highlights & category accents',
    intro: 'Gold secondary highlight plus four category accents pulled from the printed menu bands. The category colours mark the menu page chapter chips.',
    tokens: [
      { token: '--gold',    shortName: 'gold',    label: 'Gold highlight',
        hint:  'The italic emphasis word inside the chef pull-quote (on the moody chef photo), wine-list highlights.',
        def:   '#B69A52' },
      { token: '--c-green', shortName: 'c-green', label: 'Category — green',
        hint:  'Sage green band. Use as the food-section chip / divider on /menu/.',
        def:   '#5A786A' },
      { token: '--c-teal',  shortName: 'c-teal',  label: 'Category — teal',
        hint:  'Deep teal band. Cocktails section.',
        def:   '#3E6D77' },
      { token: '--c-slate', shortName: 'c-slate', label: 'Category — slate',
        hint:  'Slate / petrol band. Wine section.',
        def:   '#3E5359' },
      { token: '--c-mauve', shortName: 'c-mauve', label: 'Category — mauve',
        hint:  'Dusty mauve band. Desserts section.',
        def:   '#9D8499' },
    ],
  },
  {
    group: 'Status colours',
    intro: 'Used by the contact form and the accessibility statement page.',
    tokens: [
      { token: '--ok',  shortName: 'ok',  label: 'Success', hint: 'Successful contact-form submission message.',          def: '#4F6B47' },
      { token: '--err', shortName: 'err', label: 'Error',   hint: 'Form validation failures and network-error messages.', def: '#A53623' },
    ],
  },
];

const allTokens = groups.flatMap((g) => g.tokens);
const defaults = Object.fromEntries(allTokens.map((t) => [t.token, t.def]));

