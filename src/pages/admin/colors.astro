---
// ─────────────────────────────────────────────────────────────────────────────
//
// Architecture notes
// ──────────────────
// • Token groups + Token definitions live here (server-side) because Astro
//   uses them to render the HTML row elements. This is the correct Astro
//   pattern for static server-rendered data.
//
// • PRESETS are defined inside the <script> tag below — they are purely
//   client-side data. Keeping them here in the frontmatter and passing them
//   via define:vars was unnecessary. Only `defaults` (the token→hex map) is
//   passed via define:vars because it is derived from the array above.
//
// • STAGING MODEL: applyToken() applies to :root immediately so the preview
//   updates live, but does NOT write to localStorage or broadcast to other
//   tabs. Only clicking "Save" (or ⌘S / Ctrl+S) persists changes. "Discard"
//   reverts all unsaved changes.

import '../../styles/admin-colors.css';
import { groups, defaults, darkDefaults } from '../../data/admin-colors';

const TITLE = 'Color editor · Zahara';
// Presets live in the <script> below — no define:vars needed for them.
---

<!doctype html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{TITLE}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />

</head>
<body>

<header class="editor-top">
  <nav class="editor-top__nav" aria-label="Admin sections">
    <a class="editor-top__brand" href="/admin/">Zahara · Admin</a>
    <a class="editor-top__navlink"           href="/admin/">Menu editor</a>
    <a class="editor-top__navlink"           href="/admin/images/">Images</a>
    <a class="editor-top__navlink"           href="/admin/content/">Content</a>
    <a class="editor-top__navlink is-active" href="/admin/colors/" aria-current="page">Colors</a>
    <span class="editor-top__spacer"></span>
    <a class="editor-top__site" href="/en/" target="_blank">View site ↗</a>
  </nav>

  <div class="editor-top__tools">
    <h1>Palette editor</h1>

    <input type="search" class="top-search" data-search
           placeholder="Search tokens…" aria-label="Search colour tokens" />

    <select class="top-select" data-preset aria-label="Load a preset theme">
      <option value="">Load preset…</option>
      <optgroup label="Light themes">
        <option value="default">Default (warm cream)</option>
        <option value="monochrome">Monochrome</option>
        <option value="terracotta">Terracotta</option>
        <option value="forest">Forest</option>
        <option value="navy-light">Navy (light)</option>
        <option value="linen">Linen (crisp pale + navy)</option>
        <option value="rose-paper">Rose paper (wine accent)</option>
        <option value="sage">Sage (pale green + moss)</option>
      </optgroup>
      <optgroup label="Dark themes">
        <option value="midnight">Midnight (dark navy)</option>
        <option value="obsidian">Obsidian (near-black + gold)</option>
        <option value="espresso">Espresso (dark brown)</option>
        <option value="plum">Plum (dark purple)</option>
        <option value="dusk-navy">Dusk Navy (cool slate)</option>
        <option value="charcoal">Charcoal (warm gray + rust)</option>
        <option value="moss">Moss (dark green + gold)</option>
        <option value="wine">Wine (deep aubergine)</option>
        <option value="cobalt-noir">Cobalt Noir (ink + electric blue)</option>
        <option value="dark-frantzen">Dark · Frantzen (blue)</option>
        <option value="dark-white">Dark + white (stark)</option>
      </optgroup>
    </select>

    <div class="mode-toggle" role="group" aria-label="Edit light or dark palette">
      <button type="button" class="mode-toggle__btn is-active" data-mode-btn="light" aria-pressed="true">☀ Light</button>
      <button type="button" class="mode-toggle__btn" data-mode-btn="dark" aria-pressed="false">☾ Dark</button>
    </div>

    <label class="top-toggle-label">
      <input type="checkbox" data-modified-only />
      Modified only
    </label>

    <span class="editor-top__spacer"></span>

    <span class="pending-badge" data-pending-badge hidden>0 unsaved</span>
    <button class="btn btn-top btn-top--ghost btn-top--discard" type="button"
            data-discard disabled title="Discard all unsaved changes">Discard</button>
    <button class="btn btn-top btn-top--save" type="button"
            data-save disabled title="Save changes to localStorage &amp; broadcast (⌘S)">
      Save<span class="kbd">⌘S</span>
    </button>
    <button class="btn btn-top btn-top--ghost" type="button" data-undo
            title="Undo (⌘Z)" disabled>↶ Undo</button>
    <button class="btn btn-top btn-top--ghost" type="button" data-reset>Reset all</button>
    <button class="btn btn-top" type="button" data-export>Export CSS</button>
  </div>
</header>

<main class="layout">
  <!-- ── Token list (left pane) ─────────────────────────────── -->
  <section class="side" aria-label="Colour token editors">
    <h2>Tokens</h2>
    <p class="side__intro">
      Edits preview live but aren't saved until you click <strong>Save</strong>
      (<span class="kbd">⌘S</span> / <span class="kbd">Ctrl+S</span>).
      <span class="kbd">▣</span> picks a colour · <span class="kbd">👁</span>
      highlights where it's used.
    </p>

    {groups.map((g) => (
      <div class="group" data-group>
        <div class="group__head" data-group-toggle>
          <span class="group__toggle" aria-hidden="true">▾</span>
          <div class="group__head-text">
            <h3 class="group__title">{g.group}</h3>
            <p class="group__intro" set:html={g.intro} />
          </div>
        </div>
        <div class="group__body">
          {g.tokens.map((t) => (
            <div class="row"
                 data-row
                 data-token={t.token}
                 data-short={t.shortName}
                 data-default={t.def}
                 data-default-dark={darkDefaults[t.token] || t.def}
                 data-search-key={(t.label + ' ' + t.token + ' ' + (t.hint || '')).toLowerCase()}>
              <div class="row__swatch-area">
                <span class="row__dot" data-modified-dot title="Modified from default"></span>
                <input type="color" value={t.def} data-picker aria-label={`${t.label} colour picker`} />
              </div>

              <div class="row__meta">
                <div class="row__name">
                  {t.label}
                  <span class="row__contrast" data-contrast aria-label="Contrast ratio"></span>
                </div>
                {t.hint && <div class="row__hint">{t.hint}</div>}
                <div class="row__token-name"><code>{t.token}</code></div>
              </div>

              <div class="row__controls">
                <input type="text" class="row__hex" data-hex value={t.def}
                       maxlength="7" inputmode="text" autocomplete="off"
                       spellcheck="false" aria-label={`${t.label} hex value`} />
                <button class="row__btn row__btn--show" type="button" data-show
                        title="Highlight affected preview elements (no value change)"
                        aria-label="Highlight preview">👁</button>
                <button class="row__btn" type="button" data-palette-btn
                        title="Pick from current palette" aria-label="Pick from palette">▣</button>
                <button class="row__btn" type="button" data-copy title="Copy hex">⧉</button>
                <button class="row__btn" type="button" data-reset-one title="Reset to default">↺</button>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </section>

  <!-- ── Preview pane (right pane) ──────────────────────────── -->
  <aside class="preview-pane" aria-label="Live site preview">
    <h2>Preview — EN site</h2>
    <p class="preview-pane__intro">
      Every block mirrors a real moment on the public English site.
      Editing a token pulses the fragments that use it.
    </p>

    <div class="sim" role="img" aria-label="Site colour preview">

      <!-- SCROLL PROGRESS BAR -->
      <div class="sim__progress preview-fragment" data-uses="accent,gold"
           title="Scroll progress bar — uses --accent and --gold"></div>

      <!-- NON-PHOTO HEADER (header on /menu/, /contact/, /location/) -->
      <div class="sim__nav preview-fragment" data-uses="paper,rule-soft">
        <span class="sim__nav-brand preview-fragment" data-uses="ink">ZAHARA</span>
        <div class="sim__nav-links">
          <span class="preview-fragment" data-uses="ink-soft">HOME</span>
          <span class="preview-fragment" data-uses="ink-soft">LOCATION</span>
          <span class="preview-fragment" data-uses="ink,accent">MENU</span>
        </div>
        <span class="sim__nav-reserve preview-fragment" data-uses="ink">Reserve</span>
      </div>

      <!-- PAGE surface -->
      <div class="sim__page preview-fragment" data-uses="paper">

        <!-- HERO with floating photo header -->
        <div class="sim__hero">
          <div class="sim__hero-bar">
            <span class="sim__hero-brand preview-fragment" data-uses="paper-on-photo">ZAHARA</span>
            <span class="sim__hero-navs preview-fragment" data-uses="paper-on-photo">HOME · LOCATION · MENU · CONTACT</span>
            <span class="sim__hero-reserve preview-fragment" data-uses="paper-on-photo">Reserve</span>
          </div>
          <div class="sim__hero-body">
            <p class="sim__hero-eyebrow preview-fragment" data-uses="paper-on-photo,accent">
              CHEF RESTAURANT · JERUSALEM
            </p>
            <h3 class="sim__hero-title preview-fragment" data-uses="paper-on-photo">
              A new kitchen, on Ben Sira.
            </h3>
            <div class="sim__hero-btns">
              <span class="sim__hero-btn preview-fragment" data-uses="ink,paper">Reserve a table</span>
              <span class="sim__hero-btn ghost preview-fragment" data-uses="paper-on-photo">See the menu</span>
            </div>
          </div>
        </div>

        <!-- INFO STRIP -->
        <div class="sim__info-strip preview-fragment" data-uses="paper-deep,rule-soft">
          <div class="sim__info-cell">
            <span class="preview-fragment" data-uses="ink-muted">HOURS</span>
            <strong class="preview-fragment" data-uses="ink">Mon–Thu · 18:00–23:00</strong>
          </div>
          <div class="sim__info-cell">
            <span class="preview-fragment" data-uses="ink-muted">RESERVE</span>
            <strong class="preview-fragment" data-uses="ink">077-303-4180</strong>
          </div>
        </div>

        <!-- ISSUE STAMP -->
        <div class="sim__issue preview-fragment" data-uses="paper-deep,ink-muted,rule-soft">
          <span>VOLUME I · JERUSALEM · 2026</span>
          <span class="sim__issue-rule preview-fragment" data-uses="accent"></span>
          <span class="serif preview-fragment" data-uses="ink-soft">From the kitchen of Roi Achdut</span>
        </div>

        <!-- EDITORIAL SECTION -->
        <div class="sim__article">
          <p class="sim__eyebrow preview-fragment" data-uses="ink-muted,accent">THE STORY</p>
          <h3 class="sim__title preview-fragment" data-uses="ink">A new chapter, one kitchen.</h3>
          <p class="sim__body preview-fragment" data-uses="ink-soft">
            Roi cooks what arrived from the market that morning — sea bass,
            blistered tomatoes, a leaf salad. The menu shifts weekly.
            Wine list short, considered.
          </p>
          <div class="sim__btn-row">
            <button class="sim__btn preview-fragment" type="button" data-uses="ink,paper">Reserve</button>
            <button class="sim__btn ghost preview-fragment" type="button" data-uses="ink">Menu</button>
          </div>
        </div>

        <!-- MENU TABS (shows --ink as active-tab background) -->
        <div class="sim__tabs preview-fragment" data-uses="paper,rule-soft">
          <span class="sim__tab is-active preview-fragment" data-uses="ink,paper-on-photo">Food</span>
          <span class="sim__tab preview-fragment" data-uses="ink-muted">Cocktails</span>
          <span class="sim__tab preview-fragment" data-uses="ink-muted">Wine</span>
          <span class="sim__tab preview-fragment" data-uses="ink-muted">Desserts</span>
          <span class="sim__tabs-indicator preview-fragment" data-uses="accent"></span>
        </div>

        <!-- STRONG RULE -->
        <div class="sim__rule preview-fragment" data-uses="rule"></div>

        <!-- MENU SECTION CARD — how the /menu/ page renders each section:
             a paper-card gradient with a serif heading + accent underline,
             ink item names, ink-soft descriptions, accent prices and a soft
             gold corner ornament. -->
        <div class="sim__menucard preview-fragment" data-uses="paper-card,paper,rule-soft,gold,accent">
          <h4 class="sim__menucard-title preview-fragment" data-uses="ink,accent">Something to start</h4>
          <div class="sim__menucard-row preview-fragment" data-uses="rule-soft">
            <div class="sim__menucard-main">
              <strong class="preview-fragment" data-uses="ink">Bread service</strong>
              <span class="sim__menucard-desc preview-fragment" data-uses="ink-soft">sourdough, cultured butter, olive oil</span>
            </div>
            <span class="preview-fragment" data-uses="accent">32</span>
          </div>
          <div class="sim__menucard-row preview-fragment" data-uses="rule-soft">
            <div class="sim__menucard-main">
              <strong class="preview-fragment" data-uses="ink">Beef tartare</strong>
              <span class="sim__menucard-desc preview-fragment" data-uses="ink-soft">smoked egg yolk, capers, toast</span>
            </div>
            <span class="preview-fragment" data-uses="accent">78</span>
          </div>
          <div class="sim__menucard-row preview-fragment" data-uses="rule-soft">
            <div class="sim__menucard-main">
              <strong class="preview-fragment" data-uses="ink">Sea-bass sashimi</strong>
            </div>
            <span class="preview-fragment" data-uses="accent">78</span>
          </div>
        </div>

        <!-- SOFT RULE -->
        <div class="sim__rule sim__rule--soft preview-fragment" data-uses="rule-soft"></div>

        <!-- PULL QUOTE (accent-soft bg, gold italic) -->
        <blockquote class="sim__quote preview-fragment" data-uses="accent-soft">
          <span class="preview-fragment" data-uses="ink">"We don't cook plates. We cook the </span>
          <em class="preview-fragment" data-uses="gold">evening</em>
          <span class="preview-fragment" data-uses="ink"> for people."</span>
        </blockquote>

        {/* HOME CINEMATIC STRIP — the four full-bleed menu chapters on
            the home page. Every visible piece of text binds to its own
            --cinema-* token so editing one of the cinema rows in the
            list above pulses the matching fragment here. The strip is
            independent from the rest of the page palette by design. */}
        <div class="sim__cinema">
          <p class="sim__cinema-eyebrow preview-fragment" data-uses="cinema-eyebrow,cinema-num">
            <span class="sim__cinema-num preview-fragment" data-uses="cinema-num">01</span>
            <span class="sim__cinema-sep preview-fragment" data-uses="cinema-num">·</span>
            <span class="preview-fragment" data-uses="cinema-eyebrow">TO BEGIN</span>
          </p>
          <h4 class="sim__cinema-title preview-fragment" data-uses="cinema-title">
            Something to start
          </h4>

          <div class="sim__cinema-item preview-fragment" data-uses="cinema-divider">
            <div class="sim__cinema-item-main">
              <span class="sim__cinema-item-name preview-fragment" data-uses="cinema-item-name">Bread service</span>
              <span class="sim__cinema-item-desc preview-fragment" data-uses="cinema-item-desc">sourdough, cultured butter, olive oil</span>
            </div>
            <span class="sim__cinema-item-price preview-fragment" data-uses="cinema-item-price">32</span>
          </div>
          <div class="sim__cinema-item preview-fragment" data-uses="cinema-divider">
            <div class="sim__cinema-item-main">
              <span class="sim__cinema-item-name preview-fragment" data-uses="cinema-item-name">Beef tartare</span>
              <span class="sim__cinema-item-desc preview-fragment" data-uses="cinema-item-desc">smoked egg yolk, capers, toast</span>
            </div>
            <span class="sim__cinema-item-price preview-fragment" data-uses="cinema-item-price">78</span>
          </div>
          <div class="sim__cinema-item preview-fragment" data-uses="cinema-divider">
            <div class="sim__cinema-item-main">
              <span class="sim__cinema-item-name preview-fragment" data-uses="cinema-item-name">Sea-bass sashimi</span>
            </div>
            <span class="sim__cinema-item-price preview-fragment" data-uses="cinema-item-price">78</span>
          </div>

          <div class="sim__cinema-foot preview-fragment" data-uses="cinema-divider">
            <span class="sim__cinema-count preview-fragment" data-uses="cinema-count">01 / 04 CHAPTERS</span>
            <span class="sim__cinema-cta preview-fragment" data-uses="cinema-cta">SEE THE FULL MENU ↗</span>
          </div>
        </div>

        <!-- TOC -->
        <div class="sim__toc">
          <p class="sim__eyebrow preview-fragment" data-uses="ink-muted,accent">ON THE MENU TONIGHT</p>
          <div class="sim__toc-row">
            <span class="preview-fragment" data-uses="accent">01</span>
            <span class="preview-fragment" data-uses="ink">Something to start</span>
            <span class="sim__toc-dots preview-fragment" data-uses="ink-faint"></span>
            <span class="preview-fragment" data-uses="ink-soft">Openings from the kitchen</span>
          </div>
          <div class="sim__toc-row">
            <span class="preview-fragment" data-uses="accent">02</span>
            <span class="preview-fragment" data-uses="ink">Almost there</span>
            <span class="sim__toc-dots preview-fragment" data-uses="ink-faint"></span>
            <span class="preview-fragment" data-uses="ink-soft">Fish and meat from the market</span>
          </div>
        </div>

        <!-- CATEGORY CHIPS -->
        <div style="padding:0.35rem 0">
          <p class="sim__eyebrow preview-fragment" data-uses="ink-muted,accent" style="padding:0 0.9rem;margin-bottom:0.5rem">SECTION ACCENTS</p>
          <div class="sim__chips preview-fragment" data-uses="paper">
            <span class="sim__chip sim__chip--green preview-fragment" data-uses="c-green">Food</span>
            <span class="sim__chip sim__chip--teal  preview-fragment" data-uses="c-teal">Cocktails</span>
            <span class="sim__chip sim__chip--slate preview-fragment" data-uses="c-slate">Wine</span>
            <span class="sim__chip sim__chip--mauve preview-fragment" data-uses="c-mauve">Desserts</span>
            <span class="sim__chip sim__chip--gold  preview-fragment" data-uses="gold">Highlight</span>
          </div>
        </div>

        <!-- CONTACT TOGGLE -->
        <div class="sim__toggle preview-fragment" data-uses="paper-card,rule">
          <span class="sim__toggle-btn is-active preview-fragment" data-uses="ink">General inquiry</span>
          <span class="sim__toggle-btn preview-fragment" data-uses="ink-muted">Event inquiry</span>
          <span class="sim__toggle-ind preview-fragment" data-uses="accent"></span>
        </div>

        <!-- REACH-US CARD -->
        <div class="sim__reach preview-fragment" data-uses="paper-card,rule-soft" style="margin-top:0.5rem">
          <p class="sim__eyebrow preview-fragment" data-uses="ink-muted,accent">OTHER WAYS TO REACH US</p>
          <div class="sim__reach-row">
            <span class="preview-fragment" data-uses="ink-muted">PHONE</span>
            <a class="sim__reach-link preview-fragment" data-uses="ink,accent,accent-deep">077-303-4180</a>
          </div>
          <div class="sim__reach-row">
            <span class="preview-fragment" data-uses="ink-muted">EMAIL</span>
            <a class="sim__reach-link preview-fragment" data-uses="ink,accent,accent-deep">hello@zahara.rest</a>
          </div>
        </div>

        <!-- SELECTION + FOCUS RING demos -->
        <div class="sim__selection preview-fragment" data-uses="ink">
          Normal text and
          <mark class="sim__sel-mark preview-fragment" data-uses="accent-soft,ink">selected text highlight</mark>
          back to normal.
        </div>
        <div class="sim__focus-demo">
          <span class="preview-fragment" style="font-size:0.62rem;letter-spacing:0.1em;text-transform:uppercase;font-family:'Inter',sans-serif;color:var(--ink-muted,#8A7E68);">Focus ring →</span>
          <span class="sim__focus-ring preview-fragment" data-uses="accent,rule,ink">focused element</span>
        </div>

        <!-- SCROLLBAR demo -->
        <div class="sim__scrollbar">
          <div class="sim__sb-track preview-fragment" data-uses="paper-deep,rule-soft">
            <div class="sim__sb-thumb preview-fragment" data-uses="accent,accent-deep"></div>
          </div>
          <span class="sim__sb-label preview-fragment" data-uses="ink-muted">Scrollbar</span>
        </div>

        <!-- FAINT METADATA -->
        <p class="sim__faint preview-fragment" data-uses="ink-faint">
          Last updated · 12 March 2026 · Zahara Restaurant
        </p>

        {/* FLOATING UI — same three viewport-pinned widgets the live
            site shows in its bottom corners and inline-end edge. The
            preview lays them out inline (not pinned) so they sit next
            to the rest of the simulated sections; tokens consumed are
            exactly the ones the real elements use. */}
        <div class="sim__floating">
          {/* Vertical scroll rail (E) — one tick per page section.
              Active tick fills with --accent and the label fades in. */}
          <div class="sim__rail" aria-label="Scroll rail preview">
            <span class="sim__rail-tick preview-fragment" data-uses="ink-muted">
              <span class="sim__rail-mark preview-fragment" data-uses="ink-muted"></span>
              <span class="sim__rail-label preview-fragment" data-uses="ink-muted">OPEN</span>
            </span>
            <span class="sim__rail-tick is-active preview-fragment" data-uses="ink,accent">
              <span class="sim__rail-mark preview-fragment" data-uses="accent"></span>
              <span class="sim__rail-label preview-fragment" data-uses="ink">STORY</span>
            </span>
            <span class="sim__rail-tick preview-fragment" data-uses="ink-muted">
              <span class="sim__rail-mark preview-fragment" data-uses="ink-muted"></span>
              <span class="sim__rail-label preview-fragment" data-uses="ink-muted">KITCHEN</span>
            </span>
            <span class="sim__rail-tick preview-fragment" data-uses="ink-muted">
              <span class="sim__rail-mark preview-fragment" data-uses="ink-muted"></span>
              <span class="sim__rail-label preview-fragment" data-uses="ink-muted">MENU</span>
            </span>
            <span class="sim__rail-tick preview-fragment" data-uses="ink-muted">
              <span class="sim__rail-mark preview-fragment" data-uses="ink-muted"></span>
              <span class="sim__rail-label preview-fragment" data-uses="ink-muted">GALLERY</span>
            </span>
          </div>

          {/* Bottom-corner buttons — accessibility (inline-start) and
              scroll-to-top (inline-end). Both share the same
              ink-on-paper-on-photo treatment. */}
          <div class="sim__corner-row">
            <div class="sim__corner-cell">
              <span class="sim__corner-btn preview-fragment" data-uses="ink,paper">♿</span>
              <span class="sim__corner-caption preview-fragment" data-uses="ink-muted">A11Y TOGGLE</span>
            </div>
            <div class="sim__corner-cell">
              <span class="sim__corner-btn preview-fragment" data-uses="ink,paper">↑</span>
              <span class="sim__corner-caption preview-fragment" data-uses="ink-muted">SCROLL-TO-TOP</span>
            </div>
          </div>
        </div>

        <!-- FORM STATUS -->
        <div class="sim__status-row">
          <div class="sim__status sim__status--ok preview-fragment" data-uses="ok">
            ✓ Thanks — we'll be in touch within one business day.
          </div>
          <div class="sim__status sim__status--err preview-fragment" data-uses="err">
            ✗ Network error. Please try again.
          </div>
        </div>

        <!-- FOOTER -->
        <div class="sim__footer preview-fragment" data-uses="paper-deep,rule-soft">
          <div class="sim__footer-grid">
            <div class="sim__footer-block">
              <span class="sim__footer-label preview-fragment" data-uses="ink-muted">HOURS</span>
              <span class="sim__footer-val preview-fragment" data-uses="ink">Mon–Thu 18:00–23:00</span>
            </div>
            <div class="sim__footer-block">
              <span class="sim__footer-label preview-fragment" data-uses="ink-muted">ADDRESS</span>
              <span class="sim__footer-val preview-fragment" data-uses="ink">Ben Sira 6, Jerusalem</span>
            </div>
            <div class="sim__footer-block">
              <span class="sim__footer-label preview-fragment" data-uses="ink-muted">PHONE</span>
