      '--paper-card': '#181B22', '--paper-on-photo': '#ECEEF2',
      '--ink': '#F0F2F6', '--ink-soft': '#C4C8D2', '--ink-muted': '#7A8090', '--ink-faint': '#4A4E58',
      '--rule': '#2A2E36', '--rule-soft': '#1E2128',
      '--accent': '#5878E8', '--accent-deep': '#3854D0', '--accent-soft': '#1A2440',
      '--gold': '#8AA4FF',
      '--c-green': '#5A786A', '--c-teal': '#3E6D77', '--c-slate': '#3E5359', '--c-mauve': '#9D8499',
      '--ok': '#4DB378', '--err': '#E54F4F', '--shadow': '#04060A',
      '--cinema-eyebrow': '#C8CCD8', '--cinema-num': '#88A4FF', '--cinema-title': '#ECEEF2',
      '--cinema-item-name': '#ECEEF2', '--cinema-item-desc': '#A8ACBA', '--cinema-item-price': '#88A4FF',
      '--cinema-divider': '#2A2E36', '--cinema-count': '#80869A', '--cinema-cta': '#ECEEF2',
    },

    'dark-white': {
      '--paper': '#0A0A0A', '--paper-deep': '#121214', '--paper-edge': '#26262A',
      '--paper-card': '#17171A', '--paper-on-photo': '#F5F5F5',
      '--ink': '#FFFFFF', '--ink-soft': '#D8D8D8', '--ink-muted': '#8C8C8C', '--ink-faint': '#454548',
      '--rule': '#2A2A2D', '--rule-soft': '#1A1A1D',
      '--accent': '#FFFFFF', '--accent-deep': '#C8C8C8', '--accent-soft': '#2A2A2D',
      '--gold': '#BCBCBC',
      '--c-green': '#7B9685', '--c-teal': '#558693', '--c-slate': '#5B6B71', '--c-mauve': '#A697A1',
      '--ok': '#5BC287', '--err': '#EF5A5A', '--shadow': '#000000',
      '--cinema-eyebrow': '#D0D0D0', '--cinema-num': '#FFFFFF', '--cinema-title': '#FFFFFF',
      '--cinema-item-name': '#FFFFFF', '--cinema-item-desc': '#B0B0B0', '--cinema-item-price': '#FFFFFF',
      '--cinema-divider': '#2A2A2D', '--cinema-count': '#8C8C8C', '--cinema-cta': '#FFFFFF',
    },
  };

  // ────────────────────────────────────────────────────────────────────────────
  // STATE & STORAGE
  //
  // Source of truth is the server (KV via /api/palette). localStorage is a
  // FAST CACHE so the editor doesn't blank-flash while the network round-trip
  // happens — we hydrate from cache instantly, then reconcile against the
  // server response a moment later.
  // ────────────────────────────────────────────────────────────────────────────
  const KEY        = 'zahara-color-overrides';
  const SERVER_GET = '/api/palette';
  const SERVER_PUT = '/admin/colors/save';
  const root       = document.documentElement;
  const rows       = Array.from(document.querySelectorAll('[data-row]'));

  // Which palette we're editing: 'light' or 'dark'. The preview pane reflects
  // this mode; Save persists BOTH. State shape everywhere is a pair:
  //   { light: { '--token': '#hex', … }, dark: { … } }
  let activeMode = 'light';

  let bc = null;
  try { bc = new BroadcastChannel('zahara-colors'); } catch (_) {}

  // ── Pair helpers ────────────────────────────────────────────────────────────
  function emptyPair() { return { light: {}, dark: {} }; }
  function clonePair(p) { return { light: Object.assign({}, p.light), dark: Object.assign({}, p.dark) }; }

  // Normalise any stored / fetched value into the pair shape, migrating an
  // old flat { '--token':'#hex' } record (light only).
  function toPair(raw) {
    const pair = emptyPair();
    if (!raw || typeof raw !== 'object') return pair;
    const looksFlat = Object.keys(raw).some((k) => k.indexOf('--') === 0);
    const src = looksFlat ? { light: raw } : raw;
    ['light', 'dark'].forEach((mode) => {
      const m = src[mode];
      if (m && typeof m === 'object') {
        for (const t in m) {
          if (t.indexOf('--') === 0 && typeof m[t] === 'string') pair[mode][t] = String(m[t]).toUpperCase();
        }
      }
    });
    return pair;
  }

  function defaultFor(mode, token) {
    return ((mode === 'dark' ? darkDefaults[token] : defaults[token]) || defaults[token] || '').toUpperCase();
  }
  function rowDefault(row) {
    return (activeMode === 'dark' ? row.dataset.defaultDark : row.dataset.default).toUpperCase();
  }
  function curMap() { return currentState[activeMode]; }
  function resolved(mode, token) {
    return (currentState[mode][token] || defaultFor(mode, token)).toUpperCase();
  }

  function loadCache() {
    try { return toPair(JSON.parse(localStorage.getItem(KEY) || '{}')); } catch { return emptyPair(); }
  }
  function writeCache(o) {
    try { localStorage.setItem(KEY, JSON.stringify(o)); } catch (_) {}
  }

  // savedState: last value confirmed against the SERVER.
  // currentState: live state including unsaved edits.
  // Start optimistically from the cache; reconcile with the server below.
  let savedState   = loadCache();
  let currentState = clonePair(savedState);
  let serverSyncedAt = 0;  // becomes >0 once /api/palette has returned

  // ────────────────────────────────────────────────────────────────────────────
  // UI REFS
  // ────────────────────────────────────────────────────────────────────────────
  const toastEl      = document.querySelector('[data-toast]');
  const undoBtn      = document.querySelector('[data-undo]');
  const saveBtn      = document.querySelector('[data-save]');
  const discardBtn   = document.querySelector('[data-discard]');
  const pendingBadge = document.querySelector('[data-pending-badge]');

  // ── Render the active mode onto :root + the rows ──────────────────────────────
  // We ALWAYS set an explicit value for every token (never removeProperty):
  // the admin page carries no data-theme attribute, so relying on the cascade
  // would fall back to the LIGHT default even while editing dark.
  function renderMode() {
    rows.forEach((row) => {
      const val = resolved(activeMode, row.dataset.token);
      root.style.setProperty(row.dataset.token, val);
      _syncRowUI(row, val, { skipHistory: true });
    });
    _refreshAllContrast();
    _updatePendingUI();
  }

  // ────────────────────────────────────────────────────────────────────────────
  // INIT — render cached state immediately (zero flash), then reconcile
  // against the canonical server state.
  // ────────────────────────────────────────────────────────────────────────────
  renderMode();

  // Fire-and-forget reconciliation. We deliberately don't `await` this at
  // the top level — the editor renders from cache immediately, and the
  // server response slides values into place a moment later.
  (async function reconcileWithServer() {
    let serverPair;
    try {
      const res = await fetch(SERVER_GET, { cache: 'no-store', credentials: 'same-origin' });
      if (!res.ok) throw new Error('HTTP ' + res.status);
      serverPair = toPair(await res.json());
    } catch (err) {
      console.warn('[colors] /api/palette failed — staying on cached state', err);
      return;
    }
    serverSyncedAt = Date.now();

    // Server is canonical for savedState. Pending edits stay pending.
    savedState = serverPair;
    writeCache(savedState);

    // If the user hasn't started editing yet, bring currentState in line with
    // the server so the picker UI matches what's actually saved.
    if (history.length === 0) {
      currentState = clonePair(savedState);
      renderMode();
    } else {
      _refreshAllDots();
      _updatePendingUI();
    }
  })();

  // ────────────────────────────────────────────────────────────────────────────
  // UNDO HISTORY
  // ────────────────────────────────────────────────────────────────────────────
  const history = [];

  function _pushHistory(token, from, to) {
    history.push({ mode: activeMode, token, from, to });
    if (history.length > 50) history.shift();
    undoBtn.disabled = false;
  }

  function undo() {
    const last = history.pop();
    if (!last) { undoBtn.disabled = true; return; }
    if (last.mode !== activeMode) setMode(last.mode);
    applyToken(last.token, last.from, { silent: true });
    if (history.length === 0) undoBtn.disabled = true;
  }

  undoBtn.addEventListener('click', undo);

  // ────────────────────────────────────────────────────────────────────────────
  // PENDING TRACKING
  // ────────────────────────────────────────────────────────────────────────────
  function isPendingIn(mode, token) {
    const cur = (currentState[mode][token] || defaultFor(mode, token)).toUpperCase();
    const sav = (savedState[mode][token]   || defaultFor(mode, token)).toUpperCase();
    return cur !== sav;
  }
  function _isPending(token) { return isPendingIn(activeMode, token); }

  // Counts rows that differ from saved in EITHER mode, so the Save button
  // and "N unsaved" badge reflect edits made across both palettes.
  function _countPending() {
    return rows.filter((r) =>
      isPendingIn('light', r.dataset.token) || isPendingIn('dark', r.dataset.token)
    ).length;
  }

  function _updatePendingUI() {
    const n = _countPending();
    if (n > 0) {
      pendingBadge.textContent = n + ' unsaved';
      pendingBadge.hidden = false;
    } else {
      pendingBadge.hidden = true;
    }
    saveBtn.disabled    = n === 0;
    discardBtn.disabled = n === 0;
  }

  // ────────────────────────────────────────────────────────────────────────────
  // SAVE — POST currentState to the server. Server is canonical; only on a
  // 2xx do we update savedState (so a network failure leaves the editor
  // still showing "N unsaved" and the user can retry).
  // ────────────────────────────────────────────────────────────────────────────
  let saving = false;

  async function save() {
    if (saving) return;
    if (_countPending() === 0) return;
    saving = true;
    const label = saveBtn.textContent;
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving…';

    try {
      const res = await fetch(SERVER_PUT, {
        method:      'POST',
        headers:     { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body:        JSON.stringify(currentState),
      });
      if (!res.ok) {
        let msg = 'HTTP ' + res.status;
        try { msg = (await res.json()).error || msg; } catch (_) {}
        throw new Error(msg);
      }
      savedState = clonePair(currentState);
      writeCache(savedState);
      if (bc) bc.postMessage({ type: 'colors-changed', overrides: savedState });
      showToast('Saved to server ✓');
    } catch (err) {
      console.error('[colors] save failed', err);
      showToast('Save failed: ' + err.message);
    } finally {
      saving = false;
      saveBtn.textContent = label;
      _updatePendingUI();
      _refreshAllDots();
    }
  }

  saveBtn.addEventListener('click', save);

  // ────────────────────────────────────────────────────────────────────────────
  // DISCARD
  // ────────────────────────────────────────────────────────────────────────────
  function discard() {
    // Revert both palettes to the last saved state and repaint the active mode.
    currentState = clonePair(savedState);
    renderMode();
    history.length = 0;
    undoBtn.disabled = true;
    showToast('Changes discarded');
  }

  discardBtn.addEventListener('click', () => {
    if (_countPending() === 0 || !confirm('Discard all unsaved changes?')) return;
    discard();
  });

  // ────────────────────────────────────────────────────────────────────────────
  // APPLY TOKEN — applies to :root immediately (preview updates), tracks
  // the change as "pending" but does NOT write to localStorage.
  // ────────────────────────────────────────────────────────────────────────────
  function applyToken(token, value, opts) {
    opts = opts || {};
    const row = rows.find((r) => r.dataset.token === token);
    if (!row) return;
    const normalised = _normaliseHex(value);
    if (!normalised) return;

    const modeDefault = rowDefault(row);
    const prev = (curMap()[token] || modeDefault).toUpperCase();
    if (!opts.silent && prev !== normalised) {
      _pushHistory(token, prev, normalised);
    }

    // Track override-vs-default in state, but ALWAYS paint :root explicitly
    // (the admin page has no data-theme, so removeProperty would fall back to
    // the light default even in dark mode).
    if (normalised === modeDefault) delete curMap()[token];
    else                            curMap()[token] = normalised;
    root.style.setProperty(token, normalised);

    _syncRowUI(row, normalised, opts);
    _refreshAllContrast();
    if (!opts.silent) _highlight(token);
    _updatePendingUI();
  }

  // ────────────────────────────────────────────────────────────────────────────
  // SYNC ROW UI (picker + hex + dots)
  // ────────────────────────────────────────────────────────────────────────────
  function _syncRowUI(row, value, opts) {
    opts = opts || {};
    const picker = row.querySelector('[data-picker]');
    const hexEl  = row.querySelector('[data-hex]');
    const dot    = row.querySelector('[data-modified-dot]');

    if (picker.value.toUpperCase() !== value) picker.value = value;
    if (!opts.skipHexSync && document.activeElement !== hexEl) {
      hexEl.value = value;
    }
    hexEl.classList.remove('is-invalid');

    // Dot: orange = modified from the active mode's default; blue = unsaved.
    const isModified = value !== rowDefault(row);
    const isPend     = _isPending(row.dataset.token);
    dot.classList.toggle('is-modified', isModified && !isPend);
    dot.classList.toggle('is-pending',  isPend);
    dot.title = isPend ? 'Unsaved change' : (isModified ? 'Modified from default' : '');
  }

  function _refreshAllDots() {
    rows.forEach((row) => {
      const val = resolved(activeMode, row.dataset.token);
      _syncRowUI(row, val, { skipHexSync: true, skipHistory: true });
    });
  }

  // ────────────────────────────────────────────────────────────────────────────
  // WIRE EACH ROW
  // ────────────────────────────────────────────────────────────────────────────
  rows.forEach((row) => {
    const token    = row.dataset.token;
    const picker   = row.querySelector('[data-picker]');
    const hexEl    = row.querySelector('[data-hex]');
    const showBtn  = row.querySelector('[data-show]');
    const copyBtn  = row.querySelector('[data-copy]');
    const resetBtn = row.querySelector('[data-reset-one]');

    picker.addEventListener('input', () => {
      applyToken(token, picker.value);
    });

    let hexTimer = null;
    hexEl.addEventListener('input', () => {
      const v = _normaliseHex(hexEl.value);
      if (!v) { hexEl.classList.add('is-invalid'); return; }
      hexEl.classList.remove('is-invalid');
      clearTimeout(hexTimer);
      hexTimer = setTimeout(() => applyToken(token, v), 160);
    });
    hexEl.addEventListener('blur', () => {
      const v = _normaliseHex(hexEl.value);
      if (v) hexEl.value = v;
      else   hexEl.value = resolved(activeMode, token);
      hexEl.classList.remove('is-invalid');
    });
    hexEl.addEventListener('focus', () => hexEl.select());

    showBtn.addEventListener('click', () => {
      _highlight(token);
      showBtn.classList.remove('is-pulsing');
      requestAnimationFrame(() => showBtn.classList.add('is-pulsing'));
      setTimeout(() => showBtn.classList.remove('is-pulsing'), 1300);
    });

    copyBtn.addEventListener('click', async () => {
      const val = resolved(activeMode, token);
      try { await navigator.clipboard.writeText(val); } catch (_) {}
      showToast('Copied ' + val);
    });

    resetBtn.addEventListener('click', () => {
      applyToken(token, rowDefault(row));
    });
  });

  // ────────────────────────────────────────────────────────────────────────────
  // MODE TOGGLE (light / dark)
  // ────────────────────────────────────────────────────────────────────────────
  function setMode(mode) {
    if (mode !== 'light' && mode !== 'dark') return;
    activeMode = mode;
    document.querySelectorAll('[data-mode-btn]').forEach((b) => {
      const on = b.dataset.modeBtn === mode;
      b.classList.toggle('is-active', on);
      b.setAttribute('aria-pressed', on ? 'true' : 'false');
    });
    renderMode();   // repaint :root + rows + contrast for the new mode
    _applyFilter(); // "modified only" is mode-sensitive
  }
  document.querySelectorAll('[data-mode-btn]').forEach((b) => {
    b.addEventListener('click', () => setMode(b.dataset.modeBtn));
  });

  // ────────────────────────────────────────────────────────────────────────────
  // RESET ALL — resets the ACTIVE mode's tokens to their defaults.
  // ────────────────────────────────────────────────────────────────────────────
  document.querySelector('[data-reset]').addEventListener('click', () => {
    if (!confirm('Reset every token in ' + activeMode + ' mode to its default? This marks them as unsaved.')) return;
    rows.forEach((r) => { delete curMap()[r.dataset.token]; });
    renderMode();
    history.length = 0;
    undoBtn.disabled = true;
    showToast('Reset ' + activeMode + ' to defaults (not yet saved)');
  });

  // ────────────────────────────────────────────────────────────────────────────
  // PRESET
  // ────────────────────────────────────────────────────────────────────────────
  document.querySelector('[data-preset]').addEventListener('change', function () {
    const name = this.value;
    if (!name || !PRESETS[name]) return;
    const palette = PRESETS[name];
    Object.entries(palette).forEach(([tk, val]) => applyToken(tk, val));
    showToast('Preview: ' + name + ' → ' + activeMode + ' (not saved)');
    this.value = '';
  });

  // ────────────────────────────────────────────────────────────────────────────
  // SEARCH / FILTER
  // ────────────────────────────────────────────────────────────────────────────
  const searchInput      = document.querySelector('[data-search]');
  const modifiedOnlyChk  = document.querySelector('[data-modified-only]');

  function _applyFilter() {
    const q    = searchInput.value.trim().toLowerCase();
    const mOnly = modifiedOnlyChk.checked;
    rows.forEach((r) => {
      const matchQ = !q || r.dataset.searchKey.includes(q);
      const matchM = !mOnly || (curMap()[r.dataset.token] !== undefined &&
                                curMap()[r.dataset.token].toUpperCase() !== rowDefault(r));
      r.classList.toggle('is-hidden', !(matchQ && matchM));
    });
    document.querySelectorAll('[data-group]').forEach((g) => {
      const visible = g.querySelectorAll('[data-row]:not(.is-hidden)').length;
      g.style.display = visible ? '' : 'none';
    });
  }

  searchInput.addEventListener('input', _applyFilter);
  modifiedOnlyChk.addEventListener('change', _applyFilter);

  // ────────────────────────────────────────────────────────────────────────────
  // GROUP COLLAPSE / EXPAND
  // ────────────────────────────────────────────────────────────────────────────
  document.querySelectorAll('[data-group-toggle]').forEach((toggle) => {
    toggle.addEventListener('click', () => {
      toggle.closest('[data-group]').classList.toggle('is-collapsed');
    });
  });

  // ────────────────────────────────────────────────────────────────────────────
  // PALETTE POPUP
  // ────────────────────────────────────────────────────────────────────────────
  const palettePopup = document.querySelector('[data-palette-popup]');
  const paletteGrid  = document.querySelector('[data-palette-grid]');
  let activePaletteRow = null;

  function _openPalettePopup(btn, targetRow) {
    activePaletteRow = targetRow;

    // Populate swatches with all current token values
    paletteGrid.innerHTML = '';
    rows.forEach((r) => {
      const tk  = r.dataset.token;
      const val = resolved(activeMode, tk);
      const label = r.querySelector('.row__name').firstChild.textContent.trim();
      const sw = document.createElement('button');
      sw.className = 'palette-swatch';
      sw.style.background = val;
      sw.title = label + '\n' + val;
      sw.setAttribute('data-swatch-value', val);
      sw.setAttribute('aria-label', label + ': ' + val);
      paletteGrid.appendChild(sw);
    });

    // Position near button
    const rect = btn.getBoundingClientRect();
    const top  = rect.bottom + window.scrollY + 4;
    const left = Math.min(rect.left + window.scrollX, window.innerWidth - 230);
    palettePopup.style.top  = top  + 'px';
    palettePopup.style.left = left + 'px';
    palettePopup.hidden = false;
  }

  rows.forEach((row) => {
    row.querySelector('[data-palette-btn]').addEventListener('click', function (e) {
      if (!palettePopup.hidden && activePaletteRow === row) {
        palettePopup.hidden = true; activePaletteRow = null; return;
      }
      _openPalettePopup(this, row);
      e.stopPropagation();
    });
  });

  paletteGrid.addEventListener('click', (e) => {
    const sw = e.target.closest('.palette-swatch');
    if (!sw || !activePaletteRow) return;
    applyToken(activePaletteRow.dataset.token, sw.dataset.swatchValue);
    palettePopup.hidden = true;
    activePaletteRow = null;
  });

  document.addEventListener('click', (e) => {
    if (!palettePopup.hidden && !palettePopup.contains(e.target)) {
      palettePopup.hidden = true; activePaletteRow = null;
    }
  });

  // ────────────────────────────────────────────────────────────────────────────
  // KEYBOARD SHORTCUTS
  // ────────────────────────────────────────────────────────────────────────────
  document.addEventListener('keydown', (e) => {
    const meta = e.metaKey || e.ctrlKey;
    if (meta && !e.shiftKey && e.key === 's') {
      e.preventDefault();
      if (_countPending() > 0) save();
    }
    if (meta && !e.shiftKey && (e.key === 'z' || e.key === 'Z')) {
      e.preventDefault();
      undo();
    }
    if (e.key === 'Escape') {
      palettePopup.hidden = true;
      activePaletteRow = null;
      if (!exportModal.hidden) exportModal.hidden = true;
    }
  });

  // ────────────────────────────────────────────────────────────────────────────
  // CONTRAST
  // ────────────────────────────────────────────────────────────────────────────
  function _relLum(hex) {
    const m = hex.replace('#','').match(/.{2}/g);
    if (!m) return 0;
    const [r, g, b] = m.map((s) => {
      let c = parseInt(s, 16) / 255;
      return c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
    });
    return 0.2126 * r + 0.7152 * g + 0.0722 * b;
  }
  function _contrastRatio(a, b) {
    const la = _relLum(a), lb = _relLum(b);
    const [lo, hi] = la > lb ? [lb, la] : [la, lb];
    return (hi + 0.05) / (lo + 0.05);
  }

  function _refreshAllContrast() {
    const paper = resolved(activeMode, '--paper');
    rows.forEach((row) => {
      const token = row.dataset.token;
      const isText = /^--(ink|accent|gold|c-|ok|err)/.test(token);
      const badge  = row.querySelector('[data-contrast]');
      if (!isText) { badge.textContent = ''; badge.className = 'row__contrast'; return; }
      const val = resolved(activeMode, token);
      const c   = _contrastRatio(val, paper);
      let band, label;
      if      (c >= 7)   { band = 'aaa'; label = c.toFixed(1) + ':1 AAA'; }
      else if (c >= 4.5) { band = 'aa';  label = c.toFixed(1) + ':1 AA';  }
      else if (c >= 3)   { band = 'aa';  label = c.toFixed(1) + ':1 AA-L';}
      else               { band = 'lo';  label = c.toFixed(1) + ':1 lo';  }
      badge.textContent = label;
      badge.className   = 'row__contrast row__contrast--' + band;
    });
  }

  // ────────────────────────────────────────────────────────────────────────────
  // HIGHLIGHT PREVIEW FRAGMENTS
  // ────────────────────────────────────────────────────────────────────────────
  let highlightTimer = null;

  function _highlight(token) {
    const short = token.replace(/^--/, '');
    document.querySelectorAll('.preview-fragment.is-highlighted')
      .forEach((el) => el.classList.remove('is-highlighted'));
    requestAnimationFrame(() => {
      document.querySelectorAll('.preview-fragment').forEach((el) => {
        const uses = (el.dataset.uses || '').split(',').map((s) => s.trim());
        if (uses.includes(short)) el.classList.add('is-highlighted');
      });
    });
    clearTimeout(highlightTimer);
    highlightTimer = setTimeout(() => {
      document.querySelectorAll('.preview-fragment.is-highlighted')
        .forEach((el) => el.classList.remove('is-highlighted'));
    }, 1600);
  }

  // ────────────────────────────────────────────────────────────────────────────
  // TOAST
  // ────────────────────────────────────────────────────────────────────────────
  let toastTimer = null;
  function showToast(msg) {
    toastEl.textContent = msg;
    toastEl.classList.add('is-visible');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toastEl.classList.remove('is-visible'), 1800);
  }

  // ────────────────────────────────────────────────────────────────────────────
  // EXPORT MODAL
  // ────────────────────────────────────────────────────────────────────────────
  const exportModal    = document.querySelector('[data-export-modal]');
  const exportTextarea = document.querySelector('[data-export-textarea]');
  let exportMode = 'full';

  function _buildCss(which) {
    // Exports the ACTIVE mode, wrapped in the selector it ships under:
    //   light → :root { … }    dark → html[data-theme="dark"] { … }
    const sel = activeMode === 'dark' ? 'html[data-theme="dark"]' : ':root';
    const lines = [];
    rows.forEach((row) => {
      const token = row.dataset.token;
      const value = resolved(activeMode, token);
      if (which === 'changed' && value === rowDefault(row)) return;
      lines.push('  ' + token.padEnd(20) + ': ' + value + ';');
    });
    if (which === 'changed' && lines.length === 0) return '/* No changes from default */';
    return sel + ' {\n' + lines.join('\n') + '\n}';
  }

  document.querySelector('[data-export]').addEventListener('click', () => {
    exportTextarea.value = _buildCss(exportMode);
    exportModal.hidden = false;
    exportTextarea.select();
  });

  document.querySelectorAll('[data-export-tab]').forEach((tab) => {
    tab.addEventListener('click', () => {
      exportMode = tab.dataset.exportTab;
      document.querySelectorAll('[data-export-tab]').forEach((t) =>
        t.classList.toggle('is-active', t === tab));
      exportTextarea.value = _buildCss(exportMode);
    });
  });

  document.querySelector('[data-export-close]').addEventListener('click', () => {
    exportModal.hidden = true;
  });

  document.querySelector('[data-export-copy]').addEventListener('click', async () => {
    try { await navigator.clipboard.writeText(exportTextarea.value); }
    catch (_) { exportTextarea.select(); exportTextarea.setSelectionRange(0, 99999); }
    const btn = document.querySelector('[data-export-copy]');
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = orig; }, 1400);
  });

  exportModal.addEventListener('click', (e) => {
    if (e.target === exportModal) exportModal.hidden = true;
  });

  // ────────────────────────────────────────────────────────────────────────────
  // HELPERS
  // ────────────────────────────────────────────────────────────────────────────
  function _normaliseHex(v) {
    if (!v) return null;
    v = v.trim();
    if (!v.startsWith('#')) v = '#' + v;
    if (v.length === 4) v = '#' + v[1]+v[1] + v[2]+v[2] + v[3]+v[3];
    if (!/^#[0-9a-fA-F]{6}$/.test(v)) return null;
    return v.toUpperCase();
  }

})();
</script>
</body>
</html>