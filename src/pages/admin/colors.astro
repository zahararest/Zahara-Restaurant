  <!-- Export modal -->
  <div class="export-modal" hidden data-export-modal>
    <div class="export-modal__inner">
      <h2>Copy CSS</h2>
      <p>Paste this into the <code>:root</code> block of <code>src/styles/global.css</code> to make the palette permanent.</p>
      <textarea data-export-textarea readonly></textarea>
      <div class="export-modal__row">
        <button class="btn-top btn-top--ghost" type="button" data-export-close>Close</button>
        <button class="btn-top" type="button" data-export-copy>Copy to clipboard</button>
      </div>
