---

<!doctype html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{TITLE}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
  <style>
    :root {
      --c-bg:    #fafaf7;
      --c-fg:    #1a1410;
      --c-mut:   #6f6457;
      --c-rule:  #e2d8c4;
      --c-acc:   #a88947;
      --c-mod:   #d97706;   /* dot colour for "modified" tokens */
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--c-bg);
      color: var(--c-fg);
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 14px;
      line-height: 1.55;
    }
    code { font-family: 'Inter', ui-monospace, monospace; font-size: 0.85em; }

    /* ── Top bar — two stacked rows: admin nav, then tools ──── */
    header.editor-top {
      position: sticky; top: 0; z-index: 10;
      background: rgba(250,250,247,0.96);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--c-rule);
      padding: 0.7rem 1.5rem;
      display: grid;
      gap: 0.55rem;
    }
    .editor-top__nav {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .editor-top__brand {
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--c-fg);
      text-decoration: none;
      padding-inline-end: 0.4rem;
      border-inline-end: 1px solid var(--c-rule);
      margin-inline-end: 0.4rem;
    }
    .editor-top__navlink {
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 600;
      color: var(--c-mut);
      text-decoration: none;
      padding: 0.35rem 0.65rem;
      border: 1px solid transparent;
      transition: color 0.2s, border-color 0.2s, background 0.2s;
    }
    .editor-top__navlink:hover {
      color: var(--c-fg);
      border-color: var(--c-rule);
    }
    .editor-top__navlink.is-active {
      color: var(--c-fg);
      background: #ece3d0;
      border-color: #d8ccae;
      pointer-events: none;
    }
    .editor-top__spacer { flex: 1; }
    .editor-top__site {
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--c-acc);
      font-weight: 600;
      text-decoration: none;
      padding: 0.4rem 0.6rem;
    }
    .editor-top__site:hover { text-decoration: underline; }
    .editor-top__tools {
      display: flex;
      gap: 0.55rem;
      align-items: center;
      flex-wrap: wrap;
    }
    .editor-top h1 {
      margin: 0;
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--c-mut);
    }
    .top-row {
      display: flex;
      gap: 0.55rem;
      align-items: center;
      flex-wrap: wrap;
    }
    .top-search {
      flex: 1;
      max-width: 280px;
      padding: 0.5rem 0.8rem;
      font: inherit;
      font-size: 0.85rem;
      background: #fff;
      color: var(--c-fg);
      border: 1px solid var(--c-rule);
    }
    .top-search:focus { outline: 2px solid var(--c-acc); outline-offset: -2px; }

    .top-select {
      font: inherit;
      font-size: 0.78rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      font-weight: 600;
      padding: 0.5rem 0.85rem;
      background: #fff;
      color: var(--c-fg);
      border: 1px solid var(--c-rule);
      cursor: pointer;
    }
    .btn-top {
      font: inherit;
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 600;
      padding: 0.55rem 0.95rem;
      background: var(--c-fg);
      color: var(--c-bg);
      border: 1px solid var(--c-fg);
      cursor: pointer;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
    }
    .btn-top:hover { background: var(--c-acc); border-color: var(--c-acc); }
    .btn-top:disabled { opacity: 0.45; cursor: not-allowed; }
    .btn-top--ghost {
      background: transparent;
      color: var(--c-fg);
    }
    .btn-top--ghost:hover { color: var(--c-acc); }

    .top-link {
      font-size: 0.78rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--c-acc);
      font-weight: 600;
      text-decoration: none;
      padding: 0.55rem 0.5rem;
    }
    .top-link:hover { text-decoration: underline; }

    /* ── Main layout ────────────────────────────────────────── */
    main.layout {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
      max-width: 1400px;
      margin: 0 auto;
      padding: 1.5rem 1.5rem 6rem;
    }
    @media (min-width: 1000px) {
      main.layout { grid-template-columns: 1fr 1fr; gap: 3rem; }
    }

    /* ── Token list ─────────────────────────────────────────── */
    .side h2 {
      font-size: 0.78rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--c-mut);
      margin: 0 0 0.35rem;
      font-weight: 700;
    }
    .side__intro {
      margin: 0 0 1.5rem;
      color: var(--c-mut);
      font-size: 0.85rem;
    }
    .group { margin-block-end: 2rem; }
    .group__head {
      padding-block-end: 0.5rem;
      margin-block-end: 0.85rem;
      border-bottom: 1px solid var(--c-rule);
    }
    .group__head h3 {
      margin: 0;
      font-size: 0.92rem;
      font-weight: 700;
    }
    .group__head p {
      margin: 0.3rem 0 0;
      font-size: 0.82rem;
      color: var(--c-mut);
    }
    .group__head p code { background: #ece3d0; padding: 0 0.3rem; }

    .row {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 0.85rem;
      padding-block: 0.7rem;
      border-bottom: 1px solid rgba(0,0,0,0.04);
      position: relative;
    }
    .row:last-child { border-bottom: 0; }
    .row.is-hidden { display: none; }

    .row__swatch-area {
      position: relative;
      display: flex;
      align-items: center;
      gap: 0.45rem;
    }
    .row__dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      background: transparent;
      flex: 0 0 auto;
      transition: background 0.2s ease;
    }
    .row__dot.is-modified { background: var(--c-mod); }
    .row input[type="color"] {
      width: 44px;
      height: 34px;
      padding: 0;
      border: 1px solid var(--c-rule);
      cursor: pointer;
      background: transparent;
    }
    .row input[type="color"]::-webkit-color-swatch-wrapper { padding: 2px; }
    .row input[type="color"]::-webkit-color-swatch { border: 0; }

    .row__meta {
      display: grid;
      gap: 0.15rem;
      min-width: 0;
    }
    .row__name {
      font-weight: 600;
      font-size: 0.9rem;
    }
    .row__hint {
      font-size: 0.78rem;
      color: var(--c-mut);
      line-height: 1.4;
    }
    .row__token-name {
      font-family: ui-monospace, 'Inter', monospace;
      font-size: 0.72rem;
      color: var(--c-mut);
    }
    .row__contrast {
      display: inline-block;
      margin-inline-start: 0.45rem;
      padding: 0 0.4rem;
      font-size: 0.66rem;
      letter-spacing: 0.08em;
      font-weight: 700;
      border: 1px solid currentColor;
      border-radius: 2px;
      color: var(--c-mut);
    }
    .row__contrast--aaa { color: #3f7b3f; }
    .row__contrast--aa  { color: #5e5c2e; }
    .row__contrast--lo  { color: #a53623; }

    .row__controls {
      display: grid;
      grid-template-columns: 1fr auto auto auto;
      gap: 0.35rem;
      align-items: center;
    }
    .row__btn--show {
      /* Distinct accent so the "preview only" button reads differently
         from copy/reset which actually modify state. */
      color: var(--c-acc);
      border-color: var(--c-acc);
    }
    .row__btn--show:hover {
      background: var(--c-acc);
      color: #fff;
    }
    .row__btn--show.is-pulsing {
      animation: showBtnPulse 1.2s ease-out;
    }
    @keyframes showBtnPulse {
      0%   { box-shadow: 0 0 0 0 rgba(168,137,71,0.45); }
      50%  { box-shadow: 0 0 0 6px rgba(168,137,71,0); }
      100% { box-shadow: 0 0 0 0 rgba(168,137,71,0); }
    }
    .row__hex {
      width: 92px;
      font-family: ui-monospace, 'Inter', monospace;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      padding: 0.4rem 0.55rem;
      background: #fff;
      color: var(--c-fg);
      border: 1px solid var(--c-rule);
      text-transform: uppercase;
    }
    .row__hex:focus { outline: 2px solid var(--c-acc); outline-offset: -2px; }
    .row__hex.is-invalid { border-color: #a53623; color: #a53623; }
    .row__btn {
      font: inherit;
      font-size: 0.85rem;
      width: 32px; height: 32px;
      display: grid;
      place-items: center;
      background: transparent;
      color: var(--c-mut);
      border: 1px solid var(--c-rule);
      cursor: pointer;
      transition: color 0.2s, border-color 0.2s, background 0.2s;
    }
    .row__btn:hover { color: var(--c-fg); border-color: var(--c-fg); }
    .row__btn[disabled] { opacity: 0.35; cursor: not-allowed; }
    .row__btn:focus { outline: 2px solid var(--c-acc); outline-offset: -2px; }

    /* ── Preview pane ──────────────────────────────────────── */
    .preview-pane {
      position: sticky;
      top: 5.5rem;
      align-self: start;
      max-height: calc(100vh - 7rem);
      overflow: auto;
      padding-right: 0.25rem;
    }
    .preview-pane h2 {
      font-size: 0.78rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--c-mut);
      margin: 0 0 0.35rem;
      font-weight: 700;
    }
    .preview-pane__intro {
      margin: 0 0 1rem;
      color: var(--c-mut);
      font-size: 0.85rem;
    }

    /* Highlight pulse for the element(s) affected by the currently
       edited token. */
    .preview-fragment {
      position: relative;
      transition: box-shadow 0.2s ease;
    }
    .preview-fragment.is-highlighted {
      animation: pulseHighlight 1.4s var(--c-ease, ease-out);
      z-index: 1;
    }
    @keyframes pulseHighlight {
      0%   { box-shadow: 0 0 0 0   rgba(217,119,6, 0.85),  0 0 0 0 rgba(217,119,6, 0.18); }
      40%  { box-shadow: 0 0 0 3px rgba(217,119,6, 0.85),  0 0 0 10px rgba(217,119,6, 0.10); }
      100% { box-shadow: 0 0 0 0   rgba(217,119,6, 0),     0 0 0 0  rgba(217,119,6, 0); }
    }

    /* ─────────────────────────────────────────────────────────
       Simulated public site preview. Every block here is a 1:1
       structural mirror of a real section on the site — what the
       sim uses, the real site uses. If you change which tokens
       a real section consumes, mirror the change here.
       ───────────────────────────────────────────────────────── */
    .sim {
      padding: 0;
      border: 1px solid var(--paper-edge, #D8CCAE);
      overflow: hidden;
    }
    /* Page wrapper — bg = --paper. Pulses on paper edit. */
    .sim__page {
      background: var(--paper, #F0E8D2);
      color: var(--ink, #1A1410);
      display: grid;
      gap: 1.1rem;
      padding: 0 0 1.25rem;
    }

    /* HERO — photographic strip with floating header. The photograph
       is a fixed-black gradient so it doesn't pulse on --ink change. */
    .sim__hero {
      position: relative;
      background:
        linear-gradient(180deg, rgba(10,8,6,0.55) 0%, rgba(10,8,6,0.18) 35%, rgba(10,8,6,0.62) 100%),
        linear-gradient(135deg, #6e5a44, #2a221b);
      padding: 0.7rem 0.9rem 1.4rem;
      color: var(--paper-on-photo, #F4ECCF);
      display: grid;
      gap: 1rem;
      min-height: 220px;
    }
    .sim__hero-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.7rem;
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      font-weight: 600;
    }
    .sim__hero-brand { font-family: Georgia, serif; font-size: 0.78rem; letter-spacing: 0.18em; }
    .sim__hero-navs { opacity: 0.85; flex: 1; text-align: center; }
    .sim__hero-reserve {
      border: 1px solid var(--paper-on-photo, #F4ECCF);
      padding: 0.25rem 0.6rem;
    }
    .sim__hero-body { display: grid; gap: 0.4rem; align-self: end; }
    .sim__hero-eyebrow {
      display: inline-flex; align-items: center; gap: 0.55rem;
      font-size: 0.64rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      font-weight: 600;
      margin: 0;
    }
    .sim__hero-eyebrow::before {
      content: '';
      width: 1.2rem; height: 1px;
      background: var(--accent, #A88947);
    }
    .sim__hero-title {
      font-family: Georgia, serif;
      font-size: 1.4rem;
      letter-spacing: -0.018em;
      line-height: 1.05;
      margin: 0;
    }
    .sim__hero-btns { display: flex; gap: 0.4rem; }
    .sim__hero-btn {
      padding: 0.4rem 0.9rem;
      background: var(--paper-on-photo, #F4ECCF);
      color: var(--ink, #1A1410);
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      font-weight: 600;
      border: 1px solid var(--paper-on-photo, #F4ECCF);
    }
    .sim__hero-btn.is-ghost {
      background: transparent;
      color: var(--paper-on-photo, #F4ECCF);
    }

    /* INFO STRIP — sits under hero on the home page. */
    .sim__info-strip {
      background: var(--paper-deep, #E5DCC4);
      padding: 0.7rem 0.9rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.9rem;
      margin-block-start: -1.1rem;
      position: relative;
    }
    .sim__info-cell { display: grid; gap: 0.15rem; }
    .sim__info-cell > span {
      font-size: 0.6rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      font-weight: 600;
      color: var(--ink-muted, #8A7E68);
    }
    .sim__info-cell > strong {
      font-size: 0.82rem;
      color: var(--ink, #1A1410);
      font-weight: 500;
    }

    /* ISSUE STAMP — masthead under hero. */
    .sim__issue {
      background: var(--paper-deep, #E5DCC4);
      padding: 0.6rem 0.9rem;
      display: flex;
      gap: 0.6rem;
      align-items: center;
      justify-content: center;
      font-size: 0.6rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      font-weight: 600;
      color: var(--ink-muted, #8A7E68);
      border-block: 1px solid var(--rule-soft, #E2D8BB);
      flex-wrap: wrap;
    }
    .sim__issue > span:last-child {
      font-family: Georgia, serif;
      font-style: italic;
      letter-spacing: 0.06em;
      text-transform: none;
      font-weight: 400;
      color: var(--ink-soft, #3D362E);
    }
    .sim__issue-rule {
      width: 1.6rem; height: 1px;
      background: var(--accent, #A88947);
    }

    /* EDITORIAL ARTICLE. */
    .sim__article { padding: 0.4rem 1rem 0.6rem; display: grid; gap: 0.55rem; }
    .sim__eyebrow {
      font-size: 0.62rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--ink-muted, #8A7E68);
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      margin: 0;
    }
    .sim__eyebrow::before {
      content: '';
      width: 1.3rem; height: 1px;
      background: var(--accent, #A88947);
    }
    .sim__title {
      font-family: Georgia, serif;
      font-size: 1.55rem;
      line-height: 1.05;
      letter-spacing: -0.018em;
      margin: 0;
      color: var(--ink, #1A1410);
    }
    .sim__body {
      color: var(--ink-soft, #3D362E);
      font-size: 0.86rem;
      line-height: 1.65;
      margin: 0;
      font-weight: 300;
    }
    .sim__btn-row { display: flex; gap: 0.45rem; flex-wrap: wrap; margin-block-start: 0.4rem; }
    .sim__btn {
      font: inherit;
      font-size: 0.64rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      font-weight: 500;
      padding: 0.45rem 1rem;
      background: var(--ink, #1A1410);
      color: var(--paper-on-photo, #F4ECCF);
      border: 1px solid var(--ink, #1A1410);
      cursor: default;
    }
    .sim__btn.is-ghost {
      background: transparent;
      color: var(--ink, #1A1410);
    }

    /* DIVIDERS */
    .sim__rule {
      height: 1px;
      background: var(--rule, #CFC3A4);
      width: calc(100% - 2rem);
      margin-inline: 1rem;
    }
    .sim__rule--soft { background: var(--rule-soft, #E2D8BB); }

    /* MENU-PAGE COCKTAIL CARD. */
    .sim__card {
      background: var(--paper-card, #F7F0DB);
      border: 1px solid var(--paper-edge, #D8CCAE);
      padding: 0.85rem 1rem;
      margin-inline: 1rem;
      display: grid;
      gap: 0.4rem;
    }
    .sim__card-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 0.8rem;
      align-items: baseline;
      padding-block: 0.35rem;
      border-bottom: 1px solid var(--rule-soft, #E2D8BB);
    }
    .sim__card-row:last-child { border-bottom: 0; }
    .sim__card-row strong { font-weight: 600; color: var(--ink, #1A1410); }
    .sim__card-row span:last-child {
      color: var(--accent, #A88947);
      font-weight: 600;
    }

    /* PULL QUOTE — soft accent tint. */
    .sim__quote {
      background: var(--accent-soft, #EAE0BD);
      padding: 0.85rem 1rem;
      margin-inline: 1rem;
      color: var(--ink, #1A1410);
      font-family: Georgia, serif;
      font-size: 0.95rem;
      line-height: 1.5;
    }
    .sim__quote em { color: var(--gold, #B69A52); font-style: italic; }

    /* MENU-CINEMA chapter — text on photograph. */
    .sim__cinema {
      position: relative;
      background:
        linear-gradient(180deg, rgba(10,8,6,0.30) 0%, rgba(10,8,6,0.15) 30%, rgba(10,8,6,0.55) 100%),
        linear-gradient(135deg, #4a3a2d, #1f1812);
      padding: 1rem 1rem 0.95rem;
      color: var(--paper-on-photo, #F4ECCF);
      display: grid;
      gap: 0.55rem;
    }
    .sim__cinema-eyebrow {
      font-size: 0.62rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      font-weight: 600;
    }
    .sim__cinema-eyebrow [data-uses="accent"] { color: var(--accent, #A88947); }
    .sim__cinema-title {
      font-family: Georgia, serif;
      font-size: 1.4rem;
      letter-spacing: -0.02em;
      line-height: 1;
      margin: 0;
    }
    .sim__cinema-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 0.7rem;
      align-items: baseline;
      font-size: 0.82rem;
      padding-block-end: 0.4rem;
      border-block-end: 1px solid color-mix(in srgb, var(--paper-on-photo, #F4ECCF) 18%, transparent);
    }
    .sim__cinema-desc {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 300;
      opacity: 0.85;
      line-height: 1.4;
    }
    .sim__cinema-row > span:last-child {
      color: var(--accent, #A88947);
      font-weight: 600;
    }
    .sim__cinema-cta {
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      font-weight: 500;
      padding: 0.45rem 0.85rem;
      border: 1px solid var(--paper-on-photo, #F4ECCF);
      justify-self: start;
    }

    /* TOC — dotted leader between chapter title and caption. */
    .sim__toc { padding: 0.4rem 1rem; display: grid; gap: 0.4rem; }
    .sim__toc-row {
      display: grid;
      grid-template-columns: auto auto 1fr auto;
      align-items: baseline;
      gap: 0.55rem;
      padding-block: 0.4rem;
      border-block-end: 1px solid var(--rule-soft, #E2D8BB);
      font-size: 0.82rem;
    }
    .sim__toc-row > span:nth-child(1) { font-family: Georgia, serif; font-weight: 500; color: var(--accent, #A88947); }
    .sim__toc-row > span:nth-child(2) { font-family: Georgia, serif; color: var(--ink, #1A1410); }
    .sim__toc-row > span:last-child {
      color: var(--ink-soft, #3D362E);
      font-size: 0.72rem;
      font-style: italic;
    }
    .sim__toc-dots {
      border-block-end: 2px dotted var(--ink-faint, #B6A98C);
      align-self: end;
      transform: translateY(-0.32rem);
      min-width: 1rem;
    }

    /* CATEGORY CHIPS. */
    .sim__chip-row {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
    }
    .sim__chip {
      font-size: 0.62rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 700;
      padding: 0.3rem 0.6rem;
      border: 1px solid currentColor;
    }
    .sim__chip--green { color: var(--c-green, #5A786A); }
    .sim__chip--teal  { color: var(--c-teal,  #3E6D77); }
    .sim__chip--slate { color: var(--c-slate, #3E5359); }
    .sim__chip--mauve { color: var(--c-mauve, #9D8499); }
    .sim__chip--gold  { color: var(--gold,    #B69A52); }

    /* CONTACT TOGGLE — sliding accent indicator under active button. */
    .sim__toggle {
      position: relative;
      display: grid;
      grid-template-columns: 1fr 1fr;
      background: var(--paper-card, #F7F0DB);
      border: 1px solid var(--rule, #CFC3A4);
      margin-inline: 1rem;
    }
    .sim__toggle-btn {
      padding: 0.55rem 0.85rem;
      font-size: 0.66rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      font-weight: 600;
      text-align: center;
      color: var(--ink-muted, #8A7E68);
    }
    .sim__toggle-btn.is-active { color: var(--ink, #1A1410); }
    .sim__toggle-indicator {
      position: absolute;
      inset-block-end: 0;
      inset-inline-start: 0;
      height: 2px;
      width: 50%;
      background: var(--accent, #A88947);
    }

    /* REACH-US card on /contact/ — phone + email row. */
    .sim__reach {
      background: var(--paper-card, #F7F0DB);
      border: 1px solid var(--rule-soft, #E2D8BB);
      padding: 0.85rem 1rem;
      margin-inline: 1rem;
      display: grid;
      gap: 0.45rem;
    }
    .sim__reach-row {
      display: grid;
      grid-template-columns: minmax(4.5rem, 6rem) 1fr;
      align-items: baseline;
      gap: 0.8rem;
    }
    .sim__reach-row > span {
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--ink-muted, #8A7E68);
      font-weight: 600;
    }
    .sim__reach-link {
      color: var(--ink, #1A1410);
      text-decoration: underline;
      text-decoration-color: var(--accent, #A88947);
      text-underline-offset: 3px;
      font-size: 0.85rem;
    }
    .sim__reach-link:hover { color: var(--accent-deep, #7A6231); }

    /* FAINT METADATA. */
    .sim__faint {
      font-size: 0.7rem;
      color: var(--ink-faint, #B6A98C);
      padding-inline: 1rem;
      margin: 0;
    }

    /* FORM STATUS. */
    .sim__status-row {
      display: grid;
      gap: 0.4rem;
      padding-inline: 1rem;
    }
    .sim__status {
      padding: 0.5rem 0.7rem;
      font-size: 0.76rem;
      font-weight: 600;
    }
    .sim__status--ok  { background: color-mix(in srgb, var(--ok,  #4F6B47) 12%, transparent); color: var(--ok,  #4F6B47); }
    .sim__status--err { background: color-mix(in srgb, var(--err, #A53623) 12%, transparent); color: var(--err, #A53623); }

    /* ── Toast ─────────────────────────────────────────────── */
    .toast {
      position: fixed;
      inset-block-end: 1.5rem;
      inset-inline-end: 1.5rem;
      z-index: 30;
      padding: 0.7rem 1rem;
      background: var(--c-fg);
      color: var(--c-bg);
      font-size: 0.8rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-weight: 600;
      opacity: 0;
      transform: translateY(8px);
      pointer-events: none;
      transition: opacity 0.25s, transform 0.25s;
    }
    .toast.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── Export modal ──────────────────────────────────────── */
    .export-modal {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.55);
      display: grid;
      place-items: center;
      padding: 1.5rem;
      z-index: 40;
    }
    .export-modal[hidden] { display: none; }
    .export-modal__inner {
      background: var(--c-bg);
      padding: 1.5rem;
      border: 1px solid var(--c-rule);
      max-width: 560px;
      width: 100%;
      display: grid;
      gap: 1rem;
    }
    .export-modal h2 {
      margin: 0;
      font-size: 1rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }
    .export-modal textarea {
      width: 100%;
      min-height: 320px;
      padding: 0.85rem;
      font-family: ui-monospace, 'Inter', monospace;
      font-size: 0.78rem;
      line-height: 1.55;
      background: #fff;
      color: var(--c-fg);
      border: 1px solid var(--c-rule);
      resize: vertical;
    }
    .export-modal__row {
      display: flex;
      gap: 0.55rem;
      justify-content: flex-end;
    }

    /* Keyboard-shortcut hint chip */
    .kbd {
      display: inline-block;
      padding: 0.05rem 0.35rem;
      font-family: ui-monospace, 'Inter', monospace;
      font-size: 0.7rem;
      background: #eee5cf;
      border: 1px solid #d3c89e;
      border-radius: 3px;
      margin-inline-start: 0.4rem;
      color: var(--c-mut);
    }
  </style>
</head>
<body>
  <header class="editor-top">
    {/* Row 1 — admin nav (shared across /admin, /admin/images,
        /admin/colors). The active page is highlighted and non-clickable. */}
    <nav class="editor-top__nav" aria-label="Admin sections">
      <a class="editor-top__brand" href="/admin/">Zahara · Admin</a>
      <a class="editor-top__navlink"            href="/admin/">Menu editor</a>
      <a class="editor-top__navlink"            href="/admin/images/">Images</a>
      <a class="editor-top__navlink is-active"  href="/admin/colors/" aria-current="page">Colors</a>
      <span class="editor-top__spacer"></span>
      <a class="editor-top__site" href="/" target="_blank">View site ↗</a>
    </nav>

    {/* Row 2 — palette-editor specific tools */}
    <div class="editor-top__tools">
      <h1>Palette editor</h1>
      <input type="search" class="top-search" data-search
             placeholder="Search tokens…" aria-label="Search tokens"
             style="max-width:220px;" />
      <select class="top-select" data-preset aria-label="Preset themes">
        <option value="">Preset…</option>
        <optgroup label="Light">
          <option value="default">Default (current)</option>
          <option value="terracotta">Terracotta (old)</option>
          <option value="monochrome">Monochrome</option>
          <option value="forest">Forest</option>
          <option value="navy">Navy</option>
          <option value="midnight">Midnight (your palette)</option>
        </optgroup>
        <optgroup label="Dark">
          <option value="dark-frantzen">Dark · Frantzen</option>
          <option value="dark-white">Dark + white</option>
          <option value="dark-white-purple">Dark + white + purple</option>
        </optgroup>
      </select>
      <span style="flex:1"></span>
      <button class="btn-top btn-top--ghost" type="button" data-undo title="Undo (⌘Z)" disabled>↶ Undo</button>
      <button class="btn-top btn-top--ghost" type="button" data-reset>Reset all</button>
      <button class="btn-top" type="button" data-export>Export CSS</button>
    </div>
  </header>

  <main class="layout">
    <section class="side" aria-label="Token pickers">
      <h2>Tokens</h2>
      <p class="side__intro">
        Every change writes to <code>:root</code>, saves to
        <code>localStorage</code>, and broadcasts to any open site tab
        via <code>BroadcastChannel</code>. The preview on the right
        pulses the elements affected by whatever token you edit.
        Click the <span class="kbd">👁</span> button on any row to
        highlight its affected elements WITHOUT changing the value.
        Press <span class="kbd">⌘Z</span> / <span class="kbd">Ctrl+Z</span> to undo.
      </p>

      {groups.map((g) => (
        <div class="group" data-group>
          <div class="group__head">
            <h3>{g.group}</h3>
            <p set:html={g.intro} />
          </div>
          {g.tokens.map((t) => (
            <div class="row"
                 data-row
                 data-token={t.token}
                 data-short={t.shortName}
                 data-default={t.def}
                 data-search-key={(t.label + ' ' + t.token + ' ' + (t.hint || '')).toLowerCase()}>
              <div class="row__swatch-area">
                <span class="row__dot" data-modified-dot title="Modified from default"></span>
                <input type="color" value={t.def} data-picker aria-label={t.label} />
              </div>
              <div class="row__meta">
                <div class="row__name">
                  {t.label}
                  <span class="row__contrast" data-contrast aria-label="Contrast vs --paper"></span>
                </div>
                {t.hint && <div class="row__hint">{t.hint}</div>}
                <div class="row__token-name"><code>{t.token}</code></div>
              </div>
              <div class="row__controls">
                <input type="text"
                       class="row__hex"
                       data-hex
                       value={t.def}
                       maxlength="7"
                       inputmode="text"
                       autocomplete="off"
                       spellcheck="false"
                       aria-label={`${t.label} hex value`} />
                <button class="row__btn row__btn--show" type="button"
                        data-show
