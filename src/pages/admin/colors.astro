                        aria-label="Highlight affected preview elements">👁</button>
                <button class="row__btn" type="button" data-copy title="Copy hex">⧉</button>
                <button class="row__btn" type="button" data-reset-one title="Reset this token">↺</button>
              </div>
            </div>
          ))}
        </div>
      ))}
    </section>

