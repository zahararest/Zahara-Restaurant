---
// ─────────────────────────────────────────────────────────────────────────────
//
// Architecture notes
// ──────────────────
// • Token groups + Token definitions live here (server-side) because Astro
//   uses them to render the HTML row elements. This is the correct Astro
//   pattern for static server-rendered data.
//
// • PRESETS are defined inside the <script> tag below — they are purely
//   client-side data. Keeping them here in the frontmatter and passing them
//   via define:vars was unnecessary. Only `defaults` (the token→hex map) is
//   passed via define:vars because it is derived from the array above.
//
// • STAGING MODEL: applyToken() applies to :root immediately so the preview
//   updates live, but does NOT write to localStorage or broadcast to other
//   tabs. Only clicking "Save" (or ⌘S / Ctrl+S) persists changes. "Discard"
//   reverts all unsaved changes.

const TITLE = 'Color editor · Zahara';

interface Token {
  token:     string;
  label:     string;
  def:       string;
  hint?:     string;
  shortName: string;
}
interface Group {
  group:  string;
  intro:  string;
  tokens: Token[];
}

const groups: Group[] = [
  {
    group: 'Paper & surfaces',
    intro: 'Cream / paper tones. <code>--paper</code> is the page background everywhere. The others are progressively raised surfaces. Changing any of these shifts large background areas across the whole site.',
    tokens: [
      {
        token:     '--paper',
        shortName: 'paper',
        label:     'Paper — page background',
        hint:      'Full page background on every page (home, menu, contact, location). Also the mobile nav drawer, gallery background, and the scrollbar track tint.',
        def:       '#F0E8D2',
      },
      {
        token:     '--paper-deep',
        shortName: 'paper-deep',
        label:     'Paper deep — raised bands',
        hint:      'Footer background. Info-strip band below the hero. Issue-stamp masthead band. Menu section group card gradient base. Scrollbar track background.',
        def:       '#E5DCC4',
      },
      {
        token:     '--paper-edge',
        shortName: 'paper-edge',
        label:     'Paper edge — card outer border',
        hint:      'Strong outer borders on raised cards: /menu/ cocktail cards and the /contact/ form-card edge.',
        def:       '#D8CCAE',
      },
      {
        token:     '--paper-card',
        shortName: 'paper-card',
        label:     'Paper card — card fill',
        hint:      'Filled card surfaces on /menu/ (cocktail cards) and /contact/ (form panel + reach-us card). Also form input backgrounds, the contact-page tab toggle, and the section-HUD pill.',
        def:       '#F7F0DB',
      },
      {
        token:     '--paper-on-photo',
        shortName: 'paper-on-photo',
        label:     'Paper on photo — text over photography',
        hint:      '⚠ Wide-impact token. ALL text and UI over photographs: floating header text (brand, nav, reserve) when on a hero page, hero eyebrow/title/CTA buttons, intro-photo page titles, menu-cinema chapter text + prices, skip-link background, and — crucially — the TEXT colour inside solid dark buttons (Reserve, active menu tab). Changing this shifts both on-photo reading text and dark-button label colour.',
        def:       '#F4ECCF',
      },
    ],
  },
  {
    group: 'Ink (text)',
    intro: 'Text colours from solid through faint. <strong>Important:</strong> <code>--ink</code> is dual-role — it colours both <em>text</em> and the <em>background of solid dark buttons</em>. Lightening it will also lighten those button fills.',
    tokens: [
      {
        token:     '--ink',
        shortName: 'ink',
        label:     'Ink — text & dark-button background',
        hint:      '⚠ Dual-role token. (1) All headlines, primary body text on paper. (2) Background of all solid dark buttons (Reserve, body CTAs, active menu tabs). (3) Form input text + select arrows. (4) Footer text. Changing from near-black affects both reading text AND button fills simultaneously.',
        def:       '#1A1410',
      },
      {
        token:     '--ink-soft',
        shortName: 'ink-soft',
        label:     'Ink soft — body paragraph text',
        hint:      'Long-form paragraph text: home story editorial body, photo-block paragraphs, hero lede, menu item descriptions, cocktail card descriptions, form card intro text.',
        def:       '#3D362E',
      },
      {
        token:     '--ink-muted',
        shortName: 'ink-muted',
        label:     'Ink muted — labels & secondary',
        hint:      'All eyebrow labels, form field labels, footer section heads, info-strip cell labels, footer copyright/meta, menu metadata bar, inactive menu-tab text, wine legend, section-HUD label, the contact toggle inactive button.',
        def:       '#8A7E68',
      },
      {
        token:     '--ink-faint',
        shortName: 'ink-faint',
        label:     'Ink faint — decorative details',
        hint:      'TOC dotted leader lines (the dots between chapter title and caption), wine price separator between bottle / glass, secondary footnote metadata.',
        def:       '#B6A98C',
      },
    ],
  },
  {
    group: 'Rules & dividers',
    intro: 'Horizontal rules and borders. Strong rules separate major sections; soft rules live inside cards and between items.',
    tokens: [
      {
        token:     '--rule',
        shortName: 'rule',
        label:     'Rule — strong dividers',
        hint:      'Strong dividers between major sections, form input borders (unfocused state), the accessibility-panel border, menu-tab hover border, section-HUD border.',
        def:       '#CFC3A4',
      },
      {
        token:     '--rule-soft',
        shortName: 'rule-soft',
        label:     'Rule soft — card internals',
        hint:      'Quiet dividers inside cards and form rows, between menu items, footer bottom border, footer top border, cocktail card row dividers, wine legend border, form submit row border, mobile nav CTA divider, info-strip top/bottom border.',
        def:       '#E2D8BB',
      },
    ],
  },
  {
    group: 'Primary accent',
    intro: 'The single accent the site uses for emphasis — prices, hover underlines, tab indicators, eyebrow rules, the scroll progress bar, the scrollbar thumb.',
    tokens: [
      {
        token:     '--accent',
        shortName: 'accent',
        label:     'Accent — primary (gold/mustard)',
        hint:      'Every menu price (home + /menu/ page), eyebrow rule mark (the short line before eyebrow labels), the sliding tab indicator on /menu/ and /contact/, nav link hover underline, scroll progress bar gradient start, info-strip sub-labels hover, wine legend dot, editorial drop-cap, draw-rule underlines, menu item hover accent bar, section diamond flourish, active menu tab ping ring, scrollbar thumb gradient.',
        def:       '#A88947',
      },
      {
        token:     '--accent-deep',
        shortName: 'accent-deep',
        label:     'Accent deep — pressed / hover',
        hint:      'Hover state for accent-coloured links, the reach-us email/phone underline hover on /contact/, hero CTA button hover background, scrollbar thumb hover, menu-item name hover colour.',
        def:       '#7A6231',
      },
      {
        token:     '--accent-soft',
        shortName: 'accent-soft',
        label:     'Accent soft — selection & pull-quote',
        hint:      'Text selection highlight background (the highlight you see when dragging to select text across the entire site). Pull-quote background tint on the home page.',
        def:       '#EAE0BD',
      },
    ],
  },
  {
    group: 'Highlights & category accents',
    intro: 'Gold highlight plus four category accents pulled from the printed-menu bands. The category colours mark the /menu/ chapter chips and section identifiers.',
    tokens: [
      {
        token:     '--gold',
        shortName: 'gold',
        label:     'Gold — secondary highlight',
        hint:      'Italic emphasis word inside the chef pull-quote, scroll progress bar gradient end, menu-section-group corner glow, scrollbar thumb gradient end.',
        def:       '#B69A52',
      },
      {
        token:     '--c-green',
        shortName: 'c-green',
        label:     'Category — green (food)',
        hint:      'Sage green band for the food / starters section chip on /menu/.',
        def:       '#5A786A',
      },
      {
        token:     '--c-teal',
        shortName: 'c-teal',
        label:     'Category — teal (cocktails)',
        hint:      'Deep teal band. Cocktails section chip on /menu/.',
        def:       '#3E6D77',
      },
      {
        token:     '--c-slate',
        shortName: 'c-slate',
        label:     'Category — slate (wine)',
        hint:      'Slate / petrol band. Wine section chip on /menu/.',
        def:       '#3E5359',
      },
      {
        token:     '--c-mauve',
        shortName: 'c-mauve',
        label:     'Category — mauve (desserts)',
        hint:      'Dusty mauve band. Desserts section chip on /menu/.',
        def:       '#9D8499',
      },
    ],
  },
  {
    group: 'Status colours',
    intro: 'Used by the contact/events form feedback messages and the accessibility statement page.',
    tokens: [
      {
        token:     '--ok',
        shortName: 'ok',
        label:     'Success — form OK',
        hint:      'Successful contact-form submission message colour (text + tinted background).',
        def:       '#4F6B47',
      },
      {
        token:     '--err',
        shortName: 'err',
        label:     'Error — form failure',
        hint:      'Form validation failures and network-error messages (text + tinted background).',
        def:       '#A53623',
      },
    ],
  },
];

const allTokens = groups.flatMap((g) => g.tokens);
const defaults  = Object.fromEntries(allTokens.map((t) => [t.token, t.def]));
// Presets live in the <script> below — no define:vars needed for them.
---

<!doctype html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{TITLE}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
  <style>
    /* ── Editor UI tokens (isolated from the site palette) ── */
    :root {
      --e-bg:     #fafaf7;
      --e-fg:     #1a1410;
      --e-mut:    #6f6457;
      --e-rule:   #e2d8c4;
      --e-acc:    #a88947;
      --e-mod:    #d97706;
      --e-pend:   #2563eb;
      --e-save:   #1a6b44;
      --e-disc:   #8B2020;
    }
    *, *::before, *::after { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--e-bg);
      color: var(--e-fg);
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 14px;
      line-height: 1.55;
    }
    code { font-family: ui-monospace, monospace; font-size: 0.85em; }

    /* ── Top bar ─────────────────────────────────────────────── */
    header.editor-top {
      position: sticky; top: 0; z-index: 20;
      background: rgba(250,250,247,0.96);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--e-rule);
      padding: 0.55rem 1.25rem;
      display: grid;
      gap: 0.45rem;
    }
    .editor-top__nav {
      display: flex; align-items: center; gap: 0.45rem; flex-wrap: wrap;
    }
    .editor-top__brand {
      font-size: 0.75rem; font-weight: 700; letter-spacing: 0.22em;
      text-transform: uppercase; color: var(--e-fg); text-decoration: none;
      padding-inline-end: 0.5rem; border-inline-end: 1px solid var(--e-rule);
      margin-inline-end: 0.25rem; white-space: nowrap;
    }
    .editor-top__navlink {
      font-size: 0.75rem; letter-spacing: 0.16em; text-transform: uppercase;
      font-weight: 600; color: var(--e-mut); text-decoration: none;
      padding: 0.3rem 0.55rem; border: 1px solid transparent;
      transition: color 0.18s, border-color 0.18s, background 0.18s;
      white-space: nowrap;
    }
    .editor-top__navlink:hover { color: var(--e-fg); border-color: var(--e-rule); }
    .editor-top__navlink.is-active {
      color: var(--e-fg); background: #ece3d0; border-color: #d8ccae;
      pointer-events: none;
    }
    .editor-top__spacer { flex: 1; }
    .editor-top__site {
      font-size: 0.75rem; letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--e-acc); font-weight: 600; text-decoration: none;
      padding: 0.3rem 0.55rem; white-space: nowrap;
    }
    .editor-top__site:hover { text-decoration: underline; }

    /* ── Tools row ───────────────────────────────────────────── */
    .editor-top__tools {
      display: flex; gap: 0.45rem; align-items: center; flex-wrap: wrap;
    }
    .editor-top h1 {
      margin: 0; font-size: 0.82rem; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase; color: var(--e-mut);
      white-space: nowrap;
    }
    .top-search {
      flex: 1; max-width: 200px; padding: 0.45rem 0.7rem; font: inherit;
      font-size: 0.82rem; background: #fff; color: var(--e-fg);
      border: 1px solid var(--e-rule);
    }
    .top-search:focus { outline: 2px solid var(--e-acc); outline-offset: -2px; }
    .top-select {
      font: inherit; font-size: 0.75rem; letter-spacing: 0.12em;
      text-transform: uppercase; font-weight: 600; padding: 0.45rem 0.75rem;
      background: #fff; color: var(--e-fg); border: 1px solid var(--e-rule);
      cursor: pointer; max-width: 190px;
    }
    .top-toggle-label {
      display: flex; align-items: center; gap: 0.35rem; cursor: pointer;
      font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--e-mut); user-select: none;
      padding: 0.45rem 0.6rem; border: 1px solid var(--e-rule);
      background: #fff; white-space: nowrap;
    }
    .top-toggle-label input { accent-color: var(--e-acc); margin: 0; }
    .top-toggle-label:hover { color: var(--e-fg); }

    /* Pending badge */
    .pending-badge {
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--e-pend); white-space: nowrap;
      padding: 0.35rem 0.6rem; background: rgba(37,99,235,0.08);
      border: 1px solid rgba(37,99,235,0.22);
    }
    .pending-badge[hidden] { display: none; }

    /* Buttons */
    .btn-top {
      font: inherit; font-size: 0.75rem; letter-spacing: 0.16em;
      text-transform: uppercase; font-weight: 600;
      padding: 0.48rem 0.85rem;
      background: var(--e-fg); color: var(--e-bg);
      border: 1px solid var(--e-fg); cursor: pointer;
      transition: background 0.18s, color 0.18s, border-color 0.18s;
      white-space: nowrap;
    }
    .btn-top:hover { background: var(--e-acc); border-color: var(--e-acc); }
    .btn-top:disabled { opacity: 0.35; cursor: not-allowed; }
    .btn-top--ghost { background: transparent; color: var(--e-fg); }
    .btn-top--ghost:hover { background: transparent; color: var(--e-acc); border-color: var(--e-acc); }
    .btn-top--save {
      background: var(--e-save); border-color: var(--e-save); color: #fff;
    }
    .btn-top--save:hover { background: #145235; border-color: #145235; }
    .btn-top--save:disabled { background: var(--e-fg); border-color: var(--e-fg); opacity: 0.35; }
    .btn-top--discard { color: var(--e-disc); border-color: var(--e-disc); }
    .btn-top--discard:hover { background: var(--e-disc); color: #fff; }

    /* ── Main layout ─────────────────────────────────────────── */
    main.layout {
      display: grid; grid-template-columns: 1fr;
      gap: 0; max-width: 1440px; margin: 0 auto;
      padding: 1.25rem 1.25rem 6rem;
    }
    @media (min-width: 1000px) {
      main.layout { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
    }

    /* ── Token list ──────────────────────────────────────────── */
    .side h2 {
      font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--e-mut); margin: 0 0 0.3rem; font-weight: 700;
    }
    .side__intro { margin: 0 0 1.25rem; color: var(--e-mut); font-size: 0.83rem; }

    .group { margin-block-end: 1.75rem; }
    .group.is-collapsed .group__body { display: none; }

    .group__head {
      padding-block-end: 0.45rem; margin-block-end: 0.75rem;
      border-bottom: 1px solid var(--e-rule);
      display: flex; align-items: flex-start; gap: 0.5rem; cursor: pointer;
      user-select: none;
    }
    .group__head:hover .group__title { color: var(--e-fg); }
    .group__toggle {
      flex-shrink: 0; font-size: 0.7rem; margin-top: 0.15rem;
      color: var(--e-mut); width: 1em; text-align: center;
      transition: transform 0.2s;
    }
    .group.is-collapsed .group__toggle { transform: rotate(-90deg); }
    .group__head-text { flex: 1; min-width: 0; }
    .group__title { margin: 0; font-size: 0.9rem; font-weight: 700; color: var(--e-fg); }
    .group__intro { margin: 0.25rem 0 0; font-size: 0.8rem; color: var(--e-mut); }
    .group__intro code { background: #ece3d0; padding: 0 0.28rem; }
    .group__intro strong { color: var(--e-fg); }

    /* Each token row */
    .row {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: start;
      gap: 0.75rem;
      padding-block: 0.65rem;
      border-bottom: 1px solid rgba(0,0,0,0.04);
      position: relative;
    }
    .row:last-child { border-bottom: 0; }
    .row.is-hidden { display: none; }

    .row__swatch-area {
      display: flex; flex-direction: column; align-items: center; gap: 0.3rem;
      padding-top: 0.1rem;
    }
    .row__dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: transparent; flex-shrink: 0;
      transition: background 0.18s ease;
    }
    .row__dot.is-modified { background: var(--e-mod); }
    .row__dot.is-pending  { background: var(--e-pend); }

    .row input[type="color"] {
      width: 40px; height: 32px; padding: 2px;
      border: 1px solid var(--e-rule); cursor: pointer; background: transparent;
    }
    .row input[type="color"]::-webkit-color-swatch-wrapper { padding: 1px; }
    .row input[type="color"]::-webkit-color-swatch { border: 0; }

    .row__meta { display: grid; gap: 0.12rem; min-width: 0; }
    .row__name { font-weight: 600; font-size: 0.88rem; display: flex; align-items: baseline; gap: 0.35rem; flex-wrap: wrap; }
    .row__hint { font-size: 0.76rem; color: var(--e-mut); line-height: 1.4; }
    .row__token-name { font-family: ui-monospace, monospace; font-size: 0.7rem; color: var(--e-mut); }
    .row__contrast {
      display: inline-block; padding: 0.02rem 0.35rem;
      font-size: 0.64rem; letter-spacing: 0.08em; font-weight: 700;
      border: 1px solid currentColor; border-radius: 2px; color: var(--e-mut);
      line-height: 1.5;
    }
    .row__contrast--aaa { color: #3f7b3f; }
    .row__contrast--aa  { color: #5e5c2e; }
    .row__contrast--lo  { color: #a53623; }

    /* Controls column */
    .row__controls {
      display: grid;
      grid-template-columns: auto auto auto auto auto;
      gap: 0.28rem; align-items: center;
    }
    .row__hex {
      width: 88px; font-family: ui-monospace, monospace; font-size: 0.83rem;
      font-weight: 600; letter-spacing: 0.04em; padding: 0.36rem 0.5rem;
      background: #fff; color: var(--e-fg); border: 1px solid var(--e-rule);
      text-transform: uppercase; grid-column: 1;
    }
    .row__hex:focus { outline: 2px solid var(--e-acc); outline-offset: -2px; }
    .row__hex.is-invalid { border-color: #a53623; color: #a53623; }
    .row__btn {
      font: inherit; font-size: 0.82rem; width: 30px; height: 30px;
      display: grid; place-items: center; background: transparent;
      color: var(--e-mut); border: 1px solid var(--e-rule);
      cursor: pointer; transition: color 0.18s, border-color 0.18s, background 0.18s;
      flex-shrink: 0;
    }
    .row__btn:hover { color: var(--e-fg); border-color: var(--e-fg); }
    .row__btn[disabled] { opacity: 0.35; cursor: not-allowed; }
    .row__btn:focus-visible { outline: 2px solid var(--e-acc); outline-offset: -2px; }
    .row__btn--show { color: var(--e-acc); border-color: var(--e-acc); }
    .row__btn--show:hover { background: var(--e-acc); color: #fff; }
    .row__btn--show.is-pulsing { animation: showPulse 1.2s ease-out; }
    @keyframes showPulse {
      0%   { box-shadow: 0 0 0 0 rgba(168,137,71,0.45); }
      50%  { box-shadow: 0 0 0 6px rgba(168,137,71,0); }
      100% { box-shadow: 0 0 0 0 rgba(168,137,71,0); }
    }

    /* ── Preview pane ────────────────────────────────────────── */
    .preview-pane {
      position: sticky; top: 5.2rem; align-self: start;
      max-height: calc(100vh - 6.5rem); overflow: auto; padding-right: 0.2rem;
    }
    .preview-pane h2 {
      font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--e-mut); margin: 0 0 0.3rem; font-weight: 700;
    }
    .preview-pane__intro { margin: 0 0 0.85rem; color: var(--e-mut); font-size: 0.82rem; }

    /* Fragment highlight pulse */
    .preview-fragment { position: relative; transition: box-shadow 0.18s ease; }
    .preview-fragment.is-highlighted {
      animation: pulseFrag 1.4s ease-out;
      z-index: 1;
    }
    @keyframes pulseFrag {
      0%   { box-shadow: 0 0 0 0   rgba(217,119,6,.85), 0 0 0 0 rgba(217,119,6,.18); }
      40%  { box-shadow: 0 0 0 3px rgba(217,119,6,.85), 0 0 0 10px rgba(217,119,6,.1); }
      100% { box-shadow: 0 0 0 0   rgba(217,119,6,0),   0 0 0 0  rgba(217,119,6,0); }
    }

    /* ── Sim shell ───────────────────────────────────────────── */
    .sim {
      border: 1px solid var(--paper-edge, #D8CCAE);
      overflow: hidden;
      font-family: Georgia, 'Inter', serif;
    }

    /* Scroll progress bar */
    .sim__progress {
      height: 3px;
      background: linear-gradient(90deg, var(--accent, #A88947) 0%, var(--gold, #B69A52) 100%);
      width: 55%;
    }

    /* Non-photo page header (what the header looks like on /menu, /contact etc.) */
    .sim__nav {
      background: color-mix(in srgb, var(--paper, #F0E8D2) 85%, transparent);
      border-bottom: 1px solid var(--rule-soft, #E2D8BB);
      padding: 0.6rem 0.9rem;
      display: flex; align-items: center; justify-content: space-between; gap: 0.6rem;
      font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 600;
    }
    .sim__nav-brand { font-family: Georgia, serif; font-size: 0.72rem; letter-spacing: 0.36em; }
    .sim__nav-links { display: flex; gap: 0.7rem; }
    .sim__nav-links span { color: var(--ink-soft, #3D362E); }
    .sim__nav-links span:last-child {
      color: var(--ink, #1A1410);
      border-bottom: 1px solid var(--accent, #A88947);
      padding-bottom: 1px;
    }
    .sim__nav-reserve {
      border: 1px solid var(--ink, #1A1410);
      padding: 0.2rem 0.55rem; color: var(--ink, #1A1410);
    }

    /* Page bg */
    .sim__page {
      background: var(--paper, #F0E8D2);
      color: var(--ink, #1A1410);
      display: grid; gap: 0; padding: 0 0 0;
    }

    /* HERO */
    .sim__hero {
      position: relative;
      background:
        linear-gradient(180deg, rgba(10,8,6,.58) 0%, rgba(10,8,6,.18) 35%, rgba(10,8,6,.65) 100%),
        linear-gradient(135deg, #6e5a44, #2a221b);
      padding: 0.65rem 0.85rem 1.3rem;
      color: var(--paper-on-photo, #F4ECCF);
      display: grid; gap: 0.9rem; min-height: 200px;
    }
    .sim__hero-bar {
      display: flex; align-items: center; justify-content: space-between; gap: 0.6rem;
      font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 600;
    }
    .sim__hero-brand { font-family: Georgia, serif; font-size: 0.74rem; letter-spacing: 0.34em; }
    .sim__hero-navs  { opacity: 0.82; flex: 1; text-align: center; font-size: 0.56rem; letter-spacing: 0.18em; }
    .sim__hero-reserve {
      border: 1px solid var(--paper-on-photo, #F4ECCF); padding: 0.22rem 0.55rem;
    }
    .sim__hero-body { display: grid; gap: 0.35rem; align-self: end; }
    .sim__hero-eyebrow {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-size: 0.6rem; letter-spacing: 0.28em; text-transform: uppercase; font-weight: 600; margin: 0;
    }
    .sim__hero-eyebrow::before {
      content: ''; width: 1.1rem; height: 1px; background: var(--accent, #A88947);
    }
    .sim__hero-title {
      font-family: Georgia, serif; font-size: 1.35rem; letter-spacing: -0.018em;
      line-height: 1.05; margin: 0;
    }
    .sim__hero-btns { display: flex; gap: 0.35rem; }
    .sim__hero-btn {
      padding: 0.38rem 0.85rem;
      background: var(--ink, #F4ECCF); color: var(--ink-muted, #1A1410);
      font-size: 0.57rem; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 600;
      border: 1px solid var(--paper-on-photo, #F4ECCF); font-family: 'Inter', sans-serif;
    }
    .sim__hero-btn.ghost {
      background: transparent; color: var(--paper-on-photo, #F4ECCF);
    }

    /* INFO STRIP */
    .sim__info-strip {
      background: var(--paper-deep, #E5DCC4);
      padding: 0.65rem 0.85rem;
      display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem;
      border-block: 1px solid var(--rule-soft, #E2D8BB);
    }
    .sim__info-cell { display: grid; gap: 0.12rem; }
    .sim__info-cell > span {
      font-size: 0.57rem; letter-spacing: 0.26em; text-transform: uppercase;
      font-weight: 600; color: var(--ink-muted, #8A7E68); font-family: 'Inter', sans-serif;
    }
    .sim__info-cell > strong { font-size: 0.78rem; color: var(--ink, #1A1410); font-weight: 500; }

    /* ISSUE STAMP */
    .sim__issue {
      background: var(--paper-deep, #E5DCC4);
      padding: 0.55rem 0.85rem;
      display: flex; gap: 0.55rem; align-items: center; justify-content: center;
      font-size: 0.57rem; letter-spacing: 0.26em; text-transform: uppercase;
      font-weight: 600; color: var(--ink-muted, #8A7E68);
      border-block: 1px solid var(--rule-soft, #E2D8BB); flex-wrap: wrap;
      font-family: 'Inter', sans-serif;
    }
    .sim__issue-rule { width: 1.4rem; height: 1px; background: var(--accent, #A88947); }
    .sim__issue .serif {
      font-family: Georgia, serif; font-style: italic; letter-spacing: 0.04em;
      text-transform: none; font-weight: 400; color: var(--ink-soft, #3D362E);
    }

    /* ARTICLE */
    .sim__article { padding: 0.9rem 0.9rem 0.7rem; display: grid; gap: 0.5rem; }
    .sim__eyebrow {
      font-size: 0.58rem; letter-spacing: 0.28em; text-transform: uppercase;
      color: var(--ink-muted, #8A7E68); font-weight: 600;
      display: inline-flex; align-items: center; gap: 0.5rem; margin: 0;
      font-family: 'Inter', sans-serif;
    }
    .sim__eyebrow::before {
      content: ''; width: 1.2rem; height: 1px; background: var(--accent, #A88947);
    }
    .sim__title {
      font-family: Georgia, serif; font-size: 1.45rem; line-height: 1.05;
      letter-spacing: -0.018em; margin: 0; color: var(--ink, #1A1410);
    }
    .sim__body {
      color: var(--ink-soft, #3D362E); font-size: 0.83rem; line-height: 1.65;
      margin: 0; font-weight: 300; font-family: 'Inter', sans-serif;
    }
    .sim__btn-row { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: 0.35rem; }
    .sim__btn {
      font-family: 'Inter', sans-serif; font-size: 0.6rem; letter-spacing: 0.2em;
      text-transform: uppercase; font-weight: 500; padding: 0.42rem 0.9rem;
      background: var(--paper-on-photo, #1A1410); color: var(--ink-muted, #F4ECCF);
      border: 1px solid var(--ink, #1A1410); cursor: default;
    }
    .sim__btn.ghost {
      background: transparent; color: var(--ink, #1A1410);
    }

    /* MENU TABS (shows --ink as active-tab bg) */
    .sim__tabs {
      display: flex; gap: 0.3rem; justify-content: center;
      padding: 0.65rem 0.85rem; border-bottom: 2px solid var(--rule-soft, #E2D8BB);
      background: var(--paper, #F0E8D2); position: relative;
    }
    .sim__tab {
      font-family: 'Inter', sans-serif; font-size: 0.6rem; letter-spacing: 0.2em;
      text-transform: uppercase; font-weight: 500; padding: 0.35rem 0.8rem;
      border: 1px solid transparent; border-radius: 999px;
      color: var(--ink-muted, #8A7E68);
    }
    .sim__tab.is-active {
      background: var(--ink-muted, #1A1410); color: var(--paper-on-photo, #F4ECCF);
      border-color: var(--ink-muted, #1A1410);
    }
    .sim__tab:not(.is-active):hover { border-color: var(--rule, #CFC3A4); color: var(--ink, #1A1410); }
    .sim__tabs-indicator {
      position: absolute; inset-block-end: -2px; inset-inline-start: 0;
      height: 2px; width: 30%;
      background: linear-gradient(90deg, transparent, var(--accent, #A88947) 20%, var(--accent, #A88947) 80%, transparent);
    }

    /* DIVIDERS */
    .sim__rule { height: 1px; background: var(--rule, #CFC3A4); width: calc(100% - 1.8rem); margin-inline: 0.9rem; }
    .sim__rule--soft { background: var(--rule-soft, #E2D8BB); }

    /* MENU CARD */
    .sim__card {
      background: var(--paper-card, #F7F0DB); border: 1px solid var(--paper-edge, #D8CCAE);
      padding: 0.8rem 0.9rem; margin-inline: 0.9rem; display: grid; gap: 0.35rem;
    }
    .sim__card-row {
      display: grid; grid-template-columns: 1fr auto; gap: 0.7rem;
      align-items: baseline; padding-block: 0.3rem;
      border-bottom: 1px solid var(--rule-soft, #E2D8BB);
    }
    .sim__card-row:last-child { border-bottom: 0; }
    .sim__card-row strong { font-weight: 600; color: var(--ink, #1A1410); font-family: 'Inter', sans-serif; font-size: 0.82rem; }
    .sim__card-row span:last-child { color: var(--accent, #A88947); font-weight: 600; font-family: 'Inter', sans-serif; font-size: 0.82rem; }

    /* PULL QUOTE */
    .sim__quote {
      background: var(--accent-soft, #EAE0BD); padding: 0.8rem 0.9rem;
      margin-inline: 0.9rem; color: var(--ink, #1A1410);
      font-family: Georgia, serif; font-size: 0.92rem; line-height: 1.5;
    }
    .sim__quote em { color: var(--gold, #B69A52); font-style: italic; }

    /* MENU CINEMA */
    .sim__cinema {
      position: relative;
      background:
        linear-gradient(180deg, rgba(10,8,6,.32) 0%, rgba(10,8,6,.16) 30%, rgba(10,8,6,.58) 100%),
        linear-gradient(135deg, #4a3a2d, #1f1812);
      padding: 0.9rem 0.9rem 0.85rem; color: var(--paper-on-photo, #F4ECCF);
      display: grid; gap: 0.5rem;
    }
    .sim__cinema-eyebrow {
      font-size: 0.58rem; letter-spacing: 0.26em; text-transform: uppercase; font-weight: 600;
      font-family: 'Inter', sans-serif;
    }
    .sim__cinema-title { font-family: Georgia, serif; font-size: 1.3rem; letter-spacing: -0.02em; line-height: 1; margin: 0; }
    .sim__cinema-row {
      display: grid; grid-template-columns: 1fr auto; gap: 0.65rem;
      align-items: baseline; font-size: 0.78rem; font-family: 'Inter', sans-serif;
      padding-bottom: 0.35rem;
      border-bottom: 1px solid color-mix(in srgb, var(--paper-on-photo, #F4ECCF) 18%, transparent);
    }
    .sim__cinema-row > span:last-child { color: var(--accent, #A88947); font-weight: 600; }
    .sim__cinema-cta {
      font-family: 'Inter', sans-serif; font-size: 0.57rem; letter-spacing: 0.2em;
      text-transform: uppercase; font-weight: 500; padding: 0.4rem 0.8rem;
      border: 1px solid var(--paper-on-photo, #F4ECCF); justify-self: start;
    }

    /* TOC */
    .sim__toc { padding: 0.35rem 0.9rem; display: grid; gap: 0.35rem; }
    .sim__toc-row {
      display: grid; grid-template-columns: auto auto 1fr auto; align-items: baseline;
      gap: 0.5rem; padding-block: 0.35rem; border-bottom: 1px solid var(--rule-soft, #E2D8BB);
      font-size: 0.78rem;
    }
    .sim__toc-row > span:nth-child(1) { font-family: Georgia, serif; font-weight: 500; color: var(--accent, #A88947); }
    .sim__toc-row > span:nth-child(2) { font-family: Georgia, serif; color: var(--ink, #1A1410); }
    .sim__toc-row > span:last-child   { color: var(--ink-soft, #3D362E); font-size: 0.68rem; font-style: italic; font-family: Georgia, serif; }
    .sim__toc-dots {
      border-bottom: 2px dotted var(--ink-faint, #B6A98C); align-self: end;
      transform: translateY(-0.3rem); min-width: 1rem;
    }

    /* CATEGORY CHIPS */
    .sim__chips { display: flex; gap: 0.35rem; flex-wrap: wrap; padding: 0 0.9rem; }
    .sim__chip {
      font-family: 'Inter', sans-serif; font-size: 0.58rem; letter-spacing: 0.16em;
      text-transform: uppercase; font-weight: 700; padding: 0.28rem 0.55rem;
      border: 1px solid currentColor;
    }
    .sim__chip--green { color: var(--c-green, #5A786A); }
    .sim__chip--teal  { color: var(--c-teal,  #3E6D77); }
    .sim__chip--slate { color: var(--c-slate, #3E5359); }
    .sim__chip--mauve { color: var(--c-mauve, #9D8499); }
    .sim__chip--gold  { color: var(--gold,    #B69A52); }

    /* CONTACT TOGGLE */
    .sim__toggle {
      position: relative; display: grid; grid-template-columns: 1fr 1fr;
      background: var(--paper-card, #F7F0DB); border: 1px solid var(--rule, #CFC3A4);
      margin-inline: 0.9rem;
    }
    .sim__toggle-btn {
      padding: 0.5rem 0.8rem; font-family: 'Inter', sans-serif; font-size: 0.62rem;
      letter-spacing: 0.2em; text-transform: uppercase; font-weight: 600; text-align: center;
      color: var(--ink-muted, #8A7E68);
    }
    .sim__toggle-btn.is-active { color: var(--ink, #1A1410); }
    .sim__toggle-ind {
      position: absolute; inset-block-end: 0; inset-inline-start: 0;
      height: 2px; width: 50%; background: var(--accent, #A88947);
    }

    /* REACH-US CARD */
    .sim__reach {
      background: var(--paper-card, #F7F0DB); border: 1px solid var(--rule-soft, #E2D8BB);
      padding: 0.8rem 0.9rem; margin-inline: 0.9rem; display: grid; gap: 0.4rem;
    }
    .sim__reach-row {
      display: grid; grid-template-columns: minmax(4rem, 5.5rem) 1fr;
      align-items: baseline; gap: 0.7rem;
    }
    .sim__reach-row > span {
      font-family: 'Inter', sans-serif; font-size: 0.57rem; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--ink-muted, #8A7E68); font-weight: 600;
    }
    .sim__reach-link {
      color: var(--ink, #1A1410); text-decoration: underline;
      text-decoration-color: var(--accent, #A88947); text-underline-offset: 3px;
      font-family: 'Inter', sans-serif; font-size: 0.82rem;
    }

    /* TEXT SELECTION demo */
    .sim__selection {
      padding: 0.6rem 0.9rem; font-size: 0.82rem; font-family: 'Inter', sans-serif;
      color: var(--ink, #1A1410); line-height: 1.65;
    }
    .sim__sel-mark {
      background: var(--accent-soft, #EAE0BD); color: var(--ink, #1A1410);
    }

    /* FOCUS RING demo */
    .sim__focus-demo {
      padding: 0.5rem 0.9rem; display: flex; gap: 0.6rem; align-items: center;
      flex-wrap: wrap;
    }
    .sim__focus-ring {
      outline: 2px solid var(--accent, #A88947); outline-offset: 3px;
      padding: 0.28rem 0.7rem; font-size: 0.6rem; letter-spacing: 0.18em;
      text-transform: uppercase; font-weight: 600; font-family: 'Inter', sans-serif;
      border: 1px solid var(--rule, #CFC3A4); color: var(--ink, #1A1410);
    }

    /* SCROLLBAR demo */
    .sim__scrollbar {
      margin: 0.5rem 0.9rem; display: flex; align-items: stretch; gap: 0; height: 48px;
    }
    .sim__sb-track {
      width: 10px; background: var(--paper-deep, #E5DCC4);
      border-inline-start: 1px solid var(--rule-soft, #E2D8BB); flex-shrink: 0;
      display: flex; flex-direction: column; justify-content: center; align-items: center;
    }
    .sim__sb-thumb {
      width: 6px; height: 28px; border-radius: 999px;
      background: linear-gradient(180deg, var(--accent, #A88947) 0%, var(--accent-deep, #7A6231) 100%);
      border: 2px solid var(--paper-deep, #E5DCC4);
    }
    .sim__sb-label {
      padding-inline-start: 0.5rem; font-size: 0.62rem; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--ink-muted, #8A7E68);
      font-family: 'Inter', sans-serif; align-self: center;
    }

    /* FAINT META */
    .sim__faint {
      font-size: 0.68rem; color: var(--ink-faint, #B6A98C); padding-inline: 0.9rem; margin: 0;
      font-family: 'Inter', sans-serif;
    }

    /* FORM STATUS */
    .sim__status-row { display: grid; gap: 0.35rem; padding-inline: 0.9rem; }
    .sim__status {
      padding: 0.45rem 0.65rem; font-size: 0.74rem; font-weight: 600;
      font-family: 'Inter', sans-serif;
    }
    .sim__status--ok  { background: color-mix(in srgb, var(--ok,  #4F6B47) 12%, transparent); color: var(--ok,  #4F6B47); }
    .sim__status--err { background: color-mix(in srgb, var(--err, #A53623) 12%, transparent); color: var(--err, #A53623); }

    /* FOOTER */
    .sim__footer {
      background: var(--paper-deep, #E5DCC4);
      border-top: 1px solid var(--rule-soft, #E2D8BB);
      padding: 0.9rem;
      margin-top: 0.9rem;
    }
    .sim__footer-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem; margin-bottom: 0.6rem; }
    .sim__footer-block { display: grid; gap: 0.15rem; }
    .sim__footer-label {
      font-family: 'Inter', sans-serif; font-size: 0.55rem; letter-spacing: 0.26em;
      text-transform: uppercase; font-weight: 600; color: var(--ink-muted, #8A7E68);
    }
    .sim__footer-val {
      font-family: Georgia, serif; font-size: 0.82rem; color: var(--ink, #1A1410);
      font-weight: 400;
    }
    .sim__footer-val a { color: var(--ink, #1A1410); }
    .sim__footer-val a:hover { color: var(--accent, #A88947); }
    .sim__footer-bottom {
      display: flex; justify-content: space-between; padding-top: 0.5rem;
      border-top: 1px solid var(--rule-soft, #E2D8BB);
      font-family: 'Inter', sans-serif; font-size: 0.6rem;
      letter-spacing: 0.1em; color: var(--ink-muted, #8A7E68);
    }

    /* ── Palette popup ───────────────────────────────────────── */
    .palette-popup {
      position: fixed; z-index: 50;
      background: #fff; border: 1px solid var(--e-rule);
      padding: 0.7rem; width: 220px;
      box-shadow: 0 6px 24px rgba(0,0,0,0.12);
    }
    .palette-popup[hidden] { display: none; }
    .palette-popup__title {
      font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--e-mut); font-weight: 600; margin: 0 0 0.5rem;
    }
    .palette-popup__grid {
      display: grid; grid-template-columns: repeat(7, 1fr); gap: 0.28rem;
    }
    .palette-swatch {
      width: 100%; aspect-ratio: 1; border: 1px solid rgba(0,0,0,0.12);
      cursor: pointer; transition: transform 0.12s, box-shadow 0.12s;
      padding: 0;
    }
    .palette-swatch:hover { transform: scale(1.18); box-shadow: 0 2px 8px rgba(0,0,0,0.2); z-index: 1; position: relative; }

    /* ── Toast ───────────────────────────────────────────────── */
    .toast {
      position: fixed; inset-block-end: 1.4rem; inset-inline-end: 1.4rem; z-index: 60;
      padding: 0.6rem 0.9rem; background: var(--e-fg); color: var(--e-bg);
      font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600;
      opacity: 0; transform: translateY(8px); pointer-events: none;
      transition: opacity 0.22s, transform 0.22s;
    }
    .toast.is-visible { opacity: 1; transform: translateY(0); }

    /* ── Export modal ────────────────────────────────────────── */
    .export-modal {
      position: fixed; inset: 0; background: rgba(0,0,0,0.52);
      display: grid; place-items: center; padding: 1.5rem; z-index: 55;
    }
    .export-modal[hidden] { display: none; }
    .export-modal__inner {
      background: var(--e-bg); padding: 1.4rem; border: 1px solid var(--e-rule);
      max-width: 580px; width: 100%; display: grid; gap: 0.85rem;
    }
    .export-modal h2 { margin: 0; font-size: 0.95rem; letter-spacing: 0.2em; text-transform: uppercase; }
    .export-modal p  { margin: 0; font-size: 0.82rem; color: var(--e-mut); }
    .export-modal textarea {
      width: 100%; min-height: 300px; padding: 0.8rem; font-family: ui-monospace, monospace;
      font-size: 0.76rem; line-height: 1.55; background: #fff; color: var(--e-fg);
      border: 1px solid var(--e-rule); resize: vertical;
    }
    .export-modal__tabs {
      display: flex; gap: 0.35rem; border-bottom: 1px solid var(--e-rule); padding-bottom: 0.5rem;
    }
    .export-tab {
      font: inherit; font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase;
      font-weight: 600; padding: 0.3rem 0.65rem; background: transparent;
      color: var(--e-mut); border: 1px solid transparent; cursor: pointer;
      transition: color 0.16s, border-color 0.16s;
    }
    .export-tab.is-active { color: var(--e-fg); border-color: var(--e-rule); background: #ece3d0; }
    .export-modal__row { display: flex; gap: 0.45rem; justify-content: flex-end; }

    .kbd {
      display: inline-block; padding: 0.04rem 0.32rem;
      font-family: ui-monospace, monospace; font-size: 0.68rem;
      background: #eee5cf; border: 1px solid #d3c89e; border-radius: 3px;
      margin-inline-start: 0.35rem; color: var(--e-mut);
    }
  </style>
</head>
<body>

<header class="editor-top">
  <nav class="editor-top__nav" aria-label="Admin sections">
    <a class="editor-top__brand" href="/admin/">Zahara · Admin</a>
    <a class="editor-top__navlink"           href="/admin/">Menu editor</a>
    <a class="editor-top__navlink"           href="/admin/images/">Images</a>
    <a class="editor-top__navlink is-active" href="/admin/colors/" aria-current="page">Colors</a>
    <span class="editor-top__spacer"></span>
    <a class="editor-top__site" href="/en/" target="_blank">View site ↗</a>
  </nav>

  <div class="editor-top__tools">
    <h1>Palette editor</h1>

    <input type="search" class="top-search" data-search
           placeholder="Search tokens…" aria-label="Search colour tokens" />

    <select class="top-select" data-preset aria-label="Load a preset theme">
      <option value="">Load preset…</option>
      <optgroup label="Light themes">
        <option value="default">Default (warm cream)</option>
        <option value="monochrome">Monochrome</option>
        <option value="terracotta">Terracotta</option>
        <option value="forest">Forest</option>
        <option value="navy-light">Navy (light)</option>
      </optgroup>
      <optgroup label="Dark themes">
        <option value="midnight">Midnight (dark navy)</option>
        <option value="obsidian">Obsidian (near-black + gold)</option>
        <option value="espresso">Espresso (dark brown)</option>
        <option value="plum">Plum (dark purple)</option>
        <option value="dusk-navy">Dusk Navy (cool slate)</option>
        <option value="charcoal">Charcoal (warm gray + rust)</option>
        <option value="dark-frantzen">Dark · Frantzen (blue)</option>
        <option value="dark-white">Dark + white (stark)</option>
      </optgroup>
    </select>

    <label class="top-toggle-label">
      <input type="checkbox" data-modified-only />
      Modified only
    </label>

    <span class="editor-top__spacer"></span>

    <span class="pending-badge" data-pending-badge hidden>0 unsaved</span>
    <button class="btn-top btn-top--ghost btn-top--discard" type="button"
            data-discard disabled title="Discard all unsaved changes">Discard</button>
    <button class="btn-top btn-top--save" type="button"
            data-save disabled title="Save changes to localStorage &amp; broadcast (⌘S)">
      Save<span class="kbd">⌘S</span>
    </button>
    <button class="btn-top btn-top--ghost" type="button" data-undo
            title="Undo (⌘Z)" disabled>↶ Undo</button>
    <button class="btn-top btn-top--ghost" type="button" data-reset>Reset all</button>
    <button class="btn-top" type="button" data-export>Export CSS</button>
  </div>
</header>

<main class="layout">
  <!-- ── Token list (left pane) ─────────────────────────────── -->
  <section class="side" aria-label="Colour token editors">
    <h2>Tokens</h2>
    <p class="side__intro">
      Changes update the preview immediately but are <strong>not saved</strong>
      until you click <strong>Save</strong> or press
