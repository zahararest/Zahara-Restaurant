  <script is:inline define:vars={{ defaults, presets }}>
    (function () {
      'use strict';
      const KEY  = 'zahara-color-overrides';
      const root = document.documentElement;
      const rows = Array.from(document.querySelectorAll('[data-row]'));
      const toast= document.querySelector('[data-toast]');
      const undoBtn = document.querySelector('[data-undo]');

      let bc = null;
      try { bc = new BroadcastChannel('zahara-colors'); } catch (_) {}

      // ── localStorage state ──────────────────────────────────
      function loadOv() {
        try { return JSON.parse(localStorage.getItem(KEY) || '{}'); }
        catch { return {}; }
      }
      function saveOv(o) {
        try { localStorage.setItem(KEY, JSON.stringify(o)); } catch (_) {}
      }
      const overrides = loadOv();

      // ── Undo history (cap 30) ───────────────────────────────
      const history = [];
      function pushHistory(token, fromValue, toValue) {
        history.push({ token, from: fromValue, to: toValue });
        if (history.length > 30) history.shift();
        undoBtn.disabled = false;
      }
      function undo() {
        const last = history.pop();
        if (!last) { undoBtn.disabled = true; return; }
        // Apply the previous value without recording another history entry.
        applyToken(last.token, last.from, { silent: true });
        if (history.length === 0) undoBtn.disabled = true;
      }
      undoBtn.addEventListener('click', undo);
      document.addEventListener('keydown', (e) => {
        const meta = e.metaKey || e.ctrlKey;
        if (meta && !e.shiftKey && (e.key === 'z' || e.key === 'Z')) {
          e.preventDefault();
          undo();
        }
      });

      // ── Toast ───────────────────────────────────────────────
      let toastTimer = null;
      function showToast(msg) {
        toast.textContent = msg;
        toast.classList.add('is-visible');
        clearTimeout(toastTimer);
        toastTimer = setTimeout(() => toast.classList.remove('is-visible'), 1600);
      }

      // ── Validation / normalisation ──────────────────────────
      function normaliseHex(v) {
        if (!v) return null;
        v = v.trim();
        if (!v.startsWith('#')) v = '#' + v;
        if (!/^#[0-9a-fA-F]{6}$/.test(v)) return null;
        return v.toUpperCase();
      }

      // ── Contrast (WCAG) ─────────────────────────────────────
      function relLum(hex) {
        const m = hex.replace('#','').match(/.{2}/g);
        if (!m) return 0;
        const [r, g, b] = m.map((s) => {
          let c = parseInt(s, 16) / 255;
          return c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
        });
        return 0.2126 * r + 0.7152 * g + 0.0722 * b;
      }
      function contrast(a, b) {
        const la = relLum(a), lb = relLum(b);
        const [lo, hi] = la > lb ? [lb, la] : [la, lb];
        return (hi + 0.05) / (lo + 0.05);
      }
      function rateContrast(value, row) {
        // For text-coloured tokens (ink*, accent*, status), measure
        // contrast against the current paper.  For everything else,
        // skip — there's no obvious "second colour" to compare.
        const token = row.dataset.token;
        const isText = /^--(ink|accent|gold|c-|ok|err)/.test(token);
        if (!isText) return null;
        const paper = root.style.getPropertyValue('--paper').trim() ||
                      defaults['--paper'];
        const c = contrast(value, paper);
        let band, label;
        if      (c >= 7)   { band = 'aaa'; label = c.toFixed(2) + ':1 AAA'; }
        else if (c >= 4.5) { band = 'aa';  label = c.toFixed(2) + ':1 AA';  }
        else if (c >= 3)   { band = 'aa';  label = c.toFixed(2) + ':1 AA-L';}
        else               { band = 'lo';  label = c.toFixed(2) + ':1 lo';  }
        return { band, label };
      }
      function refreshAllContrast() {
        rows.forEach((row) => {
          const value = root.style.getPropertyValue(row.dataset.token).trim()
                     || row.dataset.default;
          const badge = row.querySelector('[data-contrast]');
          const c = rateContrast(value, row);
          if (!c) { badge.textContent = ''; badge.className = 'row__contrast'; return; }
          badge.textContent = c.label;
          badge.className = 'row__contrast row__contrast--' + c.band;
        });
      }

      // ── Highlight affected preview fragments ─────────────────
      let highlightTimer = null;
      function highlight(token) {
        // Find every fragment whose data-uses includes this token's
        // short name (without the `--` prefix).
        const short = token.replace(/^--/, '');
        document.querySelectorAll('.preview-fragment.is-highlighted')
          .forEach((el) => el.classList.remove('is-highlighted'));
        // Re-trigger the animation by forcing reflow.
        requestAnimationFrame(() => {
          document.querySelectorAll('.preview-fragment').forEach((el) => {
            const uses = (el.dataset.uses || '').split(',').map((s) => s.trim());
            if (uses.includes(short)) el.classList.add('is-highlighted');
          });
        });
        clearTimeout(highlightTimer);
        highlightTimer = setTimeout(() => {
          document.querySelectorAll('.preview-fragment.is-highlighted')
            .forEach((el) => el.classList.remove('is-highlighted'));
        }, 1500);
      }

      // ── Apply a single token (UI + state + broadcast + history)
      function applyToken(token, value, opts = {}) {
        const row = rows.find((r) => r.dataset.token === token);
        if (!row) return;
        const prev = root.style.getPropertyValue(token).trim() || row.dataset.default;
        const normalised = normaliseHex(value);
        if (!normalised) return;

        if (!opts.silent && prev !== normalised) {
          pushHistory(token, prev, normalised);
        }

        // Apply to :root. If the new value equals the project default,
        // REMOVE the inline override instead of setting it — that way
        // the editor itself reverts to the global.css :root declaration,
        // matching the behaviour the broadcast listener gives other tabs.
        if (normalised === row.dataset.default) {
          root.style.removeProperty(token);
          delete overrides[token];
        } else {
          root.style.setProperty(token, normalised);
          overrides[token] = normalised;
        }
        saveOv(overrides);

        // Sync UI inputs (picker + hex)
        const picker = row.querySelector('[data-picker]');
        const hex    = row.querySelector('[data-hex]');
        if (picker.value.toUpperCase() !== normalised) picker.value = normalised;
        if (document.activeElement !== hex && hex.value.toUpperCase() !== normalised) {
          hex.value = normalised;
        }
        hex.classList.remove('is-invalid');

        // Modified dot
        const isModified = normalised !== row.dataset.default;
        row.querySelector('[data-modified-dot]').classList.toggle('is-modified', isModified);

        // Refresh contrast labels (paper changes affect every text token)
        refreshAllContrast();

        // Visual highlight on the preview
        if (!opts.silent) highlight(token);

        if (bc) bc.postMessage({ type: 'colors-changed', overrides });
        if (!opts.silent) showToast('Saved');
      }

      // ── Wire each row ──────────────────────────────────────
      rows.forEach((row) => {
        const token  = row.dataset.token;
        const def    = row.dataset.default;
        const picker = row.querySelector('[data-picker]');
        const hex    = row.querySelector('[data-hex]');
        const show   = row.querySelector('[data-show]');
        const copy   = row.querySelector('[data-copy]');
        const resetOne = row.querySelector('[data-reset-one]');

        // Init from existing overrides. Only ACTUAL overrides (non-default
        // values) get an inline style — defaults inherit from global.css
        // :root, matching applyToken's reset-to-default behaviour.
        const initial = overrides[token] || def;
        picker.value = initial;
        hex.value    = initial.toUpperCase();
        if (initial.toUpperCase() !== def.toUpperCase()) {
          root.style.setProperty(token, initial);
          row.querySelector('[data-modified-dot]').classList.add('is-modified');
        } else {
          root.style.removeProperty(token);
        }

        // Picker → live update
        picker.addEventListener('input', () => {
          applyToken(token, picker.value);
        });

        // Hex text input — debounced live update, validates as the
        // user types. Paste works because it's a normal text input.
        let hexTimer = null;
        hex.addEventListener('input', () => {
          const v = normaliseHex(hex.value);
          if (!v) {
            hex.classList.add('is-invalid');
            return;
          }
          hex.classList.remove('is-invalid');
          clearTimeout(hexTimer);
          hexTimer = setTimeout(() => applyToken(token, v), 180);
        });
        // On blur, fully normalise the displayed value
        hex.addEventListener('blur', () => {
          const v = normaliseHex(hex.value);
          if (v) hex.value = v;
          else   hex.value = root.style.getPropertyValue(token).trim() || def;
          hex.classList.remove('is-invalid');
        });
        // Select all on focus (easier to paste over)
        hex.addEventListener('focus', () => hex.select());

        // "Show" — highlights the preview elements that use this token
        // WITHOUT changing any value. Useful for exploring what an
        // edit would affect before committing to a colour change.
        show.addEventListener('click', () => {
          highlight(token);
          show.classList.remove('is-pulsing');
          // Re-trigger animation on the button itself for instant feedback.
          requestAnimationFrame(() => show.classList.add('is-pulsing'));
          setTimeout(() => show.classList.remove('is-pulsing'), 1300);
        });

        // Copy hex to clipboard
        copy.addEventListener('click', async () => {
          try { await navigator.clipboard.writeText(hex.value); }
          catch { /* clipboard might be blocked */ }
          showToast('Copied ' + hex.value);
        });

        // Reset this token to default
        resetOne.addEventListener('click', () => {
          applyToken(token, def);
        });
      });

      refreshAllContrast();

      // ── Search / filter ─────────────────────────────────────
      const searchInput = document.querySelector('[data-search]');
      searchInput.addEventListener('input', () => {
        const q = searchInput.value.trim().toLowerCase();
        rows.forEach((r) => {
          const match = !q || r.dataset.searchKey.includes(q);
          r.classList.toggle('is-hidden', !match);
        });
        // Hide groups that became empty
        document.querySelectorAll('[data-group]').forEach((g) => {
          const visible = g.querySelectorAll('[data-row]:not(.is-hidden)').length;
          g.style.display = visible ? '' : 'none';
        });
      });

      // ── Preset themes ───────────────────────────────────────
      const presetSelect = document.querySelector('[data-preset]');
      presetSelect.addEventListener('change', () => {
        const name = presetSelect.value;
        if (!name || !presets[name]) return;
        const palette = presets[name];
        // Apply all tokens (records each in history)
        for (const [tk, value] of Object.entries(palette)) {
          applyToken(tk, value);
        }
        showToast('Applied: ' + name);
        presetSelect.value = '';
      });

      // ── Reset all ───────────────────────────────────────────
      document.querySelector('[data-reset]').addEventListener('click', () => {
        if (!confirm('Reset every token back to the project default?')) return;
        // Remove every inline custom-property override; don't re-set the
        // defaults inline (those live in :root in global.css).
        for (const t of Object.keys(overrides)) {
          delete overrides[t];
          root.style.removeProperty(t);
        }
        rows.forEach((row) => {
          const def = row.dataset.default;
          row.querySelector('[data-picker]').value = def;
          row.querySelector('[data-hex]').value    = def.toUpperCase();
          row.querySelector('[data-hex]').classList.remove('is-invalid');
          row.querySelector('[data-modified-dot]').classList.remove('is-modified');
          // Make sure no stale inline style lingers from earlier sessions.
          root.style.removeProperty(row.dataset.token);
        });
        saveOv({});
        history.length = 0;
        undoBtn.disabled = true;
        refreshAllContrast();
        if (bc) bc.postMessage({ type: 'reset' });
        showToast('Reset');
      });

      // ── Export modal ────────────────────────────────────────
      const modal    = document.querySelector('[data-export-modal]');
      const textarea = document.querySelector('[data-export-textarea]');
      function buildCss() {
        const lines = [];
        rows.forEach((row) => {
          const token = row.dataset.token;
          const value = (root.style.getPropertyValue(token).trim()
                       || row.dataset.default).toUpperCase();
          lines.push('  ' + token.padEnd(18) + ': ' + value + ';');
        });
        return ':root {\n' + lines.join('\n') + '\n}';
      }
      document.querySelector('[data-export]').addEventListener('click', () => {
        textarea.value = buildCss();
        modal.hidden = false;
        textarea.select();
      });
      document.querySelector('[data-export-close]').addEventListener('click', () => {
        modal.hidden = true;
      });
      document.querySelector('[data-export-copy]').addEventListener('click', async () => {
        try { await navigator.clipboard.writeText(textarea.value); }
        catch { textarea.select(); document.execCommand('copy'); }
        const btn = document.querySelector('[data-export-copy]');
        const original = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = original; }, 1400);
      });
      modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.hidden = true;
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal.hidden) modal.hidden = true;
      });
    })();
  </script>
</body>
</html>
