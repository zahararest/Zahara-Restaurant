# Cloudflare Pages — response headers.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/
# Order matters: most specific rules should win; CF applies all matching rules.

# ── Security hardening (all routes) ──────────────────────────────────────
# We intentionally do NOT set a restrictive script-src CSP: the site relies on
# many inlined scripts (Astro inlines them) plus optionally-injected Google
# Ads/Analytics, so a strict policy would break the page. We still get the
# high-value protections below, including clickjacking defence via
# frame-ancestors (the modern replacement for X-Frame-Options).
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Content-Security-Policy: frame-ancestors 'self'
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-DNS-Prefetch-Control: on

# ── Caching ──────────────────────────────────────────────────────────────
# Hashed, immutable build assets (Astro emits content-hashed filenames).
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts never change at a given URL.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Root static assets have no content hash, so cache moderately rather than
# letting them fall back to revalidate-every-load (PageSpeed flags this as
# inefficient cache lifetimes). Icons use a 1-day TTL (not a week) so a logo
# swap propagates at the edge within a day instead of lingering.
/favicon.svg
  Cache-Control: public, max-age=86400
/favicon.ico
  Cache-Control: public, max-age=86400
/favicon-96.png
  Cache-Control: public, max-age=86400
/apple-touch-icon.png
  Cache-Control: public, max-age=86400
/icon-192.png
  Cache-Control: public, max-age=86400
/icon-512.png
  Cache-Control: public, max-age=86400
/site.webmanifest
  Cache-Control: public, max-age=604800
/robots.txt
  Cache-Control: public, max-age=86400
/menu.pdf
  Cache-Control: public, max-age=86400

# The admin panel must never be cached or framed by anyone.
/admin/*
  Cache-Control: no-store
  X-Robots-Tag: noindex, nofollow
