  }
  if (file.size > MAX_BYTES2) {
    return json6({ ok: false, error: `File exceeds ${MAX_BYTES2} bytes` }, 413);
  }
  if (file.type && !VALID_TYPES.has(file.type)) {
    return json6({ ok: false, error: `Unsupported content-type: ${file.type}` }, 415);
  }
  const buffer = new Uint8Array(await file.arrayBuffer());
  const detected = detectImageType2(buffer);
  if (!detected) {
    return json6({ ok: false, error: "File does not look like an image" }, 415);
  }
  try {
    await env.IMAGES.put(`images/${objectKey}`, buffer, {
      httpMetadata: { contentType: detected }
    });
  } catch (err) {
    console.error("[admin/images/upload] R2 put failed", err);
    return json6({ ok: false, error: "Storage failed" }, 500);
  }
  await bumpAssetVersion(env);
  const origin = new URL(request.url).origin;
  if (!isMobile) {
    await purgePhotoCache(origin, meta.filename, env);
    for (const dep of PHOTO_CATALOGUE) {
      if (dep.fallbackKey === key) await purgePhotoCache(origin, dep.filename, env);
    }
  }
  return json6({ ok: true, key, variant: isMobile ? "mobile" : "desktop", size: buffer.byteLength, type: detected });
}, "onRequestPost");

