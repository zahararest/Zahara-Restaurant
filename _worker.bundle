// api/instagram.ts
export const onRequestGet = async ({ env }) => {
  const token = env.INSTAGRAM_ACCESS_TOKEN;
  const userId = env.INSTAGRAM_USER_ID;

  if (!token || !userId) {
    return Response.json({ profile: null, stories: [], posts: [], configured: false }, { status: 500 });
  }

  try {
    // 1. The Magic Field Expansion String
    // We ask for profile fields, then nest the specific fields we want from stories and media.
    // Notice how we can even apply the .limit(12) directly inside the nested media query!
    const fields = [
      "profile_picture_url",
      "username",
      "stories{id,media_type,media_url,thumbnail_url,permalink,timestamp}",
      "media.limit(12){id,media_type,media_product_type,media_url,thumbnail_url,permalink,caption,timestamp}"
    ].join(",");

    const url = `https://graph.instagram.com/v25.0/${userId}?fields=${fields}&access_token=${token}`;

    // 2. The Single Fetch
    const res = await fetch(url, { cf: { cacheTtl: 300 } });
if (!res.ok) {
        // This is the magic line we need to read!
        const errorBody = await res.text(); 
        
        console.error('\n🚨 META API REJECTION DETAILS 🚨');
        console.error('Status:', res.status);
        console.error('Reason:', errorBody);
        console.error('----------------------------------\n');
        
        return emptyFallback();
    }
    const data = await res.json();

    if (data.error) {
      console.error("Meta API returned error:", data.error.message);
      return Response.json({ profile: null, stories: [], posts: [], configured: true, error: "meta_internal_error" });
    }

    // 3. Destructure and Safely Parse the Unified Response
    const profile = {
      username: data.username,
      avatarUrl: data.profile_picture_url
    };

    // Graph API nests expanded edges inside a 'data' array.
    // If there are no stories, data.stories will be undefined, so we default to []
    const stories = data.stories?.data ?? [];
    
    // Grab the media, default to empty array, and apply your safety filter
    const posts = (data.media?.data ?? []).filter(
      (p) => p.media_type === "IMAGE" || p.media_type === "CAROUSEL_ALBUM" || p.media_type === "VIDEO"
    );

    // 4. Return your perfect JSON payload
    return Response.json({ profile, stories, posts, configured: true }, { 
      headers: { "Cache-Control": "public, max-age=300" } 
    });

  } catch (err) {
    console.error("Instagram fetch failed:", err);
    return Response.json({ profile: null, stories: [], posts: [], configured: true, error: "fetch_failed" });
  }
};
function jsonResponse(body, maxAge) {
  return new Response(JSON.stringify(body), {
