      <header class="card__head">
        <p class="card__label">${esc2(p.label)}</p>
        <p class="card__where">${esc2(p.where)}</p>
        <p class="card__token"><code>${esc2(p.key)}</code></p>
        <p class="card__missing-note" data-missing-note ${showMissingNote ? "" : "hidden"}>
          No image stored \u2014 visitors see a broken photo here. Upload one to fix.
        </p>
        <p class="card__optional-note" data-optional-note ${showOptionalNote ? "" : "hidden"}>
          ${esc2(p.note ?? "Optional slot \u2014 empty. Upload a photo to add it to the home gallery.")}
        </p>
      </header>
      <div class="card__actions">
        <form data-form-upload>
          <input class="card__file-input" type="file" data-input-file
                 accept="image/jpeg,image/png,image/webp" />
          <p class="card__file-name" data-file-name></p>
          <div class="card__row" style="margin-top:0.55rem">
            <button class="btn" type="submit" data-btn-upload>Upload</button>
            <button class="btn btn--ghost btn--sm" type="button" data-btn-edit>Edit &amp; adjust</button>
          </div>
        </form>
        <div class="card__row">
          <button class="btn btn--ghost btn--sm" type="button" data-btn-choose>Choose existing</button>
          <button class="btn btn--ghost btn--sm" type="button" data-btn-delete>Remove override</button>
        </div>
        <p class="card__status" data-status></p>
        ${caption ? `
        <div class="card__caption">
          <p class="card__caption-label">Gallery caption <span>shown on this photo in the home gallery</span></p>
          <input class="card__caption-input" type="text" dir="rtl"
                 data-caption-key="${esc2(galleryCaptionKey(p.key))}" data-caption-lang="he"
                 value="${esc2(caption.he ?? "")}" placeholder="\u05DB\u05D9\u05EA\u05D5\u05D1 (\u05E2\u05D1\u05E8\u05D9\u05EA)" />
          <input class="card__caption-input" type="text" dir="ltr"
                 data-caption-key="${esc2(galleryCaptionKey(p.key))}" data-caption-lang="en"
                 value="${esc2(caption.en ?? "")}" placeholder="Caption (English)" />
          <p class="card__caption-status" data-caption-status></p>
