             ${p.optional ? 'data-optional="1"' : ""}
             ${fallbackFromLabel ? `data-fallback-label="${esc2("Using " + fallbackFromLabel)}"` : ""}>
      <div class="card__thumb" data-thumb-zone>
        <img data-thumb data-src="/photos/${esc2(p.filename)}" data-fallback="${esc2(fallback)}"
             src="${esc2(src)}" alt="${esc2(p.label)}" loading="lazy" decoding="async"
             onerror="this.style.opacity=0.25" />
        <span class="card__badge ${badgeClass}" data-badge>${esc2(badgeText)}</span>
        ${tags.length ? `<div class="card__tags">${tags.join("")}</div>` : ""}
