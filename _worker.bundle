        const im = new Image();
        im.crossOrigin = 'anonymous';   // same-origin photos; keeps canvas untainted
        im.onload = () => {
          img = im;
          metaEl.textContent = im.naturalWidth + ' \xD7 ' + im.naturalHeight + ' px source';
          applyB.disabled = false;
          setStatus('', false);
          drawPreview();
        };
